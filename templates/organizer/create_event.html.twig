{% extends 'base.html.twig' %}

{% block title %}Create Event{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="animated-title text-center mb-5">Create New Event</h1>

        <div class="glass-card p-5 shadow mx-auto" style="max-width: 600px;">
            <form>
                <div class="mb-3 custom-input-group p-2">
                    <input type="text" class="form-control" placeholder="Event Name">
                </div>
                <div class="mb-3 custom-input-group p-2">
                    <input type="date" class="form-control">
                </div>
                <div class="mb-3 custom-input-group p-2">
                    <textarea class="form-control" placeholder="Event Description" rows="4"></textarea>
                </div>
                <button type="submit" class="btn btn-glow w-100">Create Event</button>
            </form>
        </div>
    </div>
{% endblock %}
