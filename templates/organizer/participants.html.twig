{% extends 'base.html.twig' %}

{% block title %}Event Participants{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="animated-title text-center mb-5">Participants of Event #{{ id }}</h1>

        <div class="glass-card p-4 shadow table-responsive">
            <table class="table table-dark table-striped table-hover">
                <thead>
                <tr>
                    <th>Participant ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Registration Date</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>1</td>
                    <td>John Doe</td>
                    <td>john@example.com</td>
                    <td>2026-01-01</td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>Jane Smith</td>
                    <td>jane@example.com</td>
                    <td>2026-01-02</td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
