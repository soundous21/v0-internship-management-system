{% extends 'base.html.twig' %}

{% block title %}Organizer Dashboard{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="animated-title text-center mb-5">Organizer Dashboard</h1>

        <div class="row g-4">
            <!-- My Events Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 shadow">
                    <h5 class="text-white"><i class="bi bi-calendar-event-fill"></i> My Events</h5>
                    <h2 class="text-white mt-2">12</h2>
                    <a href="{{ path('organizer_manage_event', {'id': 1}) }}" class="btn btn-glow mt-3 w-100">Manage Events</a>
                </div>
            </div>

            <!-- Participants Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 shadow">
                    <h5 class="text-white"><i class="bi bi-people-fill"></i> Participants</h5>
                    <h2 class="text-white mt-2">150</h2>
                    <a href="{{ path('organizer_event_participants', {'id': 1}) }}" class="btn btn-glow mt-3 w-100">View Participants</a>
                </div>
            </div>

            <!-- Create Event Card -->
            <div class="col-md-4">
                <div class="glass-card p-4 shadow">
                    <h5 class="text-white"><i class="bi bi-plus-circle-fill"></i> New Event</h5>
                    <h2 class="text-white mt-2">+</h2>
                    <a href="{{ path('organizer_create_event') }}" class="btn btn-glow mt-3 w-100">Create Event</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

