    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>🎓</text></svg>">

        {# استدعاء Bootstrap 5 CSS من الـ CDN لتسهيل العمل #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        {# استدعاء أيقونات Bootstrap #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        {# خط Google Fonts (Geist أو Inter يشبه خط الفيديو) #}
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script>
        // التأكد من الوضع المختار فور تحميل الصفحة
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <style>
        :root {
            /* الوضع الفاتح */
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --text-color: #1e293b;
            --border-color: #e2e8f0;
        }

        [data-theme="dark"] {
            /* الوضع المظلم */
            --bg-body: #000000;
            --bg-card: #09090b;
            --text-color: #ffffff;
            --border-color: #1f2937;
        }

        /* تطبيق المتغيرات على جسم الصفحة */
        body {
            background-color: var(--bg-body) !important;
            color: var(--text-color) !important;
            transition: 0.3s;
        }
    </style>
        <style>
            :root {
                --bg-dark: #030712;
                --card-bg: #000000;
                --border-color: rgb(9, 8, 11);
                --text-muted: #94a3b8;
            }
            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--bg-dark);
                color: #ffffff;
                margin: 0;
            }
            .navbar {
                background-color: rgba(3, 7, 18, 0.8);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid var(--border-color);
            }
            .nav-link { color: var(--text-muted) !important; }
            .nav-link:hover { color: #ffffff !important; }
            .navbar-brand { font-weight: 800; letter-spacing: -1px; }
        </style>


        {% block stylesheets %}
            {# هنا تضع ملفات الـ CSS الإضافية إذا كنت تستخدم Webpack Encore #}
