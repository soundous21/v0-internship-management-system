<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Advanced Conference System{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --deep-black: #050505;
            --royal-blue: #0052D4;
            --bourgeois-purple: #e3c0fb; /* البنفسجي البرجوازي الملكي */
            --pure-white: #ffffff;
            --soft-blue: #9cecfb;
        }
        body {
            margin: 0;
            /* مزيج الألوان المطلوبة في الخلفية */
            background: radial-gradient(circle at center, var(--royal-blue) 0%, var(--royal-blue) 30%, var(--deep-black) 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            font-family: 'Segoe UI', sans-serif;
        }

        .robot-glow-container {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid var(--pure-white);
            border-radius: 50%;
            position: relative;
            box-shadow: 0 0 25px rgba(255, 255, 255, 0.3), 0 0 50px rgba(75, 0, 130, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .glass-card {
            /* بطاقة زجاجية تميل للسواد والفخامة */
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.15) !important;
            border-radius: 30px !important;
        }

        .animated-title {
            font-size: 4rem;
            font-weight: 900;
            /* مزيج الأبيض والأزرق في النص */
            background: linear-gradient(to right, var(--pure-white), var(--soft-blue), var(--pure-white));
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 3s linear infinite;
        }

        @keyframes shine { to { background-position: 200% center; } }

        .btn-glow {
            /* زر يجمع البنفسجي والأزرق */
            background: linear-gradient(45deg, var(--bourgeois-purple), var(--royal-blue));
            color: var(--pure-white);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50px;
            transition: 0.4s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-glow:hover {
            box-shadow: 0 0 20px var(--royal-blue);
            transform: scale(1.02);
            color: var(--pure-white);
        }

        .custom-input-group {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .form-control { color: var(--pure-white) !important; }
        .form-control::placeholder { color: rgba(255,255,255,0.4); }
    </style>
</head>
<body>
{% block body %}{% endblock %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
