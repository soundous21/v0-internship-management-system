<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Stage.io{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2290%22>🎓</text></svg>">

        {# استدعاء Bootstrap 5 CSS من الـ CDN لتسهيل العمل #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        {# استدعاء أيقونات Bootstrap #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
        {# خط Google Fonts (Geist أو Inter يشبه خط الفيديو) #}
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

        <style>
            :root {
                --bg-dark: #030712;
                --card-bg: #000000;
                --border-color: #09080b;
                --text-muted: #94a3b8;
            }
            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--bg-dark);
                color: #ffffff;
                margin: 0;
            }
            .navbar {
                background-color: rgba(3, 7, 18, 0.8);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid var(--border-color);
            }
            .nav-link { color: var(--text-muted) !important; }
            .nav-link:hover { color: #ffffff !important; }
            .navbar-brand { font-weight: 800; letter-spacing: -1px; }
        </style>

        {% block stylesheets %}
            {# هنا تضع ملفات الـ CSS الإضافية إذا كنت تستخدم Webpack Encore #}
        {% endblock %}
</head>
<body>
{# --- الـ Navbar العلوي (كما يظهر في الفيديو) --- #}
<nav class="navbar navbar-expand-lg sticky-top py-3">
    <div class="container">
        <a class="navbar-brand text-white d-flex align-items-center" href="{{ path('app_home') }}">
            <i class="bi bi-layers-fill me-2 text-primary"></i> Stag.io
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="#">Features</a></li>
                <li class="nav-item"><a class="nav-link" href="#">For Who</a></li>
                <li class="nav-item"><a class="nav-link" href="#">About</a></li>
            </ul>
          {# <div class="d-flex align-items-center gap-3">
                <a href="#" class="nav-link">Sign In</a>
                <a href="#" class="btn btn-light fw-bold px-4 rounded-pill">Sign Up</a>
            </div>#}
            <div class="d-flex align-items-center gap-3">
                <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#signInModal">
                    Sign In
                </button>

            </div>
        </div>
    </div>
</nav>

{# --- المحتوى المتغير (الذي كتبناه في الخطوة السابقة) --- #}
<main>
    {% block body %}{% endblock %}
</main>

{# استدعاء Bootstrap JS (ضروري للقوائم والـ Modals) #}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}
    {# هنا تضع ملفات الـ JS الإضافية #}
{% endblock %}
</body>
</html>