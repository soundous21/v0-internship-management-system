{% extends 'base.html.twig' %}

{% block title %}My Profile - Scientific Event{% endblock %}

{% block body %}
    <div class="container py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card glass-card p-4 text-white border-0 shadow-lg">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center mb-3 mb-md-0">
                            <div class="robot-glow-container mx-auto" style="width: 120px; height: 120px;">
                                <i class="bi bi-person-badge text-white" style="font-size: 3.5rem;"></i>
                            </div>
                        </div>
                        <div class="col-md-9 text-center text-md-start">
                            <h2 class="fw-bold mb-1">Dr. Full Name</h2>
                            <p class="mb-2" style="color: var(--soft-blue)">
                                <i class="bi bi-mortarboard-fill me-2"></i>Senior Researcher at University of Constantine 2
                            </p>
                            <span class="badge bg-info text-dark px-3 rounded-pill">ROLE_AUTHOR</span>
                        </div>
                    </div>

                    <hr class="my-4 border-white border-opacity-10">

                    <div class="mb-4">
                        <h5 class="fw-bold" style="color: var(--soft-blue)"><i class="bi bi-info-circle me-2"></i>Biography</h5>
                        <p class="opacity-75 lead fs-6">
                            This is where the user's short biography will appear. It describes their expertise and scientific background in the health domain.
                        </p>
                    </div>

                    <div class="d-flex gap-2 justify-content-center justify-content-md-start">
                        <a href="/profile/edit" class="btn btn-glow px-4">Edit Profile</a>
                        <a href="/logout" class="btn btn-outline-danger border-0 rounded-pill px-4">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}