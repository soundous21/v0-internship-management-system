{% extends 'base.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block body %}
    <div class="container py-5 mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card glass-card p-4 border-0">
                    <h3 class="text-white fw-bold mb-4"><i class="bi bi-pencil-square me-2"></i>UPDATE INFORMATION</h3>

                    <form>
                        <div class="mb-3">
                            <label class="text-white small opacity-75">Full Name</label>
                            <input type="text" class="form-control bg-transparent border-0 border-bottom rounded-0 shadow-none text-white" value="Dr. Full Name">
                        </div>

                        <div class="mb-3">
                            <label class="text-white small opacity-75">Institution / University</label>
                            <input type="text" class="form-control bg-transparent border-0 border-bottom rounded-0 shadow-none text-white" value="University Constantine 2">
                        </div>

                        <div class="mb-4">
                            <label class="text-white small opacity-75">Biography</label>
                            <textarea class="form-control bg-transparent border-white border-opacity-25 rounded-3 text-white" rows="4"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-glow py-3">SAVE CHANGES</button>
                            <a href="/profile" class="btn btn-link text-white text-decoration-none small">Cancel and go back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}