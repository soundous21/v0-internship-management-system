                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table data-table table-hover">
                        <thead>
                        <tr>
                            <th scope="col">اسم الحدث</th>
                            <th scope="col">المنظم</th>
                            <th scope="col">التاريخ</th>
                            <th scope="col">المشاركون</th>
                            <th scope="col">الحالة</th>
                            <th scope="col" class="text-center">الإجراءات</th>
                        </tr>
                        </thead>
                        <tbody id="eventsTable">
                        <!-- سيتم ملء البيانات ديناميكياً -->
                        </tbody>
                    </table>
                </div>

                <!-- ترقيم الصفحات -->
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item disabled">
                            <a class="page-link bg-transparent border-0" href="#">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link bg-transparent border-0" href="#">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>

            <!-- تذييل الصفحة -->
            <div class="footer text-center py-3 mt-4">
                <p class="mb-2">© 2024 نظام المؤتمرات المتطور. جميع الحقوق محفوظة.</p>
                <p class="mb-0 small">
                    <i class="fas fa-server me-2"></i> إصدار النظام: 2.4.1 |
                    <i class="fas fa-clock ms-3 me-2"></i> آخر تحديث: 10 دقائق
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // بيانات المخططات
        const activityCtx = document.getElementById('activityChart').getContext('2d');
        const eventsCtx = document.getElementById('eventsChart').getContext('2d');

        // مخطط نشاط المستخدمين
        const activityChart = new Chart(activityCtx, {
            type: 'line',
            data: {
                labels: ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو'],
                datasets: [{
                    label: 'المستخدمين النشطين',
                    data: [120, 190, 300, 500, 200, 300],
                    borderColor: '#9d4edd',
                    backgroundColor: 'rgba(157, 78, 221, 0.1)',
                    borderWidth: 3,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.7)'
                        }
                    },
                    x: {
                        grid: {
                            color: 'rgba(255, 255, 255, 0.1)'
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.7)'
                        }
                    }
                }
            }
        });

        // مخطط توزيع الأحداث
        const eventsChart = new Chart(eventsCtx, {
            type: 'doughnut',
            data: {
                labels: ['مؤتمرات', 'ندوات', 'ورش عمل', 'أيام علمية'],
                datasets: [{
                    data: [40, 30, 20, 10],
                    backgroundColor: [
                        '#9d4edd',
                        '#00f5ff',
                        '#c77dff',
                        '#ff6b6b'
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: 'rgba(255, 255, 255, 0.8)',
                            padding: 20
                        }
                    }
                }
            }
        });

        // بيانات الجدول
        const eventsData = [
            {
                name: 'المؤتمر العالمي للصحة الرقمية',
                organizer: 'د. أحمد محمد',
                date: '15-20 مايو 2024',
                participants: '450',
                status: 'active'
            },
            {
                name: 'ورشة الذكاء الاصطناعي في التشخيص',
                organizer: 'د. سارة خالد',
                date: '10-12 يونيو 2024',
                participants: '120',
                status: 'active'
            },
            {
                name: 'اليوم العلمي للأبحاث الطبية',
                organizer: 'أ. محمد حسن',
                date: '5 أبريل 2024',
                participants: '300',
                status: 'inactive'
            },
            {
                name: 'ندوة الطب الشخصي',
                organizer: 'د. علي عبدالله',
                date: '20-22 يوليو 2024',
                participants: '200',
                status: 'pending'
            },
            {
                name: 'مؤتمر التكنولوجيا الطبية',
                organizer: 'د. فاطمة علي',
                date: '1-3 أغسطس 2024',
                participants: '350',
                status: 'active'
            }
        ];

        // تعبئة الجدول بالبيانات
        function populateEventsTable() {
            const tableBody = document.getElementById('eventsTable');
            tableBody.innerHTML = '';

            eventsData.forEach(event => {
                let statusBadge = '';
                if (event.status === 'active') {
                    statusBadge = '<span class="status-badge status-active">نشط</span>';
                } else if (event.status === 'pending') {
                    statusBadge = '<span class="status-badge status-pending">قيد المراجعة</span>';
                } else {
                    statusBadge = '<span class="status-badge status-inactive">منتهي</span>';
                }

                const row = `
                    <tr>
                        <td>${event.name}</td>
                        <td>${event.organizer}</td>
                        <td>${event.date}</td>
                        <td>${event.participants}</td>
                        <td>${statusBadge}</td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-view" onclick="viewEvent('${event.name}')">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn btn-edit" onclick="editEvent('${event.name}')">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn btn-delete" onclick="deleteEvent('${event.name}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;

                tableBody.innerHTML += row;
            });
        }

        // البحث في الجدول
        document.getElementById('searchInput').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#eventsTable tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // التنقل في الشريط الجانبي
        document.querySelectorAll('#sidebarNav .nav-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();

                // إزالة النشط من جميع الروابط
                document.querySelectorAll('#sidebarNav .nav-link').forEach(item => {
                    item.classList.remove('active');
                });

                // إضافة النشط للرابط الحالي
                this.classList.add('active');

                // تحديث عنوان الصفحة
                const pageName = this.querySelector('span').textContent;
                document.querySelector('.page-title').textContent = `لوحة ${pageName}`;
            });
        });

        // تسجيل الخروج
        document.getElementById('logoutBtn').addEventListener('click', function() {
            if (confirm('هل أنت متأكد من تسجيل الخروج؟')) {
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري تسجيل الخروج...';
                this.disabled = true;

                setTimeout(() => {
                    window.location.href = "login.html";
                }, 1500);
            }
        });

        // الإشعارات
        document.getElementById('notificationBell').addEventListener('click', function() {
            const notifications = [
                'تسجيل جديد: د. محمد أحمد',
                'حدث جديد: مؤتمر الذكاء الاصطناعي',
                'بلاغ: مشكلة في الخادم',
                'تحديث النظام متاح',
                '5 رسائل جديدة في صندوق الوارد'
            ];

            let notificationText = 'الإشعارات الحديثة:\n\n';
            notifications.forEach((notif, index) => {
                notificationText += `${index + 1}. ${notif}\n`;
            });

            alert(notificationText);

            // إعادة عداد الإشعارات إلى صفر
            document.querySelector('.notification-count').textContent = '0';
        });

        // معلومات المستخدم
        document.getElementById('userProfile').addEventListener('click', function() {
            alert('قائمة الملف الشخصي للمشرف العام\n\nيمكنك من هنا:\n- عرض الملف الشخصي\n- تغيير كلمة المرور\n- تعديل الإعدادات الشخصية');
        });

        // وظائف الإجراءات
        window.viewEvent = function(eventName) {
            alert(`عرض تفاصيل الحدث: ${eventName}`);
        };

        window.editEvent = function(eventName) {
            alert(`تعديل الحدث: ${eventName}`);
        };

        window.deleteEvent = function(eventName) {
            if (confirm(`هل أنت متأكد من حذف الحدث "${eventName}"؟`)) {
                alert(`تم حذف الحدث: ${eventName}`);
            }
        };

        // تحديث البيانات الحية
        function updateLiveData() {
            // تحديث عدد المستخدمين عشوائياً
            const usersElement = document.querySelectorAll('.stat-value')[1];
            if (usersElement) {
                const currentUsers = parseInt(usersElement.textContent.replace(/,/g, ''));
                const newUsers = currentUsers + Math.floor(Math.random() * 3);
                usersElement.textContent = newUsers.toLocaleString();
            }

            // تحديث الوقت في التذييل
            const now = new Date();
            const timeString = now.toLocaleTimeString('ar-SA');
            document.querySelector('.footer p:nth-child(2)').innerHTML =
                `<i class="fas fa-server me-2"></i> إصدار النظام: 2.4.1 |
                 <i class="fas fa-clock ms-3 me-2"></i> آخر تحديث: ${timeString}`;
        }

        // تحديث البيانات كل دقيقة
        setInterval(updateLiveData, 60000);

        // تهيئة البيانات
        populateEventsTable();
        updateLiveData();

        // تأثيرات عند التمرير
        const observerOptions = {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, observerOptions);

        // تطبيق تأثيرات على بطاقات الإحصائيات
        document.querySelectorAll('.stat-card').forEach(card => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
            observer.observe(card);
        });
    });
</script>
</body>
</html>