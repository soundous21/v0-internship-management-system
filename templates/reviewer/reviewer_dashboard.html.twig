{% extends 'base.html.twig' %}

{% block title %}Reviewer Dashboard - Expert Portal{% endblock %}

{% block body %}
    <style>
        body {
            height: auto !important;
            overflow-y: auto !important;
            display: block !important;
            padding: 40px 0;
        }

        /* استخدام نفس حاوية السوبر أدمن */
        .reviewer-main-card {
            background: rgba(0, 0, 0, 0.85) !important;
            border: 1px solid var(--deep-black) !important;
            border-radius: 25px !important;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.9);
            padding: 40px;
        }

        /* الأيقونة العلوية المضيئة مثل تصميمك الأخير */
        .expert-glow-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(45deg, var(--bourgeois-purple), var(--royal-blue));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 20px var(--royal-blue);
            margin: 0 auto 15px;
        }

        /* بطاقة البحث الفردية */
        .research-item-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            margin-bottom: 25px;
            transition: 0.3s;
        }

        .research-item-card:hover {
            border-color: var(--soft-blue);
            background: rgba(255, 255, 255, 0.05);
        }

        /* مساحة الوصف (Abstract) */
        .abstract-text {
            background: rgba(0, 0, 0, 0.3);
            padding: 15px;
            border-radius: 10px;
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.7);
            border: 1px dotted rgba(255, 255, 255, 0.2);
        }

        /* المدخلات (Inputs) السوداء الملكية */
        .reviewer-input {
            background: #000 !important;
            border: 1px solid var(--royal-blue) !important;
            color: white !important;
            border-radius: 8px;
        }

        .reviewer-input:focus {
            box-shadow: 0 0 10px var(--soft-blue);
            outline: none;
        }

        .section-title {
            color: var(--soft-blue);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: bold;
        }
    </style>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="reviewer-main-card">

                    <div class="text-center mb-5">
                        <div class="expert-glow-icon">
                            <i class="bi bi-patch-check-fill text-white fs-3"></i>
                        </div>
                        <h2 class="animated-title h3">Scientific Evaluation Portal</h2>
                        <p class="text-white-50">Review assigned research with academic precision</p>
                    </div>

                    {% for comm in communications %}
                        <div class="research-item-card p-4">
                            <form action="{{ path('app_reviewer_evaluate', {'id': comm.id}) }}" method="POST">
                                <div class="row align-items-center">
                                    <div class="col-md-7 border-end border-secondary border-opacity-25">
                                        <div class="mb-2">
                                            <span class="badge bg-dark text-info border border-info small">ID: #{{ comm.id }}</span>
                                        </div>
                                        <h4 class="text-white mb-3">{{ comm.title }}</h4>

                                        <p class="section-title mb-2">Research Abstract</p>
                                        <div class="abstract-text mb-3">
                                            {{ comm.abstract }}
                                        </div>
                                    </div>

                                    <div class="col-md-5 ps-md-4">
                                        <div class="mb-3">
                                            <label class="section-title mb-2">Scientific Critique (Na9d)</label>
                                            <textarea name="critique" class="form-control reviewer-input" rows="3" placeholder="Enter your detailed feedback..." required></textarea>
                                        </div>

                                        <div class="row g-2">
                                            <div class="col-6">
                                                <label class="section-title mb-2">Score (0-100)</label>
                                                <input type="number" name="score" class="form-control reviewer-input text-center" min="0" max="100" required>
                                            </div>
                                            <div class="col-6 d-flex align-items-end">
                                                <button type="submit" class="btn btn-glow w-100 py-2 fw-bold text-uppercase">
                                                    Submit
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="bi bi-inbox text-white-50 fs-1"></i>
                            <p class="text-white-50 mt-3">No submissions pending review.</p>
                        </div>
                    {% endfor %}

                    <div class="text-center mt-4">
                        <a href="{{ path('app_home') }}" class="text-white-50 text-decoration-none small hover-blue">
                            <i class="bi bi-arrow-left me-1"></i> Return to Main Gateway
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}