                            <span class="badge bg-primary-subtle text-primary" style="font-size:0.7rem;">
                                {{ app.offer.locationType }}
                            </span>
                                        </td>

                                        {# ── Date ── #}
                                        <td class="p-4 small" style="color:#94a3b8;">
                                            {{ app.createdAt|date('M d, Y') }}
                                        </td>

                                        {# ── Status Badge ── #}
                                        {# ── Status Badge ── #}
