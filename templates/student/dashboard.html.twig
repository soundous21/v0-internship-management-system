                                                        data-company-doc="{{ app.offer.company.verificationFile ? asset('uploads/verification/' ~ app.offer.company.verificationFile) : '' }}">
                                                    <i class="bi bi-eye me-1"></i> Details
                                                </button>

                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}

                                </tbody>
                            </table>
                        </div>
                    </div>
                {% endif %}
