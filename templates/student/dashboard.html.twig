            <span class="dot-glow"></span> PENDING
        </span>
                                            {% elseif app.status == 'pending_admin' %}
                                                {# حالة جديدة: الشركة وافقت والآن الدور على الجامعة #}
                                                <span class="badge-custom-tech" style="color: var(--accent-info); border-color: var(--accent-info);">
            <i class="dot-glow"></i> WAITING FOR ADMIN
        </span>
                                            {% elseif app.status == 'accepted' %}
                                                <span class="badge-custom-tech-active">
            <i></i> ACCEPTED
        </span>
                                            {% else %}
