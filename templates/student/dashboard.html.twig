{% extends 'base.html.twig' %}

{% block title %}Stag.io - Student Dashboard{% endblock %}

{% block body %}
    <style>
        :root {
            --bg-main: #030712;
            --bg-sidebar: #09090b;
            --card-bg: #111827; /* لون خلفية للبطاقات أفتح قليلاً */
            --border-color: rgba(75, 85, 99, 0.3); /* إطار شبه شفاف */
            --text-muted: #94a3b8;
            --accent-primary: #3b82f6; /* الأزرق التكنولوجي */
            --glow-color: rgba(59, 130, 246, 0.3); /* لون الوهج */
        }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
        }

        .main-content {
            margin-left: 260px;
            padding: 2rem;
            width: calc(100% - 260px);
            padding-top: 2rem;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            cursor: pointer;
            transition: 0.2s;
        }

        .nav-link-custom:hover, .nav-link-custom.active {
            background: #1e293b;
            color: white;
        }

        /* --- تحسين البطاقات (Cards) --- */
        .stat-card {
            background: var(--card-bg); /* استخدام لون الخلفية الجديد */
            border: 1px solid var(--border-color); /* إطار ناعم */
            border-radius: 16px; /* زوايا منحنية أكثر */
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* حركة أنعم ومعبرة */
            position: relative;
            overflow: hidden;
        }

        /* تأثير الحركة والوهج عند تمرير الفأرة */
        .stat-card:hover {
            transform: translateY(-8px) scale(1.02); /* الارتفاع للأعلى مع تكبير بسيط جداً */
            border-color: var(--accent-primary); /* تغيير لون الإطار للأزرق */
            box-shadow: 0 15px 30px var(--glow-color); /* إضافة وهج ناعم */
        }

        /* إضافة خط متدرج في أسفل البطاقة كتأثير تكنولوجي إضافي */
        .stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

        .stat-card:hover::after {
            transform: translateX(100%);
        }

        /* --- تحسين الحقول والمكونات الأخرى --- */
        .form-control {
            background-color: rgba(0, 0, 0, 0.5) !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 8px;
            padding: 0.7rem 1rem;
            transition: 0.3s;
        }

        .form-control:focus {
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 10px var(--glow-color) !important;
        }

        .badge-skill {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--accent-primary);
            border: 1px solid rgba(59, 130, 246, 0.2);
            padding: 5px 12px;
            border-radius: 6px;
        }

        .d-none { display: none !important; }
        .cursor-pointer { cursor: pointer; }

        nav.navbar, .main-header, header { display: none !important; }

        .badge-custom {
            padding: 5px 12px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.75rem;
            border: 1px solid transparent;
        }

        .badge-react { background-color: rgba(97, 218, 251, 0.1); color: #61dafb; border-color: rgba(97, 218, 251, 0.3); }
        .badge-typescript { background-color: rgba(49, 120, 198, 0.1); color: #3178c6; border-color: rgba(49, 120, 198, 0.3); }
        .badge-tailwind { background-color: rgba(56, 189, 248, 0.1); color: #38bdf8; border-color: rgba(56, 189, 248, 0.3); }

        .badge-custom:hover { filter: brightness(1.2); cursor: default; }

        .label-custom, label.small.text-muted {
            color: #ffffff !important;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 0.5px;
        }

        .label-accent {
            color: #ffffff !important;
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
        }

        /* تحسين الأزرار */
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #1d4ed8 100%);
            border: none;
            transition: 0.3s;
        }

        .btn-primary:hover {
            box-shadow: 0 5px 15px var(--glow-color);
            transform: translateY(-2px);
        }

    </style>

    <div class="d-flex">
        <div class="sidebar">
            <h3 class="fw-bold mb-4 text-primary">Stag.io</h3>
            <nav>
                <a class="nav-link-custom active" onclick="switchTab('dashboard', this)">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>
                <a class="nav-link-custom" onclick="switchTab('profile', this)">
                    <i class="bi bi-person-circle"></i> My Profile
                </a>
                <a class="nav-link-custom" onclick="switchTab('offers', this)">
                    <i class="bi bi-search"></i> Browse Internships
                </a>
                <a class="nav-link-custom"><i class="bi bi-file-earmark-text"></i> My Applications</a>
                <hr class="border-secondary">
                <a href="{{ path('app_logout') }}" class="nav-link-custom text-danger"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </nav>
        </div>

        <div class="main-content">
            <div id="section-dashboard">
                <header class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="fw-bold mb-0">Welcome back, {{ user.firstName }}!</h2>
                        <p class="text-secondary small">Here's what's happening with your applications.</p>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-end">
                            <p class="mb-0 fw-bold small">{{ user.firstName }} {{ user.lastName }}</p>
                            <small class="text-muted" style="font-size: 0.7rem;">{{ user.email }}</small>
                        </div>
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center fw-bold" style="width: 45px; height: 45px;">
                            {{ user.firstName|first }}{{ user.lastName|first }}
                        </div>
                    </div>
                </header>

                <div class="row g-4 mb-5">
                    {% set stats = [
                        {'label': 'Total Applied', 'value': 8, 'icon': 'bi-send', 'color': 'text-white'},
                        {'label': 'Pending Review', 'value': 4, 'icon': 'bi-clock', 'color': 'text-white'},
                        {'label': 'Accepted', 'value': 1, 'icon': 'bi-check-circle', 'color': 'text-white'},
                        {'label': 'Rejected', 'value': 3, 'icon': 'bi-x-circle', 'color': 'text-white'}
                    ] %}
                    {% for stat in stats %}
                        <div class="col-md-3">
                            <div class="stat-card">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-secondary small fw-bold">{{ stat.label|upper }}</span>
                                    <i class="bi {{ stat.icon }} {{ stat.color }}"></i>
                                </div>
                                <h2 class="fw-bold mb-0">{{ stat.value }}</h2>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <h4 class="fw-bold mb-4">Recommended for You</h4>
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="badge bg-primary-subtle text-primary mb-2">New</span>
                                    <h5 class="fw-bold">Full-stack Symfony Developer</h5>
                                    <p class="text-secondary small mb-3">TechSolutions Algeria • Constantine</p>
                                    <div class="d-flex gap-2">
                                        <span class="badge bg-black border border-secondary">Symfony</span>
                                        <span class="badge bg-black border border-secondary">PHP</span>
                                    </div>
                                </div>
                                <button class="btn btn-primary btn-sm px-4 rounded-pill">Apply Now</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="stat-card">
                            <h5 class="fw-bold mb-4">Profile Completion</h5>
                            <div class="progress bg-black mb-3" style="height: 10px; border-radius: 5px;">
                                <div class="progress-bar bg-primary" style="width: 75%; border-radius: 5px;"></div>
                            </div>
                            <p class="small text-secondary mb-4">Complete your profile to increase your chances!</p>
                            <h6 class="small fw-bold text-primary mb-3">YOUR SKILLS</h6>
                            <div class="d-flex flex-wrap gap-2">
                                {% for skill in user.skills %}
                                    <span class="badge bg-secondary">{{ skill }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="section-offers" class="d-none">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-0">Internship Offers</h2>
                        <p class="text-secondary small">Browse and apply to internship opportunities</p>
                    </div>
                </div>

                <div class="stat-card p-3 mb-4">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <div class="input-group">
                                <span class="input-group-text bg-black border-secondary text-muted"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" placeholder="Search by title, company, or skills...">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select form-control">
                                <option selected>All Locations</option>
                                <option>Algiers</option>
                                <option>Constantine</option>
                                <option>Oran</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select form-control">
                                <option selected>All Technology</option>
                                <option>Frontend</option>
                                <option>Backend</option>
                                <option>Design</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select class="form-select form-control">
                                <option selected>All Durations</option>
                                <option>1-3 Months</option>
                                <option>4-6 Months</option>
                            </select>
                        </div>
                    </div>
                </div>

                <p class="text-secondary small mb-3">Showing 2 of 2 offers</p>

                <div class="d-flex flex-column gap-3">
                    <div class="stat-card p-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <h5 class="fw-bold mb-0">Frontend Developer Intern</h5>
                                    <i class="bi bi-bookmark ms-2 cursor-pointer text-muted hover-primary"></i>
                                </div>
                                <div class="d-flex gap-3 text-secondary small mb-3">
                                    <span><i class="bi bi-building me-1"></i> TechCorp Algeria</span>
                                    <span><i class="bi bi-geo-alt me-1"></i> Algiers</span>
                                    <span><i class="bi bi-clock me-1"></i> 6 months</span>
                                    <span><i class="bi bi-calendar-event me-1"></i> Deadline: April 30, 2026</span>
                                </div>
                                <p class="text-muted small mb-3">Join our team to build modern web applications using React and TypeScript...</p>
                                <div class="d-flex gap-2 mt-2">
                                    <span class="badge-custom badge-react">React</span>
                                    <span class="badge-custom badge-typescript">TypeScript</span>
                                    <span class="badge-custom badge-tailwind">Tailwind</span>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-2">
                                <button class="btn btn-primary px-4 rounded-3">Apply Now</button>
                                <button class="btn btn-outline-secondary btn-sm px-4 rounded-3">View Details</button>
                            </div>
                        </div>
                    </div>

                    
                </div>
            </div>

            <div id="section-profile" class="d-none mt-2">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2 class="fw-bold mb-0">My Profile</h2>
                                <p class="text-secondary small">Manage your digital CV and profile settings</p>
                            </div>
                            <button class="btn btn-primary px-4" onclick="saveProfileData()">
                                <i class="bi bi-save me-2"></i> Save Changes
                            </button>
                        </div>

                        <div class="stat-card mb-4">
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-person me-2"></i> Personal Information</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="label-custom">First Name</label>
                                    <input type="text" class="form-control" value="{{ user.firstName }}">
                                </div>
                                <div class="col-md-6">
                                    <label class="label-custom">Last Name</label>
                                    <input type="text" class="form-control" value="{{ user.lastName }}">
                                </div>
                                <div class="col-md-6">
                                    <label class="label-custom">Email</label>
                                    <input type="email" class="form-control" value="{{ user.email }}">
                                </div>
                                <div class="col-md-6">
                                    <label class="label-custom">Phone</label>
                                    <input type="text" id="input-phone" class="form-control" value="{{ user.phone }}" placeholder="+213 5XX XX XX XX">
                                </div>
                                <div class="col-md-12">
                                    <label class="label-custom">Wilaya</label>
                                    <input type="text" id="input-wilaya" class="form-control" value="{{ user.wilaya }}" placeholder="e.g. Algiers">
                                </div>
                            </div>
                        </div>

                        <div class="stat-card">
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-mortarboard me-2"></i> Academic Information</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="label-custom">University</label>
                                    <input type="text" class="form-control" value="University of Constantine 2">
                                </div>
                                <div class="col-md-6">
                                    <label class="label-custom">Department</label>
                                    <input type="text" id="input-specialty" class="form-control" value="{{ user.specialty }}" placeholder="Computer Science">
                                </div>
                                <div class="col-md-12">
                                    <label class="label-custom">Current Level</label>
                                    <input type="text" id="input-level" class="form-control" value="{{ user.level }}" placeholder="L3">
                                </div>
                                <div class="col-md-12">
                                    <label class="label-custom">Bio / About Me</label>
                                    <textarea id="input-bio" class="form-control" rows="3">{{ user.bio }}</textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="stat-card mb-4">
                            <h6 class="fw-bold mb-3 text-primary">Technical Skills</h6>
                            <div id="skills-container" class="d-flex flex-wrap gap-2 mb-3">
                                {% for skill in user.skills %}
                                    <span class="badge badge-skill d-flex align-items-center gap-1">
                                        {{ skill }} <i class="bi bi-x cursor-pointer" onclick="this.parentElement.remove()"></i>
                                    </span>
                                {% endfor %}
                            </div>
                            <div class="input-group input-group-sm">
                                <input type="text" id="skill-input" class="form-control bg-black" placeholder="Add a skill...">
                                <button class="btn btn-outline-primary" type="button" onclick="addSkill()">+</button>
                            </div>
                        </div>

                        <div class="stat-card text-center border-primary hover-glow">
                            <p class="small text-muted text-start mb-3">Profile Preview</p>
                            <div class="rounded-circle bg-primary mx-auto mb-3 d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 70px; height: 70px;">
                                {{ user.firstName|first }}{{ user.lastName|first }}
                            </div>
                            <h6 class="fw-bold mb-1">{{ user.firstName }} {{ user.lastName }}</h6>
                            <p id="preview-academic" class="text-muted small">
                                {{ user.level }} - {{ user.specialty }}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function switchTab(tab, element) {
            document.getElementById('section-dashboard').classList.add('d-none');
            document.getElementById('section-profile').classList.add('d-none');
            document.getElementById('section-offers').classList.add('d-none');
            document.querySelectorAll('.nav-link-custom').forEach(el => el.classList.remove('active'));

            if (tab === 'dashboard') document.getElementById('section-dashboard').classList.remove('d-none');
            else if (tab === 'profile') document.getElementById('section-profile').classList.remove('d-none');
            else if (tab === 'offers') document.getElementById('section-offers').classList.remove('d-none');

            element.classList.add('active');
        }

        function addSkill() {
            const input = document.getElementById('skill-input');
            const container = document.getElementById('skills-container');
            const skillName = input.value.trim();
            if (skillName !== "") {
                const newSkill = document.createElement('span');
                newSkill.className = 'badge badge-skill d-flex align-items-center gap-1';
                newSkill.innerHTML = `${skillName} <i class="bi bi-x cursor-pointer" onclick="this.parentElement.remove()"></i>`;
                container.appendChild(newSkill);
                input.value = "";
                input.focus();
            }
        }

        document.getElementById('skill-input')?.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') addSkill();
        });

        function saveProfileData() {
            const skills = [];
            document.querySelectorAll('#skills-container .badge').forEach(badge => {
                skills.push(badge.textContent.replace('x', '').trim());
            });

            const formData = {
                firstName: document.querySelector('input[value="{{ user.firstName }}"]').value,
                lastName: document.querySelector('input[value="{{ user.lastName }}"]').value,
                phone: document.querySelector('input[placeholder="+213 5XX XX XX XX"]').value,
                wilaya: document.querySelector('input[placeholder="e.g. Algiers"]').value,
                bio: document.querySelector('textarea').value,
                specialty: document.getElementById('input-specialty').value,
                level: document.getElementById('input-level').value,
                skills: skills
            };

            fetch('/student/profile/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(formData)
            })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') { alert('✅ تم حفظ التعديلات بنجاح!'); location.reload(); }
                    else alert('❌ فشل الحفظ: ' + data.message);
                })
                .catch(error => alert('حدث خطأ في الاتصال بالسيرفر'));
        }
    </script>
{% endblock %}