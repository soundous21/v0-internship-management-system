{% extends 'base.html.twig' %}

{% block title %}Stag.io - Student Dashboard{% endblock %}

{% block body %}
    <style>
        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --card-bg: #000000; /* لون خلفية للبطاقات أفتح قليلاً */
            --border-color: rgb(17, 24, 39); /* إطار شبه شفاف */
            --text-muted: #94a3b8;
            --accent-primary: #3378f3; /* الأزرق التكنولوجي */
            --glow-color: rgba(59, 130, 246, 0.3); /* لون الوهج */
        }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
        }

        .main-content {
            margin-left: 260px;
            padding: 2rem;
            width: calc(100% - 260px);
            padding-top: 2rem;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            cursor: pointer;
            transition: 0.2s;
        }

        .nav-link-custom:hover, .nav-link-custom.active {
            background: #1e293b;
            color: white;
        }

        /* --- تحسين البطاقات (Cards) --- */
        .stat-card {
            background: var(--card-bg); /* استخدام لون الخلفية الجديد */
            border: 2px solid var(--border-color); /* إطار ناعم */
            border-radius: 16px; /* زوايا منحنية أكثر */
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* حركة أنعم ومعبرة */
            position: relative;
            overflow: hidden;
        }

        /* تأثير الحركة والوهج عند تمرير الفأرة */
        .stat-card:hover {
            transform: translateY(-8px) scale(1.02); /* الارتفاع للأعلى مع تكبير بسيط جداً */
            border-color: var(--accent-primary); /* تغيير لون الإطار للأزرق */
            box-shadow: 0 15px 30px var(--glow-color); /* إضافة وهج ناعم */
        }

        /* إضافة خط متدرج في أسفل البطاقة كتأثير تكنولوجي إضافي */
        .stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
            transform: translateX(-100%);
            transition: transform 0.6s;
        }

        .stat-card:hover::after {
            transform: translateX(100%);
        }

        /* --- تحسين الحقول والمكونات الأخرى --- */
        .form-control {
            background-color: rgba(0, 0, 0, 0.5) !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 8px;
            padding: 0.7rem 1rem;
            transition: 0.3s;
        }

        .form-control:focus {
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 10px var(--glow-color) !important;
        }

        .badge-skill {
            background-color: rgba(59, 130, 246, 0.1);
            color: var(--accent-primary);
            border: 1px solid rgba(59, 130, 246, 0.2);
            padding: 5px 12px;
            border-radius: 6px;


        }

        .d-none { display: none !important; }
        .cursor-pointer { cursor: pointer; }

        nav.navbar, .main-header, header { display: none !important; }

        .badge-custom {
            padding: 5px 12px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.75rem;
            border: 1px solid transparent;
        }

        .badge-react { background-color: rgba(97, 218, 251, 0.1); color: #61dafb; border-color: rgba(97, 218, 251, 0.3); }
        .badge-typescript { background-color: rgba(49, 120, 198, 0.1); color: #3178c6; border-color: rgba(49, 120, 198, 0.3); }
        .badge-tailwind { background-color: rgba(56, 189, 248, 0.1); color: #38bdf8; border-color: rgba(56, 189, 248, 0.3); }

        .badge-custom:hover { filter: brightness(1.2); cursor: default; }

        .label-custom, label.small.text-muted {
            color: #ffffff !important;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 0.5px;
        }

        .label-accent {
            color: #ffffff !important;
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
        }

        /* تحسين الأزرار */
        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #1d4ed8 100%);
            border: none;
            transition: 0.3s;
        }

        .btn-primary:hover {
            box-shadow: 0 5px 15px var(--glow-color);
            transform: translateY(-2px);
        }



        /* ألوان شارات المهارات - فاتحة وهادئة */
        .badge-custom {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 500;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #cbd5e1;
        }

        .hover-primary:hover {
            color: var(--accent-primary) !important;
        }

        .cursor-pointer {
            cursor: pointer;
        }

        /* تأثير بسيط عند تمرير الماوس على البطاقة */
        .offer-card {
            transition: transform 0.2s ease, border-color 0.2s ease;
        }

        .offer-card:hover {
            border-color: var(--accent-primary) !important;
            background: rgba(59, 130, 246, 0.02) !important;
        }











        /* تأثير الصفوف عند التمرير */
        .table-hover tbody tr:hover {
            background-color: rgba(51, 120, 243, 0.05) !important;
            transition: background 0.3s ease;
        }












        /* تأثير الصفوف عند التمرير بشكل خافت */
        .transition-row {
            transition: all 0.3s ease;
        }
        .transition-row:hover {
            background: rgba(51, 120, 243, 0.03) !important;
        }

        /* شارة مخصصة: حدود زرقاء ونص رمادي فاتح */
        .badge-custom-tech {
            background: rgba(51, 120, 243, 0.05);
            border: 1px solid rgba(51, 120, 243, 0.2);
            color: #94a3b8;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        /* نقطة متوهجة للشارات */
        .dot-glow {
            width: 6px;
            height: 6px;
            background-color: var(--accent-primary);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--accent-primary);
        }

        /* شارة الحالة النشطة (Accepted) بالأزرق الكامل */
        .badge-custom-tech-active {
            background: var(--accent-primary);
            color: white;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(51, 120, 243, 0.2);
        }

        /* زر تقني بحدود زرقاء فقط */
        .btn-tech-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: #94a3b8;
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 0.75rem;
            transition: 0.3s;
        }

        .btn-tech-outline:hover {
            border-color: var(--accent-primary);
            color: white;
            box-shadow: 0 0 10px rgba(51, 120, 243, 0.2);
        }

        .uppercase-tracking {
            letter-spacing: 1px;
            font-size: 0.65rem !important;
        }


        /* شارة الرفض المتطابقة مع التصميم التقني */
        .badge-custom-rejected {
            background: rgba(239, 68, 68, 0.05);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #f87171;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .dot-glow-red {
            width: 6px;
            height: 6px;
            background-color: #ef4444;
            border-radius: 50%;
            box-shadow: 0 0 8px #ef4444;
        }

        /* تنسيق إضافي لزر عرض السبب ليتناسب مع الجدول */
        .btn-tech-outline-danger {
            background: transparent;
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #f87171;
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 0.75rem;
            transition: 0.3s;
        }

        .btn-tech-outline-danger:hover {
            border-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            color: white;
        }


        /* كود إضافي لضمان تلوين القائمة المنسدلة نفسها في بعض المتصفحات */
        .form-select-dark {
            background-color: #000 !important;
            color: #fff !important;
            border-color: #444 !important;
        }
        .form-select-dark option {
            background-color: #000 !important;
            color: #fff !important;
        }






        .skill-badge {
            background-color: transparent; /* خلفية شفافة */
            border: 1px solid var(--accent-primary); /* إطار بلون الأزرق التكنولوجي */
            color: var(--accent-primary); /* لون النص بنفس لون الإطار */
            padding: 2px 10px;
            border-radius: 12px; /* حواف دائرية أنيقة */
            font-size: 0.85rem;
            font-weight: 500;
            display: inline-block;
            margin-right: 5px;
            margin-bottom: 5px;
            transition: all 0.3s ease;
        }

        /* تأثير اختياري عند تمرير الماوس لجعلها أكثر حيوية */
        .skill-badge:hover {
            background-color: var(--accent-primary);
            color: white;
            box-shadow: 0 0 8px var(--glow-color);
        }





        .logout-blue {
            color: var(--accent-primary) !important; /* استخدام الأزرق التكنولوجي */
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 15px;
            border-radius: 8px;
            text-decoration: none;
        }

        .logout-blue:hover {
            background-color: rgba(51, 120, 243, 0.1); /* خلفية زرقاء خفيفة جداً عند الحوم */
            color: white !important;
            box-shadow: 0 0 15px var(--glow-color); /* توهج أزرق ناعم */
            transform: translateX(5px); /* حركة بسيطة لليمين */
        }

        .logout-blue i {
            font-size: 1.2rem;
        }




        /* تنسيق الشعار */
        .brand-text {
            font-weight: 800;
            letter-spacing: -1px;
            color: white;
            font-size: 1.5rem;
        }
        .brand-text .dot {
            color: var(--accent-primary);
            text-shadow: 0 0 10px var(--glow-color);
        }

        /* التعديلات على الروابط */
        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }

        .nav-link-custom i {
            font-size: 1.2rem;
            margin-right: 12px;
            transition: all 0.3s ease;
        }

        /* تأثير الرابط النشط */
        .nav-link-custom.active {
            background-color: rgba(51, 120, 243, 0.1);
            color: var(--accent-primary);
            border-left: 3px solid var(--accent-primary);
            box-shadow: inset 10px 0 20px rgba(51, 120, 243, 0.05);
        }

        /* تأثير Hover */
        .nav-link-custom:hover:not(.active) {
            color: white;
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        /* الفاصل */
        .nav-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-color), transparent);
            margin: 20px 0;
        }

        /* زر الخروج الأزرق */
        .logout-blue {
            margin-top: auto; /* يدفعه للأسفل */
            color: var(--accent-primary) !important;
        }

    </style>

    <div class="sidebar">
        <div class="brand-container mb-5">
            <h3 class="brand-text">Stag<span class="dot">.</span>io</h3>
        </div>

        <nav class="nav flex-column">
            <a class="nav-link-custom active" onclick="switchTab('dashboard', this)">
                <i class="bi bi-grid-1x2"></i> <span>Dashboard</span>
            </a>
            <a class="nav-link-custom" onclick="switchTab('profile', this)">
                <i class="bi bi-person-circle"></i> <span>My Profile</span>
            </a>
            <a class="nav-link-custom" onclick="switchTab('offers', this)">
                <i class="bi bi-briefcase"></i> <span>Browse Offers</span>
            </a>
            <a class="nav-link-custom" onclick="switchTab('applications', this)">
                <i class="bi bi-file-earmark-text"></i> <span>My Applications</span>
            </a>

            <div class="nav-divider"></div>

            <a href="{{ path('app_logout') }}" class="nav-link-custom logout-blue">
                <i class="bi bi-box-arrow-right"></i> <span>Logout</span>
            </a>
        </nav>
    </div>

        <div class="main-content">
                <!-- بداية قسم الداشبورد -->
                <div id="section-dashboard">
                    <header class="d-flex justify-content-between align-items-center mb-5">
                        <div>
                            <h2 class="fw-bold mb-0">Hello {{ user.firstName }}!</h2>
                            <p class="text-secondary small">Here’s a summary of your activity.</p>
                        </div>

                        {# قسم معلومات المستخدم في الهيدر #}
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-end">
                                <p class="mb-0 fw-bold small">{{ user.firstName }} {{ user.lastName }}</p>
                                <small class="text-secondary small" style="font-size: 0.7rem;">{{ user.email }}</small>
                            </div>
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center fw-bold overflow-hidden"
                                 style="width: 45px; height: 45px; border: 1px solid var(--border-color);">
                                {% if user.profilePicture %}
                                    <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" class="w-100 h-100 object-fit-cover">
                                {% else %}
                                    <span class="text-white">{{ user.firstName|first|upper }}{{ user.lastName|first|upper }}</span>
                                {% endif %}
                            </div>
                        </div>
                    </header>

                    {# قسم الإحصائيات #}
                    <div class="row g-4 mb-5">
                        {% set items = [
                            {'label': 'Total Applied', 'value': stats.total, 'icon': 'bi-send', 'color': 'text-white'},
                            {'label': 'Pending', 'value': stats.pending, 'icon': 'bi-clock', 'color': 'text-white'},
                            {'label': 'Accepted', 'value': stats.accepted, 'icon': 'bi-check-circle', 'color': 'text-white'},
                            {'label': 'Rejected', 'value': stats.refused, 'icon': 'bi-x-circle', 'color': 'text-white'}
                        ] %}
                        {% for stat in items %}
                            <div class="col-md-3">
                                <div class="stat-card">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="text-secondary small fw-bold">{{ stat.label|upper }}</span>
                                        <i class="bi {{ stat.icon }} {{ stat.color }}"></i>
                                    </div>
                                    <h2 class="fw-bold mb-0">{{ stat.value }}</h2>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {# القسم السفلي: العرض المقبول + نسبة اكتمال الملف #}
                     <div class="row g-4">
                        <!-- الجزء الذي طلبتِ استبداله بالعرض المقبول -->
                       {#  <div class="col-lg-8">
                            {% if myInternship %}
                                <h4 class="fw-bold mb-4">My Current Internship</h4>
                                <div class="stat-card p-4 border-primary" style="background: rgba(51, 120, 243, 0.05);">

                                </div>
                            {% else %}
                                <h4 class="fw-bold mb-4">Recommended for You</h4>
                                <div class="stat-card p-4 text-center">
                                    <p class="text-secondary mb-0">No approved internship yet.</p>
                                </div>
                            {% endif %}
                        </div>#}
                         <div class="col-lg-8">
                             {% if myInternship %}
                                 <h4 class="fw-bold mb-4">My Internship</h4>
                                 <div class="stat-card p-4 border-primary position-relative" style="background: rgba(51, 120, 243, 0.05); border: 1px solid rgba(51, 120, 243, 0.2);">

                                     {# الجزء العلوي: العنوان والحالة #}
                                     <div class="d-flex justify-content-between align-items-start mb-4">
                                         <div>
                                             <h5 class="fw-bold mb-1 text-white" style="font-size: 1.25rem;">{{ myInternship.title }}</h5>
                                             <div class="d-flex align-items-center gap-2">
                                                 <p class="text-secondary mb-0"><i class="bi bi-building me-1"></i>{{ myInternship.company.fullName }}</p>
                                                 <span class="text-muted">•</span>
                                                      </div>
                                         </div>
                                         <span class="badge rounded-pill px-3 py-2" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2);">
                    <i class="bi bi-check-circle-fill me-1"></i> Active
                </span>
                                     </div>

                                     {# الجزء الأوسط: تفاصيل سريعة #}
                                     <div class="row g-3 mb-4">
                                         <div class="col-6 col-md-3">
                                             {# تم تغيير text-muted إلى text-white لجعل العنوان فاتحاً وواضحاً #}
                                             <small class="text-white d-block text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px; opacity: 0.9;">Duration</small>
                                             <span class="fw-medium"><i class="bi bi-calendar3 me-2 text-primary"></i>{{ myInternship.duration }}</span>
                                         </div>
                                         <div class="col-6 col-md-3">
                                             {# تم تغيير text-muted إلى text-white لجعل كلمة Type فاتحة #}
                                             <small class="text-white d-block text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px; opacity: 0.9;">Type</small>
                                             <span class="fw-medium"><i class="bi bi-laptop me-2 text-primary"></i>{{ myInternship.locationType }}</span>
                                         </div>

                                         <div class="col-6 col-md-3">
                                             {# تم تغيير text-muted إلى text-white لجعل كلمة Start Date فاتحة #}
                                             <small class="text-white d-block text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px; opacity: 0.9;">Start Date</small>
                                             <span class="fw-medium"><i class="bi bi-clock-history me-2 text-primary"></i>{{ myInternship.internshipStart|date('d M Y') }}</span>
                                         </div>
                                     </div>

                                     <hr style="border-color: rgba(255,255,255,0.1);">

                                     {# الأزرار التفاعلية #}
                                     <div class="d-flex flex-wrap gap-2 mt-3">
                                         {# استبدلي الزر القديم بهذا #}
                                         <button type="button" class="btn btn-sm btn-outline-light px-3" data-bs-toggle="modal" data-bs-target="#companyModal">
                                             <i class="bi bi-eye me-1"></i> View Company Details
                                         </button>

                                         {# زر تحميل الاتفاقية (مهم جداً للعلامة الكاملة) #}
                                         {% if acceptedApplication and acceptedApplication.conventionFile %}
                                             <a href="{{ asset('conventions/' ~ acceptedApplication.conventionFile) }}" class="btn btn-sm btn-primary px-3">
                                                 <i class="bi bi-file-earmark-pdf me-1"></i> Download Convention
                                             </a>
                                         {% endif %}
                                     </div>

                                 </div>
                             {% else %}
                                 {# الكود الخاص بحالة عدم وجود تربص يبقى كما هو #}
                                 <h4 class="fw-bold mb-4">Recommended for You</h4>
                                 <div class="stat-card p-5 text-center border-dashed" style="border: 2px dashed rgba(255,255,255,0.1); background: transparent;">
                                     <div class="mb-3">
                                         <i class="bi bi-search text-muted" style="font-size: 2rem;"></i>
                                     </div>
                                     <p class="text-secondary mb-3">You don't have an active internship yet.</p>
                                     <a href="{{ path('app_student_browse_offers') }}" class="btn btn-primary btn-sm px-4">Browse Offers</a>
                                 </div>
                             {% endif %}
                         </div>
                        <!-- جانب لوحة التحكم: نسبة اكتمال الملف -->
                        <div class="col-lg-4">
                            <div class="stat-card">
                                <h5 class="fw-bold mb-4">Profile Completion</h5>
                                <div class="progress bg-black mb-3" style="height: 10px; border-radius: 5px;">
                                    <div class="progress-bar bg-primary" style="width: {{ completionPercent }}%;"></div>
                                </div>
                                <p class="small text-secondary mb-4">{{ completionPercent }}% Completed</p>
                                <h6 class="small fw-bold text-primary mb-3">YOUR SKILLS</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for skill in user.skills %}
                                        <span class="skill-badge">{{ skill.tagName }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div> <!-- إغلاق الـ row السفلي -->
                </div> <!-- إغلاق section-dashboard الصحيح -->





















            <div id="section-offers" class="d-none">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-0">Browse Internships</h2>
                        <p class="text-secondary small">
                            Offers from companies
                            {% if offers|length > 0 %}
                                — <span class="text-primary fw-bold">{{ offers|length }} available</span>
                            {% endif %}
                        </p>
                    </div>
                </div>

                {# ══ Filters ══ #}
                <div class="stat-card p-3 mb-4">
                    <div class="row g-2 align-items-end">

                        {# Search #}
                        <div class="col-md-4">
                            <div class="input-group">
                    <span class="input-group-text bg-black border-secondary text-white">
                        <i class="bi bi-search"></i>
                    </span>
                                <input type="text" id="filter-search" class="form-control shadow-none bg-black text-white border-secondary"
                                       placeholder="Search by title, company, skill..."
                                       oninput="filterOffers()">
                            </div>
                        </div>

                        {# Wilaya #}
                        <div class="col-md-3">
                            <input class="form-control shadow-none bg-black text-white border-secondary"
                                   id="filter-wilaya" list="datalistWilaya" placeholder="Wilaya..." oninput="filterOffers()">
                            <datalist id="datalistWilaya">
                                <option value="Adrar"><option value="Chlef"><option value="Laghouat">
                                <option value="Oum El Bouaghi"><option value="Batna"><option value="Béjaïa">
                                <option value="Biskra"><option value="Béchar"><option value="Blida">
                                <option value="Bouira"><option value="Tamanrasset"><option value="Tébessa">
                                <option value="Tlemcen"><option value="Tiaret"><option value="Tizi Ouzou">
                                <option value="Algiers"><option value="Djelfa"><option value="Jijel">
                                <option value="Sétif"><option value="Saïda"><option value="Skikda">
                                <option value="Sidi Bel Abbès"><option value="Annaba"><option value="Guelma">
                                <option value="Constantine"><option value="Médéa"><option value="Mostaganem">
                                <option value="M'Sila"><option value="Mascara"><option value="Ouargla">
                                <option value="Oran"><option value="El Bayadh"><option value="Illizi">
                                <option value="Bordj Bou Arreridj"><option value="Boumerdès"><option value="El Tarf">
                                <option value="Tindouf"><option value="Tissemsilt"><option value="El Oued">
                                <option value="Khenchela"><option value="Souk Ahras"><option value="Tipaza">
                                <option value="Mila"><option value="Aïn Defla"><option value="Naâma">
                                <option value="Aïn Témouchent"><option value="Ghardaïa"><option value="Relizane">
                                <option value="Timimoun"><option value="Bordj Badji Mokhtar">
                                <option value="Ouled Djellal"><option value="Béni Abbès"><option value="In Salah">
                                <option value="In Guezzam"><option value="Touggourt"><option value="Djanet">
                                <option value="El M'Ghair"><option value="El Meniaa">
                            </datalist>
                        </div>

                        {# Type #}
                        <div class="col-md-2">
                            <select class="form-select shadow-none bg-black text-white border-secondary" id="filter-type" onchange="filterOffers()">
                                <option value="">All Types</option>
                                <option value="PFE">PFE</option>
                                <option value="Stage d'Immersion">Stage d'Immersion</option>
                                <option value="Stage Technique">Stage Technique</option>
                            </select>
                        </div>

                        {# Smart Match Filter #}
                        <div class="col-md-1">
                            <div class="form-check form-switch pt-2">
                                <input class="form-check-input" type="checkbox" id="filter-match" onchange="filterOffers()">
                                <label class="form-check-label text-secondary small" for="filter-match">Match</label>
                            </div>
                        </div>

                        {# Reset #}
                        <div class="col-md-2">
                            <button class="btn btn-outline-secondary w-100 shadow-none" onclick="resetFilters()">
                                <i class="bi bi-x-circle me-1"></i> Reset
                            </button>
                        </div>
                    </div>
                </div>

                <p class="text-secondary small mb-3" id="offers-count">
                    Showing <span id="offers-count-num">{{ offers|length }}</span>
                    offer{{ offers|length != 1 ? 's' : '' }}
                </p>

                {# ══ Offers List ══ #}
                <div class="d-flex flex-column gap-3" id="offers-container">

                    {% if offers is empty %}
                        <div class="stat-card p-5 text-center">
                            <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                            <h5 class="text-white-50">No offers available yet</h5>
                            <p class="text-secondary small">Your university hasn't approved any company partners yet.</p>
                        </div>
                    {% endif %}

                    {# ★ Smart Matching: حساب مهارات الطالب #}
                    {% set studentSkills = user.skills|map(s => s.tagName|lower)|join(',') %}

                    {% for offer in offers %}
                        {% set isApplied = offer.id in appliedOfferIds %}

                        {# حساب نسبة التوافق #}
                        {% set matchCount = 0 %}
                        {% set totalSkills = offer.skills|length %}
                        {% for skill in offer.skills %}
                            {% if skill.tagName|lower in user.skills|map(s => s.tagName|lower) %}
                                {% set matchCount = matchCount + 1 %}
                            {% endif %}
                        {% endfor %}
                        {% set matchPercent = totalSkills > 0 ? ((matchCount / totalSkills) * 100)|round : 0 %}
                        {% set matchColor = matchPercent >= 70 ? '#22c55e' : (matchPercent >= 40 ? '#f59e0b' : '#ef4444') %}
                        {% set matchLabel = matchPercent >= 70 ? 'Great Match' : (matchPercent >= 40 ? 'Partial Match' : 'Low Match') %}

                        <div class="stat-card p-4 offer-card"
                             data-title="{{ offer.title|lower }}"
                             data-company="{{ (offer.company.companyName ?? offer.company.fullName)|lower }}"
                             data-wilaya="{{ offer.wilaya|lower }}"
                             data-type="{{ offer.locationType }}"
                             data-skills="{{ offer.skills|map(s => s.tagName|lower)|join(',') }}"
                             data-match="{{ matchPercent }}"
                             id="offer-card-{{ offer.id }}">

                            <div class="d-flex justify-content-between align-items-start gap-3">

                                {# ═══ LEFT — Offer Info ═══ #}
                                <div class="flex-grow-1">

                                    {# Title + Status #}
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        {# Company Logo #}
                                        <div style="width:36px;height:36px;border-radius:8px;background:#0f172a;border:1px solid #1e293b;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;">
                                            {% if offer.company.logo %}
                                                <img src="{{ asset('uploads/logos/' ~ offer.company.logo) }}" style="width:100%;height:100%;object-fit:cover;">
                                            {% else %}
                                                <i class="bi bi-building text-primary" style="font-size:14px;"></i>
                                            {% endif %}
                                        </div>
                                        <h5 class="fw-bold mb-0 text-white">{{ offer.title }}</h5>{% set cs = offer.computedStatus %}
                                        {% if cs == 'Active' %}
                                            <span class="badge bg-success-subtle text-success ms-1" style="font-size:0.65rem;">ACTIVE</span>
                                        {% elseif cs == 'In Progress' %}
                                            <span class="badge bg-info-subtle text-info ms-1" style="font-size:0.65rem;">IN PROGRESS</span>
                                        {% elseif cs == 'Deadline Over' %}
                                            <span class="badge bg-warning-subtle text-warning ms-1" style="font-size:0.65rem;">DEADLINE OVER</span>
                                        {% endif %}
                                    </div>

                                    {# Company + Type + Level #}
                                    <div class="mb-2">
                            <span class="text-primary fw-bold small">
                                {{ offer.company.companyName ?? offer.company.fullName }}
                            </span>
                                        <span class="text-muted mx-2">|</span>
                                        {% if offer.locationType %}
                                            <span class="badge bg-primary-subtle text-primary" style="font-size:0.7rem;">
                                    {{ offer.locationType }}
                                </span>
                                        {% endif %}
                                        {% if offer.level is defined and offer.level %}
                                            <span class="badge bg-info-subtle text-info ms-1" style="font-size:0.7rem;">
                                    {{ offer.level }}
                                </span>
                                        {% endif %}
                                    </div>

                                    {# Meta: location, duration, dates #}
                                    <div class="d-flex flex-wrap gap-3 text-secondary small mb-3">
                                        {% if offer.wilaya %}
                                            <span><i class="bi bi-geo-alt me-1 text-primary"></i>{{ offer.wilaya }}</span>
                                        {% endif %}
                                        {% if offer.duration %}
                                            <span><i class="bi bi-clock me-1 text-primary"></i>{{ offer.duration }}</span>
                                        {% endif %}
                                        {% if offer.deadline %}
                                            <span><i class="bi bi-calendar-event me-1 text-danger"></i>Deadline: {{ offer.deadline|date('M d, Y') }}</span>
                                        {% endif %}
                                        {% if offer.internshipStart %}
                                            <span><i class="bi bi-play-circle me-1 text-success"></i>Internship: {{ offer.internshipStart|date('M d, Y') }}</span>
                                        {% endif %}
                                    </div>

                                    {# Description #}
                                    {% if offer.description %}
                                        <p class="text-secondary small mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;max-width:700px;">
                                            {{ offer.description }}
                                        </p>
                                    {% endif %}

                                    {# Skills + Map #}
                                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                        <div class="d-flex gap-2 flex-wrap">
                                            {% for skill in offer.skills %}
                                                {% set isMatched = skill.tagName|lower in user.skills|map(s => s.tagName|lower) %}
                                                <span class="skill-badge"
                                                      style="background:{{ isMatched ? 'rgba(34,197,94,0.1)' : '#1e293b' }};
                                                              border:1px solid {{ isMatched ? 'rgba(34,197,94,0.4)' : '#334155' }};
                                                              color:{{ isMatched ? '#86efac' : '#94a3b8' }};
                                                              border-radius:20px;padding:3px 10px;font-size:11px;display:inline-flex;align-items:center;gap:4px;">
                                        {% if isMatched %}<i class="bi bi-check-circle-fill" style="font-size:10px;"></i>{% endif %}
                                                    {{ skill.tagName }}
                                    </span>
                                            {% endfor %}
                                        </div>

                                        {# Map Link #}
                                        {% if offer.latitude and offer.longitude %}
                                            <a href="https://www.google.com/maps?q={{ offer.latitude }},{{ offer.longitude }}"
                                               target="_blank" class="btn btn-sm btn-outline-info border-secondary">
                                                <i class="bi bi-map me-1"></i> View Map
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>

                                {# ═══ RIGHT — Match % + Buttons ═══ #}
                                <div class="d-flex flex-column align-items-center gap-3" style="min-width:120px;">

                                    {# ★ Smart Match Badge #}
                                    <div class="text-center">
                                        <div style="width:60px;height:60px;border-radius:50%;border:3px solid {{ matchColor }};display:flex;align-items:center;justify-content:center;margin:0 auto;background:rgba(0,0,0,0.3);">
                                            <span style="font-size:14px;font-weight:700;color:{{ matchColor }};">{{ matchPercent }}%</span>
                                        </div>
                                        <div style="font-size:10px;color:{{ matchColor }};font-weight:600;margin-top:4px;">
                                            {{ matchLabel }}
                                        </div>
                                    </div>
                                    {# ─── Apply / Withdraw / Seats Full ─── #}
                                    {% set isFull = offer.seats is not null and offer.remainingSeats == 0 %}

                                    {% if isFull and not isApplied %}
                                        {# المقاعد منتهية #}
                                        <button class="btn btn-secondary px-3 rounded-3 fw-bold w-100" disabled
                                                style="opacity:0.7; cursor:not-allowed;">
                                            <i class="bi bi-person-fill-slash me-1"></i>
                                            <span class="small">Seats Full</span>
                                        </button>
                                    {% else %}
                                        <button class="btn px-3 rounded-3 fw-bold w-100 apply-btn {{ isApplied ? 'btn-outline-danger' : 'btn-primary' }}"
                                                data-offer-id="{{ offer.id }}"
                                                data-applied="{{ isApplied ? 'true' : 'false' }}"
                                                data-seats="{{ offer.seats }}"
                                                data-remaining="{{ offer.remainingSeats }}"
                                                onclick="toggleApply(this)">
                                            {% if isApplied %}
                                                <i class="bi bi-x-circle me-1"></i><span class="small">Withdraw</span>
                                            {% else %}
                                                <i class="bi bi-send me-1"></i><span class="small">Apply Now</span>
                                            {% endif %}
                                        </button>
                                    {% endif %}

                                    {# عدد المقاعد المتبقية #}
                                    {% if offer.seats is not null %}
                                        <div class="text-center mt-1" style="font-size:0.7rem;">
                                            {% if isFull %}
                                                <span style="color:#ef4444;">
                <i class="bi bi-x-circle-fill me-1"></i>0 / {{ offer.seats }} seats
            </span>
                                            {% elseif offer.remainingSeats <= 2 %}
                                                <span style="color:#f59e0b;">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>{{ offer.remainingSeats }} / {{ offer.seats }} left
            </span>
                                            {% else %}
                                                <span style="color:#22c55e;">
                <i class="bi bi-people-fill me-1"></i>{{ offer.remainingSeats }} / {{ offer.seats }} seats
            </span>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {# View Details #}
                                    <button class="btn btn-outline-secondary btn-sm px-3 rounded-3 w-100"
                                            onclick="openOfferModal(this)"
                                            data-offer-id="{{ offer.id }}"
                                            data-title="{{ offer.title|escape('html_attr') }}"
                                            data-description="{{ (offer.description ?? '')|escape('html_attr') }}"
                                            data-duration="{{ (offer.duration ?? '')|escape('html_attr') }}"
                                            data-type="{{ offer.locationType }}"
                                            data-level="{{ offer.level is defined ? (offer.level ?? '') : '' }}"
                                            data-wilaya="{{ (offer.wilaya ?? '')|escape('html_attr') }}"
                                            data-deadline="{{ offer.deadline ? offer.deadline|date('M d, Y') : '' }}"
                                            data-internship-start="{{ offer.internshipStart ? offer.internshipStart|date('M d, Y') : '' }}"
                                            data-lat="{{ offer.latitude ?? '' }}"
                                            data-lng="{{ offer.longitude ?? '' }}"
                                            data-skills="{{ offer.skills|map(s => s.tagName)|join(',')|escape('html_attr') }}"
                                            data-matched-skills="{{ offer.skills|filter(s => s.tagName|lower in user.skills|map(u => u.tagName|lower))|map(s => s.tagName)|join(',')|escape('html_attr') }}"
                                            data-match-percent="{{ matchPercent }}"
                                            data-match-color="{{ matchColor }}"
                                            data-match-label="{{ matchLabel }}"
                                            data-applied="{{ isApplied ? 'true' : 'false' }}"
                                            data-company-name="{{ (offer.company.companyName ?? offer.company.fullName)|escape('html_attr') }}"
                                            data-company-email="{{ offer.company.email|escape('html_attr') }}"
                                            data-company-phone="{{ (offer.company.phone ?? '')|escape('html_attr') }}"
                                            data-company-industry="{{ (offer.company.industry ?? '')|escape('html_attr') }}"
                                            data-company-wilaya="{{ (offer.company.wilaya ?? '')|escape('html_attr') }}"
                                            data-company-website="{{ (offer.company.website ?? '')|escape('html_attr') }}"
                                            data-company-bio="{{ (offer.company.bio ?? '')|escape('html_attr') }}"
                                            data-company-logo="{{ offer.company.logo ? asset('uploads/logos/' ~ offer.company.logo) : '' }}"
                                            data-company-doc="{{ offer.company.verificationFile ? asset('uploads/verification/' ~ offer.company.verificationFile) : '' }}">
                                        <i class="bi bi-eye me-1"></i> Details
                                    </button>
                                </div>

                            </div>
                        </div>
                    {% endfor %}

                </div>
            </div>












        <div id="section-profile" class="d-none mt-2">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="fw-bold mb-0">My Profile</h2>
                            <p class="text-secondary small">Manage your digital CV and profile settings</p>
                        </div>
                        <button class="btn btn-primary px-4" onclick="saveProfileData()">
                            <i class="bi bi-save me-2"></i> Save Changes
                        </button>
                    </div>
                    <div class="position-relative d-inline-block mb-3">
                        <div id="avatar-container" class="rounded-circle border border-primary d-flex align-items-center justify-content-center overflow-hidden bg-dark mx-auto"
                             style="width: 100px; height: 100px; cursor: pointer;"
                             onclick="document.getElementById('profile-upload').click()">

                            {# إذا كان لدى الطالب صورة في قاعدة البيانات، نعرضها #}
                            {% if user.profilePicture %}
                                <img id="preview-img" src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}" class="w-100 h-100 object-fit-cover">
                            {% else %}
                                {# إذا لم تكن لديه صورة، نعرض الحروف الأولى (الخيار الافتراضي) #}
                                <div id="initials-placeholder" class="fw-bold fs-2 text-primary">
                                    {{ user.firstName|first }}{{ user.lastName|first }}
                                </div>
                            {% endif %}
                        </div>

                        <!-- زر الكاميرا للتعديل -->
                        <div class="position-absolute bottom-0 end-0 bg-primary rounded-circle p-1 d-flex shadow" style="cursor: pointer;" onclick="document.getElementById('profile-upload').click()">
                            <i class="bi bi-camera-fill text-white small" style="font-size: 0.8rem;"></i>
                        </div>
                    </div>

                    {# حقل تحميل الملف المخفي #}
                    <input type="file" id="profile-upload" class="d-none" accept="image/*" onchange="previewImage(this)">
                    <div class="stat-card mb-4">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-person me-2"></i> Personal Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="label-custom">First Name</label>
                                <input type="text" class="form-control" value="{{ user.firstName }}">
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Last Name</label>
                                <input type="text" class="form-control" value="{{ user.lastName }}">
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Email</label>
                                <input type="email" class="form-control" value="{{ user.email }}">
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Phone</label>
                                <input type="text" id="input-phone" class="form-control" value="{{ user.phone }}" placeholder="+213 5XX XX XX XX">
                            </div>
                            <div class="col-md-12">
                                <label class="label-custom">Wilaya</label>
                                <input type="text" id="input-wilaya" class="form-control" value="{{ user.wilaya }}" placeholder="e.g. Algiers">
                            </div>

                            {# داخل ملف dashboard.html.twig - قسم Personal Information #}
                            <div class="col-md-6">
                                <label class="label-custom"><i class="bi bi-github me-1"></i> GitHub Profile</label>
                                <input type="url" id="input-github" class="form-control" value="{{ user.githubLink }}" placeholder="https://github.com/username">
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom"><i class="bi bi-globe me-1"></i> Portfolio Website</label>
                                <input type="url" id="input-portfolio" class="form-control" value="{{ user.portfolioLink }}" placeholder="https://yourportfolio.com">
                            </div>
                        </div>
                    </div>

                    <div class="stat-card">
                        <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-mortarboard me-2"></i> Academic Information</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="label-custom">University</label>
                                <input type="text" id="input-university" class="form-control" value="{{ user.university }}" placeholder="e.g. University of Constantine 2">     </div>
                            <div class="col-md-6">
                                <label class="label-custom">Speciality</label>
                                <input type="text" id="input-specialty" class="form-control" value="{{ user.specialty }}" placeholder="Computer Science">
                            </div>
                            <div class="col-md-6">
                                <label class="label-custom">Department</label>
                                {# هنا نستخدم app.user.department لجلب القيمة من العمود الذي تمتلكه في قاعدة البيانات #}
                                <input type="text"
                                       id="input-department"
                                       class="form-control"
                                       value="{{ app.user.department }}"
                                       placeholder="No department assigned"
                                       readonly>
