                                                    {% endif %}
                                                </div>
                                                <div>
                                                    <p class="fw-bold mb-0 text-white">{{ app.offer.title }}</p>
                                                    <small style="color:#64748b;">
                                                        {{ app.offer.company.companyName ?? app.offer.company.fullName }}
                                                        {% if app.offer.wilaya %}
                                                            · <i class="bi bi-geo-alt"></i> {{ app.offer.wilaya }}
                                                        {% endif %}
                                                    </small>
                                                </div>
                                            </div>
                                        </td>

                                        {# ── Type ── #}
