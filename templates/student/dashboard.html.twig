                    <div class="stat-card text-center border-primary hover-glow">
                        <p class="fw-bold mb-3 text-primary">Profile Preview</p>

                        <!-- الصورة الشخصية -->
                        <div class="rounded-circle border border-primary d-flex align-items-center justify-content-center overflow-hidden bg-dark mx-auto mb-3"
                             style="width: 80px; height: 80px;">
