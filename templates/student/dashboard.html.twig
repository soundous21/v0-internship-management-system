                        <div class="rounded-circle bg-primary" style="width:8px;height:8px;box-shadow:0 0 10px var(--accent-primary);"></div>
                        <span class="small fw-bold text-white">{{ stats.pending }} Pending</span>
                    </div>
                </div>

                {% if applications is empty %}
                    <div class="stat-card p-5 text-center">
