        // ══════════════════════════════════════════════════
        // ★ Open Offer Modal
        // ══════════════════════════════════════════════════
        function openOfferModal(btn) {
            const d = btn.dataset;

            // ── Offer Info ──
            document.getElementById('od-title').textContent       = d.title || '';
            document.getElementById('od-description').textContent = d.description || 'No description provided.';
            document.getElementById('od-wilaya').textContent      = d.wilaya   || '—';
            document.getElementById('od-duration').textContent    = d.duration || '—';
            document.getElementById('od-deadline').textContent    = d.deadline || '—';
            document.getElementById('od-start').textContent       = d.internshipStart || '—';

            // Type badge
            const typeBadge = document.getElementById('od-type-badge');
            typeBadge.textContent = d.type || '';
            typeBadge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle';

            // Level badge
            const lvlBadge = document.getElementById('od-level-badge');
            if (d.level) { lvlBadge.textContent = d.level; lvlBadge.style.display = ''; }
            else         { lvlBadge.style.display = 'none'; }

            // Map
            const mapWrap = document.getElementById('od-map-wrap');
            if (d.lat && d.lng) {
                document.getElementById('od-map-link').href = `https://www.google.com/maps?q=${d.lat},${d.lng}`;
                mapWrap.classList.remove('d-none');
            } else {
                mapWrap.classList.add('d-none');
            }

            // ── Smart Match ──
            const pct   = parseInt(d.matchPercent) || 0;
            const color = d.matchColor || '#ef4444';
            const circle = document.getElementById('od-match-circle');
            circle.style.borderColor = color;
            document.getElementById('od-match-pct').style.color   = color;
            document.getElementById('od-match-pct').textContent   = pct + '%';
            document.getElementById('od-match-label').style.color = color;
            document.getElementById('od-match-label').textContent = d.matchLabel || '';

            // ── Skills with highlight ──
            const skillsEl   = document.getElementById('od-skills');
            const matched    = d.matchedSkills ? d.matchedSkills.split(',').map(s => s.trim().toLowerCase()) : [];
            skillsEl.innerHTML = '';
            if (d.skills) {
                d.skills.split(',').filter(s => s.trim()).forEach(skill => {
                    const isM = matched.includes(skill.trim().toLowerCase());
                    skillsEl.innerHTML += `
                <span style="background:${isM ? 'rgba(34,197,94,0.1)' : '#1e293b'};
                             border:1px solid ${isM ? 'rgba(34,197,94,0.4)' : '#334155'};
                             color:${isM ? '#86efac' : '#94a3b8'};
                             border-radius:20px;padding:4px 12px;font-size:12px;
                             display:inline-flex;align-items:center;gap:5px;">
                    ${isM ? '<i class="bi bi-check-circle-fill" style="font-size:11px;"></i>' : ''}
                    ${skill.trim()}
                </span>`;
                });
            }

            // ── Apply Button ──
            const applyBtn = document.getElementById('od-apply-btn');
            applyBtn.dataset.offerId = d.offerId;
            applyBtn.dataset.applied = d.applied;
            updateApplyBtnUI(applyBtn);

            // ── Company Preview ──
            document.getElementById('cp-name').textContent     = d.companyName     || '—';
            document.getElementById('cp-industry').textContent = d.companyIndustry || '—';
            document.getElementById('cp-email').textContent    = d.companyEmail    || '—';
            document.getElementById('cp-phone').textContent    = d.companyPhone    || 'Not provided';
            document.getElementById('cp-wilaya').textContent   = d.companyWilaya   || '—';
            document.getElementById('cp-bio').textContent      = d.companyBio      || '';

            const img = document.getElementById('cp-logo-img');
            const icon = document.getElementById('cp-logo-icon');
            if (d.companyLogo) { img.src = d.companyLogo; img.classList.remove('d-none'); icon.classList.add('d-none'); }
            else               { img.classList.add('d-none'); icon.classList.remove('d-none'); }

            const webEl  = document.getElementById('cp-website');
            const webRow = document.getElementById('cp-web-row');
            if (d.companyWebsite) { webEl.href = d.companyWebsite; webEl.textContent = d.companyWebsite; webRow.style.display = 'flex'; }
            else                  { webRow.style.display = 'none'; }

            const docWrap = document.getElementById('cp-doc-wrap');
            if (d.companyDoc) { document.getElementById('cp-doc').href = d.companyDoc; docWrap.classList.remove('d-none'); }
            else              { docWrap.classList.add('d-none'); }

            new bootstrap.Modal(document.getElementById('offerDetailModal')).show();
        }

        // ══════════════════════════════════════════════════
        // ★ Apply / Withdraw — من البطاقة
        // ══════════════════════════════════════════════════
        async function toggleApply(btn) {
            const offerId   = btn.dataset.offerId;
            const isApplied = btn.dataset.applied === 'true';
            const action    = isApplied ? 'withdraw' : 'apply';
            if (isApplied && !confirm('Withdraw your application?')) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const res  = await fetch(`/student/offers/${offerId}/${action}`, { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    const nowApplied = !isApplied;
                    btn.dataset.applied = nowApplied ? 'true' : 'false';
                    updateApplyBtnUI(btn);
                    // sync modal button
                    const mb = document.getElementById('od-apply-btn');
                    if (mb && mb.dataset.offerId === offerId) {
                        mb.dataset.applied = nowApplied ? 'true' : 'false';
                        updateApplyBtnUI(mb);
                    }
                } else { alert(data.error || 'Failed.'); }
            } catch { alert('Network error.'); }
            finally  { btn.disabled = false; }
        }

        // ══════════════════════════════════════════════════
        // ★ Apply / Withdraw — من المودال
        // ══════════════════════════════════════════════════
        async function toggleApply(btn) {
            const offerId   = btn.dataset.offerId;
            const isApplied = btn.dataset.applied === 'true';
            const action    = isApplied ? 'withdraw' : 'apply';
            if (isApplied && !confirm('Withdraw your application?')) return;

            btn.disabled = true;
            try {
                const res  = await fetch(`/student/offers/${offerId}/${action}`, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    const nowApplied = !isApplied;
                    btn.dataset.applied = nowApplied ? 'true' : 'false';
                    updateApplyBtnUI(btn);

                    // ✅ تحديث عداد المقاعد بعد التقديم
                    if (!isApplied && data.remainingSeats !== undefined) {
                        updateSeatsUI(offerId, data.remainingSeats, btn.dataset.seats);
                    }

                    // مزامنة زر المودال
                    const mb = document.querySelector(`.modal-apply-btn[data-offer-id="${offerId}"]`);
                    if (mb) { mb.dataset.applied = nowApplied ? 'true' : 'false'; updateApplyBtnUI(mb); }

                } else if (data.error === 'seats_full') {
                    // ✅ المقاعد انتهت — تحديث UI فوراً بدون reload
                    showSeatsFull(btn, offerId);
                } else {
                    alert(data.error || 'Failed.');
                }
            } catch { alert('Network error.'); }
            finally  { btn.disabled = false; }
        }

        // ✅ دالة جديدة: تحويل الزر لـ "Seats Full"
        function showSeatsFull(btn, offerId) {
            btn.disabled  = true;
            btn.className = 'btn btn-secondary px-3 rounded-3 fw-bold w-100';
            btn.style.opacity = '0.7';
            btn.style.cursor  = 'not-allowed';
            btn.innerHTML = '<i class="bi bi-person-fill-slash me-1"></i><span class="small">Seats Full</span>';
            btn.onclick   = null;

            // تحديث عداد المقاعد
            updateSeatsUI(offerId, 0, btn.dataset.seats);
        }

        // ✅ دالة جديدة: تحديث عرض المقاعد
        function updateSeatsUI(offerId, remaining, total) {
            const card = document.getElementById(`offer-card-${offerId}`);
            if (!card) return;
            const seatsEl = card.querySelector('.seats-counter');
            if (!seatsEl || total == null) return;

            if (remaining <= 0) {
                seatsEl.style.color = '#ef4444';
                seatsEl.innerHTML   = `<i class="bi bi-x-circle-fill me-1"></i>0 / ${total} seats`;
            } else if (remaining <= 2) {
                seatsEl.style.color = '#f59e0b';
                seatsEl.innerHTML   = `<i class="bi bi-exclamation-triangle-fill me-1"></i>${remaining} / ${total} left`;
            } else {
                seatsEl.style.color = '#22c55e';
                seatsEl.innerHTML   = `<i class="bi bi-people-fill me-1"></i>${remaining} / ${total} seats`;
            }
        }

        // ══════════════════════════════════════════════════
        // ★ تحديث شكل زر Apply
        // ══════════════════════════════════════════════════
        function updateApplyBtnUI(btn) {
            const applied = btn.dataset.applied === 'true';
            if (applied) {
                btn.classList.remove('btn-primary'); btn.classList.add('btn-outline-danger');
                btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Withdraw';
            } else {
                btn.classList.remove('btn-outline-danger'); btn.classList.add('btn-primary');
                btn.innerHTML = '<i class="bi bi-send me-1"></i> Apply Now';
            }
        }

        // ══════════════════════════════════════════════════
        // ★ Filters
        // ══════════════════════════════════════════════════
        function filterOffers() {
            const search    = document.getElementById('filter-search').value.toLowerCase();
            const wilaya    = document.getElementById('filter-wilaya').value.toLowerCase();
            const type      = document.getElementById('filter-type').value.toLowerCase();
            const matchOnly = document.getElementById('filter-match').checked;

            const cards = document.querySelectorAll('.offer-card');
            let visible = 0;

            cards.forEach(card => {
                const title    = card.dataset.title    || '';
                const company  = card.dataset.company  || '';
                const skills   = card.dataset.skills   || '';
                const cardWil  = card.dataset.wilaya   || '';
                const cardType = (card.dataset.type    || '').toLowerCase();
                const match    = parseInt(card.dataset.match) || 0;

                const okSearch = !search || title.includes(search) || company.includes(search) || skills.includes(search);
                const okWilaya = !wilaya || cardWil.includes(wilaya.replace(/^\d+- /i, ''));
                const okType   = !type   || cardType.includes(type);
                const okMatch  = !matchOnly || match >= 50;

                if (okSearch && okWilaya && okType && okMatch) {
                    card.style.display = '';
                    visible++;
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('offers-count-num').textContent = visible;
        }

        function resetFilters() {
            document.getElementById('filter-search').value = '';
            document.getElementById('filter-wilaya').value = '';
            document.getElementById('filter-type').value   = '';
            document.getElementById('filter-match').checked = false;
            document.querySelectorAll('.offer-card').forEach(c => c.style.display = '');
            document.getElementById('offers-count-num').textContent =
                document.querySelectorAll('.offer-card').length;
        }










        // ══════════════════════════════════════════════════
        // ★ Withdraw من جدول My Applications
        // ══════════════════════════════════════════════════
        async function withdrawApp(offerId, appId, btn) {
            if (!confirm('Are you sure you want to withdraw this application?')) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const res  = await fetch(`/student/offers/${offerId}/withdraw`, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    // إخفاء الصف بأنيميشن
                    const row = document.getElementById(`app-row-${appId}`);
                    if (row) {
                        row.style.transition = 'opacity 0.4s, transform 0.4s';
                        row.style.opacity    = '0';
                        row.style.transform  = 'translateX(20px)';
                        setTimeout(() => row.remove(), 420);
                    }
                    // تحديث زر Apply في قسم Browse Internships
                    const cardBtn = document.querySelector(`.apply-btn[data-offer-id="${offerId}"]`);
                    if (cardBtn) {
                        cardBtn.dataset.applied = 'false';
                        updateApplyBtnUI(cardBtn);
                    }
                } else {
                    alert(data.error || 'Cannot withdraw.');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Withdraw';
                }
            } catch {
                alert('Network error.');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Withdraw';
            }
        }

        // ══════════════════════════════════════════════════
        // ★ Show Rejection Reason Modal
        // ══════════════════════════════════════════════════
        function showRejectionReason(btn) {
            document.getElementById('rejection-offer-name').textContent = btn.dataset.offer || '';
            document.getElementById('rejection-reason-text').textContent = btn.dataset.reason || 'No reason provided.';
            new bootstrap.Modal(document.getElementById('rejectionReasonModal')).show();
        }


























        async function handleApplicationAction(offerId, appId, action, btn) {
            const confirmMsg = action === 'delete'
                ? 'Are you sure you want to delete this rejection record?'
                : 'Are you sure you want to withdraw this application?';

            if (!confirm(confirmMsg)) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            // نستخدم نفس المسار (Route) لكن مع تحديد الـ action (سواء withdraw أو delete)
            // ملاحظة: تأكدي من وجود Route في Symfony يستقبل طلب الحذف
            const url = action === 'delete'
                ? `/student/applications/${appId}/delete`
                : `/student/offers/${offerId}/withdraw`;

            try {
                const res = await fetch(url, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    // إخفاء الصف بأنيميشن سلس
                    const row = document.getElementById(`app-row-${appId}`);
                    if (row) {
                        row.style.transition = 'all 0.4s ease';
                        row.style.opacity = '0';
                        row.style.transform = 'scale(0.95)';
                        setTimeout(() => row.remove(), 400);
                    }

                    // إذا كان تراجعاً، نحتاج لتحديث أزرار التقديم في قسم Browse
                    if (action === 'withdraw') {
                        const cardBtn = document.querySelector(`.apply-btn[data-offer-id="${offerId}"]`);
                        if (cardBtn) {
                            cardBtn.dataset.applied = 'false';
                            updateApplyBtnUI(cardBtn);
                        }
                    }
                } else {
                    alert(data.error || 'Operation failed.');
                    btn.disabled = false;
                    btn.innerHTML = action === 'delete' ? '<i class="bi bi-trash3"></i> Delete' : 'Withdraw';
                }
            } catch (e) {
                alert('Server connection error.');
                btn.disabled = false;
            }
        }
    </script>
