    <script>


        function switchTab(tab, element) {
            document.getElementById('section-dashboard').classList.add('d-none');
            document.getElementById('section-profile').classList.add('d-none');
            document.getElementById('section-offers').classList.add('d-none');
            document.getElementById('section-applications').classList.add('d-none'); // القسم الجديد


            document.querySelectorAll('.nav-link-custom').forEach(el => el.classList.remove('active'));

            if (tab === 'dashboard') document.getElementById('section-dashboard').classList.remove('d-none');
            else if (tab === 'profile') document.getElementById('section-profile').classList.remove('d-none');
            else if (tab === 'offers') document.getElementById('section-offers').classList.remove('d-none');
            else if (tab === 'applications') document.getElementById('section-applications').classList.remove('d-none');

            element.classList.add('active');
        }

        function addSkill() {
            const input = document.getElementById('skill-input');
            const container = document.getElementById('skills-container');
            const skillName = input.value.trim();
            if (skillName !== "") {
                const newSkill = document.createElement('span');
                newSkill.className = 'badge badge-skill d-flex align-items-center gap-1';
                newSkill.innerHTML = `${skillName} <i class="bi bi-x cursor-pointer" onclick="this.parentElement.remove()"></i>`;
                container.appendChild(newSkill);
                input.value = "";
                input.focus();
            }
        }

        document.getElementById('skill-input')?.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') addSkill();
        });

        function saveProfileData() {
            // 1. جمع المهارات
            const skills = [];
            document.querySelectorAll('#skills-container .badge').forEach(badge => {
                skills.push(badge.textContent.replace('x', '').trim());
            });

            // 2. استخدام FormData بدلاً من JSON العادي لدعم إرسال الملفات
            const formData = new FormData();
// جلب الإيميل لاستخراج الدومين
            const emailValue = document.querySelector('input[value="{{ user.email }}"]').value;
            const domain = emailValue.split('@')[1]; // استخراج ما بعد @
            // إضافة البيانات النصية
            // نستخدم معرفات العناصر (id) أو الانتقاء الدقيق لضمان جلب القيم المكتوبة حالياً
            formData.append('firstName', document.querySelector('input[value="{{ user.firstName }}"]').value);
            formData.append('lastName', document.querySelector('input[value="{{ user.lastName }}"]').value);
            formData.append('phone', document.getElementById('input-phone').value);
            formData.append('wilaya', document.getElementById('input-wilaya').value);
            formData.append('bio', document.getElementById('input-bio').value);
            formData.append('specialty', document.getElementById('input-specialty').value);
            formData.append('level', document.getElementById('input-level').value);
            formData.append('skills', JSON.stringify(skills)); // نرسل المصفوفة كـ string ليتم فكها في السيرفر
            formData.append('university', document.getElementById('input-university').value);
            formData.append('githubLink', document.getElementById('input-github').value);
            formData.append('portfolioLink', document.getElementById('input-portfolio').value);


            formData.append('email', emailValue);
            formData.append('emailDomain', domain); // إرسال الدومين للسيرفر
            // 3. إضافة ملف الصورة إذا تم اختياره
            const imageFile = document.getElementById('profile-upload').files[0];
            if (imageFile) {
                formData.append('profilePicture', imageFile);
            }

            // 4. إرسال الطلب
            fetch('/student/profile/update', {
                method: 'POST',
                body: formData, // نرسل الـ formData مباشرة
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                    // ملاحظة هامة: لا تضعي Content-Type يدوياً هنا، المتصفح سيضبطه تلقائياً لـ multipart/form-data
                }
            })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        alert('Changes have been saved successfully!');
                        location.reload(); // لإعادة تحميل الصفحة وعرض الصورة الجديدة
                    } else {
                        alert('❌ Save failed: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while connecting to the server');
                });
        }



