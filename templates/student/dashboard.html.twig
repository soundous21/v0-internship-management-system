                                                        data-lng="{{ app.offer.longitude ?? '' }}"
                                                        data-skills="{{ app.offer.skills|map(s => s.tagName)|join(',')|escape('html_attr') }}"
                                                        data-matched-skills="{{ app.offer.skills|filter(s => s.tagName|lower in user.skills|map(u => u.tagName|lower))|map(s => s.tagName)|join(',')|escape('html_attr') }}"
                                                        {# استبدل القيم القديمة بهذه القيم الديناميكية #}
                                                        data-match-percent="{{ app.getMatchingScore }}"
                                                        data-match-color="{% if app.getMatchingScore >= 70 %}#22c55e{% elseif app.getMatchingScore >= 40 %}#f59e0b{% else %}#ef4444{% endif %}"
                                                        data-match-label="{% if app.getMatchingScore >= 70 %}High Match{% elseif app.getMatchingScore >= 40 %}Average Match{% else %}Low Match{% endif %}"
                                                        data-applied="true"
                                                        data-company-name="{{ (app.offer.company.companyName ?? app.offer.company.fullName)|escape('html_attr') }}"
                                                        data-company-email="{{ app.offer.company.email|escape('html_attr') }}"
                                                        data-company-phone="{{ (app.offer.company.phone ?? '')|escape('html_attr') }}"
                                                        data-company-industry="{{ (app.offer.company.industry ?? '')|escape('html_attr') }}"
