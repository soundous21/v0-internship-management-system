                        </p>

                        <!-- الموقع والجامعة والبريد -->
                        <div class="mt-3 text-start px-3">
                            <div class="d-flex flex-column gap-3">

                                <!-- الموقع -->
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                                         style="width: 32px; height: 32px; background: rgba(51, 120, 243, 0.1); border: 1px solid rgba(51, 120, 243, 0.2);">
                                        <i class="bi bi-geo-alt text-primary small"></i>
                                    </div>
                                    <div>
                                        <p class="text-secondary small" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Location</p>
                                        <p class="mb-0 small fw-semibold text-white">{{ user.wilaya|default('Not set') }}</p>
                                    </div>
                                </div>

                                <!-- الجامعة -->
