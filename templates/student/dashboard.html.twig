                            <i class="bi bi-search me-2"></i> Browse Offers
                        </button>
                    </div>
                {% else %}
                    <div class="stat-card p-0 overflow-hidden border-0 shadow-lg">
                        <div class="table-responsive">
                            <table class="table table-dark mb-0" style="--bs-table-bg:transparent;background:rgba(0,0,0,0.4);">
                                <thead>
                                <tr style="border-bottom:1px solid var(--border-color);">
                                    <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Internship & Company</th>
                                    <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Type</th>
                                    <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Date Applied</th>
                                    <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Status</th>
                                    <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-end">Action</th>
                                </tr>
                                </thead>
                                <tbody class="border-0">

                                {% for app in applications %}
                                    <tr class="align-middle transition-row"
                                        style="border-bottom:1px solid rgba(17,24,39,0.5);"
                                        id="app-row-{{ app.id }}">

                                        {# ── Company + Offer ── #}
                                        <td class="p-4">
                                            <div class="d-flex align-items-center gap-3">
