                                    {{ user.firstName|first }}{{ user.lastName|first }}
                                </div>
                            {% endif %}
                        </div>

                        <!-- المعلومات الأساسية -->
                        <h6 class="fw-bold mb-1">{{ user.firstName }} {{ user.lastName }}</h6>
                        {#  <p id="preview-academic" class="text-muted small mb-2">
                                <i class="fw-bold mb-3 text-primary"></i> {{ user.level }} - {{ user.specialty }}
                            </p>#}
                        <p id="preview-academic" class="small mb-2 py-1 px-2 rounded-2"
                           style="background-color: rgba(51, 120, 243, 0.1); border: 1px solid rgba(51, 120, 243, 0.2); color: var(--accent-primary);">
                            <i class="bi bi-mortarboard-fill me-2"></i>
                            <span class="fw-bold">{{ user.level }}</span>
                            <span class="mx-1">|</span>
