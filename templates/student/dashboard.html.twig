                                    {# إذا كان الطلب قيد الانتظار: يظهر زر التراجع #}
                                    {% if app.status == 'pending' %}
                                    <button class="btn-tech-outline-danger"
                                            onclick="handleApplicationAction({{ app.offer.id }}, {{ app.id }}, 'withdraw', this)">
