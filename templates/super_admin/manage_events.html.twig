{% extends 'base.html.twig' %}

{% block title %}Manage Events{% endblock %}

{% block body %}
    <div class="container py-5">
        <h1 class="animated-title text-center mb-5">Manage Events</h1>

        <div class="mb-4 text-end">
            <a href="#" class="btn btn-glow">Add New Event</a>
        </div>

        <div class="glass-card p-4 shadow table-responsive">
            <table class="table table-dark table-striped table-hover">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Event Name</th>
                    <th>Organizer</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>1</td>
                    <td>Science Expo</td>
                    <td>John Doe</td>
                    <td>2026-02-15</td>
                    <td>
                        <a href="#" class="btn btn-glow btn-sm">Edit</a>
                        <a href="#" class="btn btn-glow btn-sm">Delete</a>
                    </td>
                </tr>
                <tr>
                    <td>2</td>
                    <td>Math Conference</td>
                    <td>Jane Smith</td>
                    <td>2026-03-10</td>
                    <td>
                        <a href="#" class="btn btn-glow btn-sm">Edit</a>
                        <a href="#" class="btn btn-glow btn-sm">Delete</a>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
