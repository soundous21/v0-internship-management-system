{# templates/company/candidates_list.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Candidats — {{ offer.title }}{% endblock %}

{% block body %}
    <style>
        nav.navbar { display: none !important; }
        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --card-bg: #0a0a0a;
            --border-color: #03305e;
            --text-main: #ffffff;
            --text-muted: #94a3b8;
            --accent-primary: #3b82f6;
            --accent-success: #10b981;
            --accent-danger: #ef4444;
            --glow-primary: rgba(59, 130, 246, 0.15);
        }

        body { background-color: var(--bg-main); color: var(--text-main); font-family: 'Inter', sans-serif; }

        .main-content { margin-left: 260px; padding: 2.5rem; min-height: 100vh; }

        /* Header Stats */
        .stat-badge {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border-color);
            padding: 6px 16px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
        }

        /* Tabs Styling */
        .tabs-container {
            display: flex;
            gap: 10px;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 2rem;
        }
        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 12px 24px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.3s;
            position: relative;
        }
        .tab-btn.active {
            color: var(--accent-primary);
        }
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--accent-primary);
            box-shadow: 0 0 10px var(--accent-primary);
        }

        /* Table & Cards */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            overflow: hidden;
        }

        .custom-table thead {
            background: rgba(255,255,255,0.02);
        }
        .custom-table th {
            padding: 18px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            border: none;
        }
        .custom-table td {
            padding: 20px 18px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }
        .custom-table tr:hover {
            background: rgba(59, 130, 246, 0.02);
        }

        /* Avatars */
        .avatar-ui {
            width: 45px; height: 45px;
            border-radius: 12px;
            background: linear-gradient(135deg, #1a1a1a, #000);
            border: 1px solid #333;
            display: flex; align-items: center; justify-content: center;
            font-weight: bold; color: var(--accent-primary);
        }

        /* Buttons & Badges */
        .btn-action-sm {
            padding: 6px 14px;
            font-size: 0.75rem;
            font-weight: 600;
            border-radius: 8px;
            transition: 0.2s;
            border: 1px solid transparent;
        }
        .btn-accept-ui { background: rgba(16, 185, 129, 0.1); color: #10b981; }
        .btn-accept-ui:hover { background: #10b981; color: #fff; }

        .btn-refuse-ui { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
        .btn-refuse-ui:hover { background: #ef4444; color: #fff; }

        .btn-mini-modern {
            padding: 4px 12px; font-size: 0.7rem; font-weight: 600;
            background: rgba(255, 255, 255, 0.05); color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 8px;
            cursor: pointer; transition: 0.2s; text-transform: uppercase;
        }
        .btn-mini-modern:hover { border-color: var(--accent-primary); color: var(--accent-primary); }

        /* Intern Cards */
        .intern-card-ui {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 24px;
            transition: 0.3s ease;
        }
        .intern-card-ui:hover {
            transform: translateY(-5px);
            border-color: var(--accent-primary);
            box-shadow: 0 10px 30px var(--glow-primary);
        }

        .compatibility-pill {
            background: rgba(255, 255, 255, 0.03);
            padding: 2px 8px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: bold;
        }

        .tab-panel { display: none; }
        .tab-panel.active { display: block; }

        /* Match Bar */
        .match-bar-ui { width: 60px; height: 4px; background: #1a1a1a; border-radius: 10px; margin-top: 4px; overflow: hidden; }
        .match-fill-ui { height: 100%; border-radius: 10px; }

        /* Row removing animation */
        .row-removing {
            animation: row-fade 0.5s forwards;
        }
        @keyframes row-fade {
            to { opacity: 0; transform: translateX(50px); }
        }
    </style>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-start mb-5">
            <div>
                <a href="{{ path('app_company_dashboard') }}" class="text-muted small text-decoration-none d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-chevron-left"></i> Retour au Dashboard
                </a>
                <h1 class="fw-bold text-white mb-1">{{ offer.title }}</h1>
                <p class="text-secondary mb-0"><i class="bi bi-geo-alt me-1"></i> {{ offer.wilaya }} · {{ offer.locationType }}</p>
            </div>

            <div class="d-flex gap-3">
                {% set pendingCount = candidates|filter(c => c.status == 'pending')|length %}
                {% set acceptedCount = candidates|filter(c => c.status == 'accepted')|length %}
                <div class="stat-badge">
                    <span class="dot-glow" style="width:8px; height:8px; background:#f59e0b; border-radius:50%; box-shadow: 0 0 8px #f59e0b;"></span>
                    <span id="counter-pending">{{ pendingCount }} En attente</span>
                </div>
                <div class="stat-badge">
                    <span class="dot-glow" style="width:8px; height:8px; background:#10b981; border-radius:50%; box-shadow: 0 0 8px #10b981;"></span>
                    <span>{{ acceptedCount }} Acceptés</span>
                </div>
            </div>
        </div>

        <div class="tabs-container">
            <button class="tab-btn active" id="btn-applicants" onclick="switchTab('applicants')">
                <i class="bi bi-people-fill me-2"></i> Candidats
                <span class="badge bg-primary ms-2" id="badge-pending" style="font-size: 0.65rem;">{{ pendingCount }}</span>
            </button>
            <button class="tab-btn" id="btn-interns" onclick="switchTab('interns')">
                <i class="bi bi-mortarboard-fill me-2"></i> Stagiaires Actuels
            </button>
        </div>

        <div id="tab-applicants" class="tab-panel active">
            {% set activeApplicants = candidates|filter(c => c.status not in ['refused','rejected']) %}

            {% if activeApplicants|length == 0 %}
                <div class="text-center py-5 stat-card">
                    <i class="bi bi-person-x text-muted fs-1 mb-3"></i>
                    <p class="text-muted">Aucun candidat actif pour le moment.</p>
                </div>
            {% else %}
                <div class="stat-card">
                    <div class="table-responsive">
                        <table class="table custom-table table-dark mb-0">
                            <thead>
                            <tr>
                                <th>Candidat</th>
                                <th>Spécialité & Niveau</th>
                                <th class="text-center">Score Match</th>
                                <th class="text-center">Statut</th>
                                <th class="text-end">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for candidate in activeApplicants %}
                                <tr id="row-{{ candidate.id }}">
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-ui">
                                                {{ candidate.student.firstName|first }}{{ candidate.student.lastName|first }}
                                            </div>
                                            <div>
                                                <div class="fw-bold text-white">{{ candidate.student.firstName }} {{ candidate.student.lastName }}</div>
                                                <div class="text-muted small" style="font-size: 0.75rem;">{{ candidate.student.email }}</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-white-50 small">{{ candidate.student.specialty|default('Non spécifié') }}</div>
                                        <div class="text-primary small" style="font-size: 0.7rem; font-weight: 600;">{{ candidate.student.level }}</div>
                                    </td>
                                    <td class="text-center">
                                        {% set score = candidate.matchingScore %}
                                        <span class="compatibility-pill" style="color: {% if score >= 70 %}#10b981{% elseif score >= 40 %}#f59e0b{% else %}#ef4444{% endif %};">
                                                {{ score }}%
                                            </span>
                                        <div class="match-bar-ui mx-auto">
                                            <div class="match-fill-ui" style="width: {{ score }}%; background: {% if score >= 70 %}#10b981{% elseif score >= 40 %}#f59e0b{% else %}#ef4444{% endif %};"></div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        {% if candidate.status == 'pending' %}
                                            <span class="badge bg-warning bg-opacity-10 text-warning" style="font-size: 0.65rem;">En attente</span>
                                        {% elseif candidate.status == 'pending_admin' %}
                                            <span class="badge bg-info bg-opacity-10 text-info" style="font-size: 0.65rem;">Chez l'Admin</span>
                                        {% elseif candidate.status == 'accepted' %}
                                            <span class="badge bg-success bg-opacity-10 text-success" style="font-size: 0.65rem;">Accepté</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end align-items-center gap-2">
                                            <button type="button" onclick="showStudentProfile({{ candidate.student.id }})" class="btn-mini-modern">
                                                <i class="bi bi-person-badge"></i> Profile
                                            </button>

                                            {% if candidate.status == 'pending' %}
                                                <form method="POST" action="{{ path('app_company_application_validate', {id: candidate.id}) }}" class="m-0">
                                                    <button type="submit" class="btn-action-sm btn-accept-ui"><i class="bi bi-check2"></i></button>
                                                </form>
                                                <button onclick="openRefuseModal({{ candidate.id }}, '{{ candidate.student.firstName }}')" class="btn-action-sm btn-refuse-ui">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endif %}
        </div>

        <div id="tab-interns" class="tab-panel">
            {% set now = "now"|date("U") %}
            {% set interns = candidates|filter(c => c.status == 'accepted') %}

            {% if interns|length == 0 %}
                <div class="text-center py-5 stat-card">
                    <i class="bi bi-mortarboard text-muted fs-1 mb-3"></i>
                    <p class="text-muted">Aucun stagiaire accepté pour le moment.</p>
                </div>
            {% else %}
                <div class="row g-4">
                    {% for candidate in interns %}
                        <div class="col-md-6 col-lg-4">
                            <div class="intern-card-ui">
                                <div class="d-flex align-items-start justify-content-between mb-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-ui" style="width: 55px; height: 55px; font-size: 1.2rem;">
                                            {{ candidate.student.firstName|first }}{{ candidate.student.lastName|first }}
                                        </div>
                                        <div>
                                            <h6 class="fw-bold text-white mb-0">{{ candidate.student.firstName }} {{ candidate.student.lastName }}</h6>
                                            <span class="text-primary small fw-semibold">{{ candidate.student.specialty }}</span>
                                        </div>
                                    </div>
                                    <div class="compatibility-pill text-success">{{ candidate.matchingScore }}% Match</div>
                                </div>

                                <div class="p-3 rounded-4 mb-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color);">
                                    <div class="small text-muted mb-2"><i class="bi bi-bank me-2"></i> {{ candidate.student.universityName|default('Université Algérie') }}</div>
                                    <div class="small text-white-50"><i class="bi bi-calendar-event me-2"></i> Accepté le: {{ candidate.approvedAt|default(candidate.offer.createdAt)|date('d/m/Y') }}</div>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="button" onclick="showStudentProfile({{ candidate.student.id }})" class="btn btn-sm flex-grow-1 fw-bold" style="background: #1a1a1a; color: #fff; border: 1px solid #333; border-radius: 10px;">
                                        Voir Profile
                                    </button>
                                    {% if candidate.conventionFile %}
                                        <a href="{{ path('app_company_download_convention', {id: candidate.id}) }}" class="btn btn-sm btn-primary flex-grow-1 fw-bold" style="border-radius: 10px;">
                                            <i class="bi bi-file-earmark-pdf me-1"></i> Convention
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>

    <div id="refuseOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;align-items:center;justify-content:center;backdrop-filter:blur(5px);">
        <div style="background:#0a0a0a;border:1px solid #333;border-radius:24px;padding:2rem;max-width:450px;width:90%;">
            <h5 class="fw-bold text-white mb-4">Refuser la candidature</h5>
            <textarea id="refuseReason" rows="4" class="form-control mb-4" style="background:#000;border:1px solid #333;color:white;border-radius:12px;padding:15px;" placeholder="Expliquez la raison (optionnel)..."></textarea>
            <div class="d-flex gap-3">
                <button onclick="submitRefuse()" id="confirmRefuseBtn" class="btn btn-danger flex-grow-1 fw-bold py-2" style="border-radius:10px;">Confirmer</button>
                <button onclick="closeRefuseModal()" class="btn btn-dark flex-grow-1 fw-bold py-2" style="border-radius:10px;">Annuler</button>
            </div>
        </div>
    </div>

    <div id="toast-container" style="position:fixed; bottom:2rem; right:2rem; z-index:10000;"></div>

    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + tab).classList.add('active');
            document.getElementById('btn-' + tab).classList.add('active');
        }

        function openRefuseModal(id, name) {
            _refuseId = id;
            document.getElementById('refuseOverlay').style.display = 'flex';
        }

        function closeRefuseModal() {
            document.getElementById('refuseOverlay').style.display = 'none';
        }

        async function submitRefuse() {
            const reason = document.getElementById('refuseReason').value;
            const btn = document.getElementById('confirmRefuseBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const formData = new FormData();
                formData.append('rejection_reason', reason);

                const res = await fetch(`/company/application/${_refuseId}/refuse`, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (res.ok) {
                    closeRefuseModal();
                    const row = document.getElementById('row-' + _refuseId);
                    if (row) {
                        row.classList.add('row-removing');
                        setTimeout(() => row.remove(), 500);
                    }
                    showToast('Candidature refusée', 'success');
                }
            } catch (err) {
                btn.disabled = false;
                btn.innerHTML = 'Confirmer';
                showToast('Erreur serveur', 'danger');
            }
        }

        function showToast(msg, type) {
            const toast = document.createElement('div');
            toast.className = `alert alert-${type} shadow-lg`;
            toast.style.cssText = "min-width:200px; border-radius:12px; font-weight:600;";
            toast.innerHTML = `<i class="bi bi-info-circle me-2"></i> ${msg}`;
            document.getElementById('toast-container').appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
{% endblock %}