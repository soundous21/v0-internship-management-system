            function saveProfile() {
                const btn = event.currentTarget;
                const originalContent = btn.innerHTML;

                // إظهار مؤشر تحميل بسيط
                btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Saving...';
                btn.disabled = true;

                const formData = new FormData();

                // جمع البيانات من الحقول
                formData.append('companyName', document.getElementById('comp-name').value);
                formData.append('email', document.getElementById('comp-email').value);
                formData.append('phone', document.getElementById('comp-phone').value);
                formData.append('industry', document.getElementById('comp-industry').value);
                formData.append('wilaya', document.getElementById('comp-wilaya').value);
                formData.append('website', document.getElementById('comp-web').value);
                formData.append('bio', document.getElementById('comp-desc').value);

                // إحداثيات الخريطة
                formData.append('latitude', document.getElementById('profile-lat').value);
                formData.append('longitude', document.getElementById('profile-lng').value);

                // إضافة ملف اللوجو
                const logoInput = document.getElementById('logo-input');
                if (logoInput.files[0]) {
                    formData.append('logo', logoInput.files[0]);
                }

                // إضافة ملف الإثبات
                const vInput = document.getElementById('verification-input');
                if (vInput.files[0]) {
                    formData.append('verificationFile', vInput.files[0]);
                }

                // إرسال الطلب إلى الـ Controller
                fetch("{{ path('app_company_profile_update') }}", {
                    method: "POST",
                    body: formData
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            alert("The profile has been updated successfully!");
                            window.location.reload(); // لتحديث الصور والبيانات في الصفحة
                        } else {
                            alert("Error: " + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert("An error occurred while connecting to the server");
                    })
                    .finally(() => {
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                    });
            }







