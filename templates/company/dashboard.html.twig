            function updateOfferPreview() {
                const titleEl    = document.getElementById('offer-title');
                const locEl      = document.getElementById('offer-location');
                const wilayaEl   = document.getElementById('offer-wilaya');
                const durationEl = document.getElementById('offer-duration');
                const deadlineEl = document.getElementById('offer-deadline');
                // تحديث تاريخ بداية العرض
                const startOffer = document.getElementById('offer-start-date').value;
                document.getElementById('prev-start-offer').innerHTML = `<i class="bi bi-calendar-check"></i> Starts: ${startOffer || 'Not set'}`;

                // تحديث تاريخ بداية التربص
                const startInternship = document.getElementById('internship-start-date').value;
                document.getElementById('prev-start-internship').innerHTML = `<i class="bi bi-play-circle"></i> Internship: ${startInternship || 'Not set'}`;
                const latEl      = document.getElementById('offer-lat');
                const lngEl      = document.getElementById('offer-lng');

                if (!titleEl) return; // الصفحة مش صفحة إنشاء offer

                const title    = titleEl.value;
                const loc      = locEl    ? locEl.value      : '';
                const wilaya   = wilayaEl ? wilayaEl.value   : '';
                const duration = durationEl ? durationEl.value : '';
                const deadline = deadlineEl ? deadlineEl.value : '';
                const lat      = latEl ? latEl.value : '';
                const lng      = lngEl ? lngEl.value : '';

                const prevTitle    = document.getElementById('prev-offer-title');
                const prevLoc      = document.getElementById('prev-offer-loc');
                const prevWilaya   = document.getElementById('prev-offer-wilaya');
                const prevDuration = document.getElementById('prev-offer-duration');
                const prevDate     = document.getElementById('prev-offer-date');
                const prevCoords   = document.getElementById('prev-offer-coords');

                if (prevTitle)    prevTitle.innerText    = title    || 'Position Title';
                if (prevLoc)      prevLoc.innerText      = `• ${loc || 'Hybrid'}`;
                if (prevWilaya)   prevWilaya.innerText   = wilaya   || 'Location / Wilaya';
                if (prevDuration) prevDuration.innerText = duration ? `Duration: ${duration}` : 'Duration not set';
                if (prevDate)     prevDate.innerText     = deadline ? `Until: ${deadline}`    : 'No deadline';

                // إحداثيات الخريطة
                if (prevCoords) {
                    if (lat && lng) {
                        const mapUrl = `https://www.google.com/maps?q=${lat},${lng}`;
                        prevCoords.innerHTML = `
                    <a href="${mapUrl}" target="_blank" class="text-info text-decoration-none d-flex align-items-center gap-1">
                        <i class="bi bi-geo-fill text-danger"></i>
                        <span>View on Map</span>
                        <i class="bi bi-box-arrow-up-right" style="font-size:0.6rem;"></i>
                    </a>`;
                    } else {
                        prevCoords.innerText = 'Coordinates not set';
                    }
                }


                // الجديد
                const prevSkills = document.getElementById('prev-skills-container');
                const checked    = document.querySelectorAll('.skill-checkbox:checked');
                if (prevSkills) {
                    prevSkills.innerHTML = '';
                    checked.forEach(cb => {
                        const span = document.createElement('span');
                        span.className = 'badge bg-dark border border-secondary text-primary me-1 mb-1';
                        span.style.fontSize = '0.7rem';
                        span.innerText = cb.parentElement.textContent.trim();
                        prevSkills.appendChild(span);
                    });
                }
            }
