{% extends 'base.html.twig' %}

{% block title %}Stag.io - Company{% endblock %}

{% block body %}

    {% block stylesheets %}
        {# رابط مكتبة الخرائط CSS #}
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
        <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">
        <style>
            :root {
                --bg-main: #000000;
                --bg-sidebar: #000000;
                --card-bg: #000000;
                --border-color: #111827;
                --text-main: #ffffff;
                --text-muted: #94a3b8;
                --accent-primary: #3b82f6;
            }

            body {
                background-color: var(--bg-main);
                color: var(--text-main);
                font-family: 'Inter', sans-serif;
                overflow-x: hidden;
                -webkit-font-smoothing: antialiased;
            }

            header, .navbar, .navbar-top { display: none !important; }

            .sidebar {
                width: 260px; height: 100vh; position: fixed;
                background: var(--bg-sidebar); border-right: 1px solid var(--border-color);
                padding: 1.5rem; z-index: 1000; left: 0; top: 0;
            }

            .main-content { margin-left: 260px; padding: 2rem; width: calc(100% - 260px); }

            .nav-link-custom {
                display: flex; align-items: center; gap: 12px;
                color: var(--text-muted); text-decoration: none;
                padding: 12px 15px; border-radius: 8px; margin-bottom: 5px;
                transition: all 0.2s;
            }

            .nav-link-custom:hover, .nav-link-custom.active {
                background: rgba(59, 130, 246, 0.1);
                color: var(--accent-primary);
            }

            .stat-card {
                background: var(--card-bg);
                border: 1px solid var(--border-color);
                border-radius: 12px;
                padding: 1.5rem;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .stat-card:hover {
                transform: translateY(-5px);
                border-color: var(--accent-primary);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            }

            .form-control {
                background: #020617;
                border: 1px solid #334155; color: white; border-radius: 8px; padding: 12px;
            }

            .form-control:focus {
                background: #020617;
                color: white; border-color: var(--accent-primary); box-shadow: none;
            }

            .label-custom { color: #cbd5e1; font-weight: 500; font-size: 0.85rem; margin-bottom: 8px; display: block; }

            .logo-preview-circle {
                width: 80px; height: 80px; border-radius: 12px;
                background: #020617; border: 1px dashed var(--border-color);
                display: flex; align-items: center; justify-content: center; overflow: hidden;
            }

            .btn-save-custom {
                background: linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
                border: none; color: white;
                transition: transform 0.2s, box-shadow 0.2s;
            }

            .btn-save-custom:hover {
                transform: scale(1.05);
                box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
            }


            .skill-badge {
                background: rgba(59, 130, 246, 0.1);
                color: #3b82f6;
                border: 1px solid rgba(59, 130, 246, 0.3);
                padding: 5px 12px;
                border-radius: 20px;
                font-size: 0.8rem;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .skill-badge i { cursor: pointer; }















            .status-badge {
                padding: 6px 14px;
                border-radius: 50px;
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }
            .status-badge.warning { background: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.2); }
            .status-badge.success { background: rgba(40, 167, 69, 0.1); color: #28a745; border: 1px solid rgba(40, 167, 69, 0.2); }
            .status-badge.danger  { background: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.2); }

            .request-row:hover {
                background: rgba(255, 255, 255, 0.02) !important;
                transform: scale(1.002);
            }

            .btn-outline-danger:hover {
                background: #dc3545 !important;
                color: white !important;
                box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
            }



            .stat-card-custom {
                background-color: var(--bg-sidebar); /* أسود صريح */
                border: 1px solid var(--border-color); /* إطار ناعم */
                border-radius: 16px;
                padding: 20px;
                display: flex;
                align-items: center;
                gap: 15px;
                transition: all 0.3s ease;
                height: 100%;
            }

            /* تأثير عند التمرير */
            .stat-card-custom:hover {
                border-color: var(--accent-primary);
                box-shadow: 0 0 20px var(--glow-color);
                transform: translateY(-5px);
            }

            /* تنسيق الأيقونة */
            .stat-icon-wrapper {
                background-color: rgba(51, 120, 243, 0.1); /* خلفية زرقاء شفافة جداً */
                color: var(--accent-primary); /* اللون الأزرق التكنولوجي */
                width: 50px;
                height: 50px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
            }

            /* تنسيق النصوص */
            .stat-number {
                font-size: 1.5rem;
                font-weight: 800;
                color: white;
                margin-bottom: 0;
                line-height: 1;
            }

            .stat-label {
                color: var(--text-muted); /* رمادي باهت */
                font-size: 0.85rem;
                margin-bottom: 0;
                margin-top: 5px;
                white-space: nowrap;
            }


            .search-container-custom {
                position: relative;
                width: 300px;
            }

            /* أيقونة البحث */
            .search-icon {
                position: absolute;
                top: 50%;
                left: 15px;
                transform: translateY(-50%);
                color: var(--text-muted);
                font-size: 1rem;
                transition: all 0.3s ease;
                pointer-events: none; /* لكي لا تعيق النقر على المربع */
            }

            /* مربع الإدخال */
            .search-input {
                width: 100%;
                background-color: var(--bg-sidebar); /* الأسود الصريح #000 */
                border: 1px solid var(--border-color); /* الإطار الناعم الحالي */
                border-radius: 12px;
                padding: 10px 15px 10px 45px; /* مساحة للأيقونة على اليسار */
                color: white;
                font-size: 0.9rem;
                outline: none;
                transition: all 0.3s ease;
            }

            /* تأثير عند التركيز (Focus) - النيون الأزرق */
            .search-input:focus {
                border-color: var(--accent-primary);
                box-shadow: 0 0 15px var(--glow-color);
                background-color: rgba(51, 120, 243, 0.05); /* لمسة زرقاء خفيفة جداً للخلفية */
            }

            /* تغيير لون الأيقونة عند التركيز */
            .search-input:focus + .search-icon {
                color: var(--accent-primary);
            }

            /* لون الـ Placeholder */
            .search-input::placeholder {
                color: var(--text-muted);
                opacity: 0.6;
            }










             .stat-card {
                 background: #000000 !important; /* أسود عميق */
                 border: 2px solid #1e293b !important;
                 transition: all 0.3s ease-in-out;
                 position: relative;
                 overflow: hidden;
             }

            /* تأثير عند تمرير الفأرة على البطاقة */
            .stat-card:hover {
                transform: translateY(-5px);
                border-color: #3b82f6 !important; /* تغيير اللون للحدود عند التمرير */
                box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.2); /* توهج أزرق خفيف */
            }

            .skill-badge {
                background: rgba(59, 130, 246, 0.1) !important;
                color: #60a5fa !important;
                border: 1px solid rgba(59, 130, 246, 0.2);
                padding: 4px 10px;
                border-radius: 6px;
                font-size: 0.75rem;
            }

            .progress {
                background-color: #1a1a1a !important;
                border-radius: 10px;
            }

            .progress-bar {
                background: linear-gradient(90deg, #3b82f6, #2dd4bf) !important; /* تدرج أزرق للمقاعد */
                box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
            }

            .btn-outline-light {
                border-color: #334155 !important;
                color: #94a3b8 !important;
            }

            .btn-outline-light:hover {
                background: #f8fafc !important;
                color: #000 !important;
            }
        </style>








    {% endblock %}

    <div class="sidebar">
        <div class="d-flex align-items-center gap-2 mb-4 px-2">

            <span class="fw-bold fs-5 text-white">Stag<span class="text-primary">.io</span></span>
        </div>

        <nav>
            <a href="{{ path('app_company_dashboard') }}"
               class="nav-link-custom {{ app.request.attributes.get('_route') == 'app_company_dashboard' ? 'active' : '' }}">
                <i class="bi bi-grid"></i> Dashboard
            </a>

            <a href="{{ path('app_company_offers') }}"
               class="nav-link-custom {{ app.request.attributes.get('_route') == 'app_company_offers' ? 'active' : '' }}">
                <i class="bi bi-briefcase"></i> Manage Offers
            </a>

            <a href="{{ path('app_company_applicants') }}"
               class="nav-link-custom {{ app.request.attributes.get('_route') == 'app_company_applicants' ? 'active' : '' }}">
                <i class="bi bi-people"></i> Applicants
            </a>

            <a href="{{ path('app_company_profile') }}"
               class="nav-link-custom {{ app.request.attributes.get('_route') == 'app_company_profile' ? 'active' : '' }}">
                <i class="bi bi-person-circle"></i> Company Profile
            </a>

            <hr class="border-secondary my-4 opacity-25">


    <div class="d-flex justify-content-center mt-5 mb-4">
        <a href="{{ path('app_logout') }}"
           style="color: #93c5fd; border: 1px solid rgba(147, 197, 253, 0.3); background: rgba(147, 197, 253, 0.05); text-decoration: none; padding: 10px 25px; border-radius: 8px; font-weight: 500; transition: all 0.3s ease;"
           onmouseover="this.style.background='rgba(147, 197, 253, 0.2)'; this.style.borderColor='#93c5fd';"
           onmouseout="this.style.background='rgba(147, 197, 253, 0.05)'; this.style.borderColor='rgba(147, 197, 253, 0.3)';"
           class="d-inline-flex align-items-center">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>
        </nav>
    </div>

    <div class="main-content">
    {% set current_route = app.request.attributes.get('_route') %}

    {# --- 1. Dashboard Overview --- #}
    {% if current_route == 'app_company_dashboard' %}
        <div class="dashboard-header mb-4">
            <h2 class="fw-bold text-white">Company Dashboard</h2>
            <p class="text-secondary">Welcome back! Here is a summary of your activity.</p>
        </div>




        <div class="row g-3 mb-4">


            {# تنبيه انعدام المشاركة #}
            {# تنبيه انعدام المشاركة بتصميم مودرن #}
{% if noApplicants is not empty %}
    <div class="col-md-4">
        <div class="stat-card h-100 p-4" style="border-color: rgba(239, 68, 68, 0.3) !important;">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
