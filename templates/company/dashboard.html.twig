        <div class="d-flex flex-column gap-4">
            {% for offer in offers %}
                <div class="stat-card p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <h5 class="fw-bold mb-0 text-white" style="letter-spacing: -0.5px; font-size: 1.25rem;">{{ offer.title }}</h5>

                                {# حالة العرض المتوهجة #}
                                {% set cs = offer.computedStatus %}
                                {% set status_styles = {
                                    'Active': 'background: rgba(34, 197, 94, 0.1); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.2);',
                                    'In Progress': 'background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2);',
                                    'Deadline Over': 'background: rgba(234, 179, 8, 0.1); color: #facc15; border: 1px solid rgba(234, 179, 8, 0.2);',
                                    'Expired': 'background: rgba(239, 68, 68, 0.1); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2);',
                                    'Closed': 'background: rgba(148, 163, 184, 0.1); color: #94a3b8; border: 1px solid rgba(148, 163, 184, 0.2);',
                                    'Draft': 'background: rgba(255, 255, 255, 0.05); color: #64748b; border: 1px solid rgba(255, 255, 255, 0.1);'
                                } %}
                                <span class="badge rounded-pill" style="{{ status_styles[cs]|default(status_styles['Closed']) }} font-size: 0.65rem; padding: 5px 12px;">
                            {{ cs|upper }}
                        </span>
                            </div>

                            <div class="d-flex align-items-center gap-2 small">
                                <span class="text-primary fw-semibold" style="color: #3b82f6 !important;">{{ offer.company.companyName }} Algeria</span>
                                <span style="color: #334155;">/</span>
                                <span class="text-primary fw-semibold"><i class="bi bi-geo-alt me-1 text-primary"></i> {{ offer.wilaya }}</span>
                            </div>
                        </div>

                        <div class="text-end">
                            <div class="text-secondary mb-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">Availability</div>
                            <div class="d-flex align-items-center gap-3">
                                <div class="progress" style="width: 100px; height: 8px;">
                                    {% set occupancy = (offer.seats > 0) ? ((offer.seats - offer.remainingSeats) / offer.seats * 100) : 0 %}
                                    <div class="progress-bar" role="progressbar" style="width: {{ occupancy }}%"></div>
                                </div>
