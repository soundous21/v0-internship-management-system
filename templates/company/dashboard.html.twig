                         id="application-card-{{ app.id }}"
                         style="background: #000; border: 1px solid #262626; border-radius: 20px; transition: all 0.3s ease;">

                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm"
                                 style="width: 48px; height: 48px; background: #111; border-radius: 12px; border: 1px solid #333;">
