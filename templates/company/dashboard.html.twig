<script>
document.getElementById('companyStampInput').addEventListener('change', async function () {
    const file = this.files[0];
    if (!file) return;

    // ── التحقق المبدئي على جانب العميل ──────────────────────────
    const allowedTypes = ['image/png', 'image/jpeg', 'image/webp'];
    if (!allowedTypes.includes(file.type)) {
        showStampMsg('❌ Unsupported format. Use PNG, JPG, or WebP.', '#ef4444');
        return;
    }
    if (file.size > 2 * 1024 * 1024) {
        showStampMsg('❌ File too large. Maximum 2 MB.', '#ef4444');
        return;
    }

    // ── معاينة فورية قبل الرفع ───────────────────────────────────
    const reader = new FileReader();
    reader.onload = e => {
        const wrapper = document.getElementById('stamp-preview-wrapper');
        wrapper.innerHTML = `<img id="stamp-preview-img"
            src="${e.target.result}"
            style="width:100%;height:100%;object-fit:contain;">`;
    };
    reader.readAsDataURL(file);

    // ── رفع الملف إلى الـ server ─────────────────────────────────
    showStampMsg('⏳ Uploading...', '#94a3b8');

    const formData = new FormData();
    formData.append('file', file);

    try {
        const res  = await fetch('{{ path("app_company_upload_stamp") }}', {
            method: 'POST',
            body:   formData,
        });
        const data = await res.json();

        if (data.success) {
            showStampMsg('✅ Stamp saved successfully!', '#10b981');
        } else {
            showStampMsg('❌ ' + (data.error || 'Upload failed.'), '#ef4444');
        }
    } catch (err) {
        showStampMsg('❌ Network error. Please try again.', '#ef4444');
    }
});

function showStampMsg(text, color) {
    const el = document.getElementById('stamp-msg');
    el.textContent = text;
    el.style.color  = color;
    el.style.display = 'block';
    // اخفاء الرسالة بعد 4 ثواني
    setTimeout(() => { el.style.display = 'none'; }, 4000);
}
</script>
    {% endblock %}