                    <div class="modal-dialog modal-dialog-centered">
                        <form id="refuse-form-{{ app.id }}" action="{{ path('app_company_application_refuse', {id: app.id}) }}" method="POST" class="w-100 m-0">
                            <div class="modal-content" style="background: #000; border: 1px solid #dc2626; border-radius: 24px;">
                                <div class="modal-header border-0">
