            async function rejectApplication(applicationId) {
                const reason = prompt("اكتب سبب الرفض");

                if (!reason) return;

                const response = await fetch(`/application/${applicationId}/reject`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: new URLSearchParams({
                        reason: reason
                    })
                });

                const data = await response.json();

                if (data.success) {
                    const card = document.getElementById(`application-card-${applicationId}`);

                    if (card) {
                        card.remove();
                    }
                }
            }






            async function handleApplication(id, action, btn) {
                if (!confirm(`Are you sure you want to ${action} this application?`)) return;

                btn.disabled = true;
                const originalContent = btn.innerHTML;
                btn.innerHTML = '<span class=\"spinner-border spinner-border-sm\"></span>';

                try {
                    const res = await fetch(`/company/applications/${id}/${action}`, { method: 'POST' });
                    const data = await res.json();

                    if (data.success) {
                        // العثور على بطاقة الطلب (Card) وإخفاؤها
                        const card = btn.closest('.application-card'); // تأكد أن الكلاس مطابق لما لديك
                        if (card) {
                            card.style.transition = 'all 0.4s ease';
                            card.style.opacity = '0';
                            card.style.transform = 'scale(0.95)';
                            setTimeout(() => {
                                card.remove();
                                // تحديث العدادات إذا وجدت
                                updateCounters();
                            }, 400);
                        }
                    } else {
                        alert(data.error || 'Operation failed');
                        btn.disabled = false;
                        btn.innerHTML = originalContent;
                    }
                } catch (err) {
                    alert('Network error');
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                }
            }




