                                    data-level="{{ app.student.level }}"
                                    data-specialty="{{ app.student.specialty|default('Student') }}"
                                    data-location="{{ app.student.wilaya|default('Not set') }}"
                                    data-university="{{ app.student.university|default('Not set') }}"
                                    data-email="{{ app.student.email }}"
                                    data-image="{{ app.student.profilePicture ? asset('uploads/profiles/' ~ app.student.profilePicture) : '' }}"
                                    data-initials="{{ app.student.firstName|first }}{{ app.student.lastName|first }}"
                                    data-phone="{{ app.student.phone|default('') }}"
                                    data-portfolio="{{ app.student.portfolioLink|default('') }}"
                                    data-github="{{ app.student.githubLink|default('') }}"
                                    data-bio="{{ app.student.bio|default('') }}"
                                    data-skills="{{ app.student.skills|map(s => s.tagName)|join(',') }}">
                                <i class="bi bi-eye me-2"></i>View Profile
                            </button>

                            <div class="d-flex gap-2">
                                {% if app.status == 'pending' %}
                                    <form action="{{ path('app_company_application_validate', {id: app.id}) }}" method="POST" class="flex-grow-1 m-0">
                                        <button class="btn btn-sm w-100 fw-bold py-2" style="background: #3b82f6; color: #fff; border: none; border-radius: 10px;">
                                            Accept
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center"
                                            style="width: 42px; border-radius: 10px; border-color: rgba(220, 38, 38, 0.4);"
                                            data-bs-toggle="modal" data-bs-target="#refuseModal{{ app.id }}">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                {% elseif app.status == 'pending_admin' %}
                                    <div class="btn btn-sm w-100 disabled py-2 fw-bold" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 10px;">
                                        <i class="bi bi-clock-history me-1"></i> Waiting Admin
                                    </div>
                                {% elseif app.status == 'accepted' %}
                                    <div class="btn btn-sm w-100 disabled py-2 fw-bold" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); border-radius: 10px;">
                                        <i class="bi bi-check2-all me-1"></i> Accepted
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>

