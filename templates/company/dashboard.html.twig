                                              placeholder="Provide feedback (sent via email)..."
                                              style="background: #111; color: #fff; border: 1px solid #333; border-radius: 15px;"></textarea>
                                </div>
                                <div class="modal-footer border-0">
                                    <div class="d-flex gap-2 w-100">
                                        <button type="button" class="btn btn-dark flex-grow-1 py-2" style="border-radius: 12px;" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-danger flex-grow-1 py-2 fw-bold" style="border-radius: 12px;">Confirm Rejection</button>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="p-5" style="background: #0a0a0a; border-radius: 20px; border: 1px dashed #333;">
