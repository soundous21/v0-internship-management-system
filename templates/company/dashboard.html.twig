    {% block javascripts %}
        {# 1. تحميل المكتبة أولاً #}
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

        <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

        <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>

        <script>
            // =============================================
            // 1. PROFILE FUNCTIONS
            // =============================================
            function previewLogo(input) {
                if (input.files && input.files[0]) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const preview = document.getElementById('logo-preview-img');
                        const prevIcon = document.getElementById('logo-preview-icon');
                        if (preview) {
                            preview.src = e.target.result;
                            preview.classList.remove('d-none');
                        }
                        if (prevIcon) { prevIcon.classList.add('d-none'); }
                    }
                    reader.readAsDataURL(input.files[0]);
                }
            }

            function updatePreview() {
                const name     = document.getElementById('comp-name');
                const email    = document.getElementById('comp-email');
                const industry = document.getElementById('comp-industry');
                const desc     = document.getElementById('comp-desc');

                if (name)     document.getElementById('prev-name').innerText     = name.value     || 'Company Name';
                if (email)    document.getElementById('prev-email').innerText    = email.value    || 'email@company.com';
                if (industry) document.getElementById('prev-industry').innerText = industry.value || 'Industry';
                if (desc)     document.getElementById('prev-desc').innerText     = desc.value     || 'Description...';
            }

            function saveProfile() {
                const formData = new FormData();
                formData.append('companyName', document.getElementById('comp-name').value);
                formData.append('email',       document.getElementById('comp-email').value);
                formData.append('phone',       document.getElementById('comp-phone').value);
                formData.append('industry',    document.getElementById('comp-industry').value);
                formData.append('wilaya',      document.getElementById('comp-wilaya').value);
                formData.append('website',     document.getElementById('comp-web').value);
                formData.append('bio',         document.getElementById('comp-desc').value);
                formData.append('latitude',  document.getElementById('profile-lat').value);
                formData.append('longitude', document.getElementById('profile-lng').value);
                const logoFile = document.getElementById('logo-input').files[0];
                if (logoFile) formData.append('logo', logoFile);











                fetch('{{ path("app_company_profile_update") }}', {
                    method: 'POST',
                    body: formData
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.status === 'success') alert('✅ Changes Saved!');
                        else alert('❌ Error: ' + data.message);
                    })
                    .catch(() => alert('❌ Network error, please try again.'));
            }

            // =============================================
            // 2. SKILLS TAGS
            // =============================================

            function addSkillTag() {
                const input     = document.getElementById('skill-input');
                const container = document.getElementById('skills-container');
                if (!input || input.value.trim() === '') return;

                const tag = document.createElement('div');
                tag.className     = 'skill-badge';
                tag.dataset.skill = input.value.trim();
                tag.innerHTML     = `${input.value.trim()} <i class="bi bi-x-circle" onclick="removeSkill(this)"></i>`;
                container.appendChild(tag);

                input.value = '';
                syncSkillsToHidden();
                updateOfferPreview();
            }

            function removeSkill(icon) {
                icon.parentElement.remove();
                syncSkillsToHidden();
                updateOfferPreview();
            }

            function syncSkillsToHidden() {
                const tags   = document.querySelectorAll('#skills-container .skill-badge');
                const hidden = document.getElementById('skills-hidden');
                if (!hidden) return;
                hidden.value = Array.from(tags).map(t => t.dataset.skill).join(',');
            }
            // السماح بالإضافة عبر Enter
            const skillInput = document.getElementById('skill-input');
            if (skillInput) {
                skillInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        addSkillTag();
                    }
                });
            }

            // =============================================
            // 3. OFFER PREVIEW
            // =============================================
            function updateOfferPreview() {
                const titleEl    = document.getElementById('offer-title');
                const locEl      = document.getElementById('offer-location');
                const wilayaEl   = document.getElementById('offer-wilaya');
                const durationEl = document.getElementById('offer-duration');
                const deadlineEl = document.getElementById('offer-deadline');
                // تحديث تاريخ بداية العرض
                const startOffer = document.getElementById('offer-start-date').value;
                document.getElementById('prev-start-offer').innerHTML = `<i class="bi bi-calendar-check"></i> Starts: ${startOffer || 'Not set'}`;

                // تحديث تاريخ بداية التربص
                const startInternship = document.getElementById('internship-start-date').value;
                document.getElementById('prev-start-internship').innerHTML = `<i class="bi bi-play-circle"></i> Internship: ${startInternship || 'Not set'}`;
