{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
        <div class="glass-card p-5 col-md-5">
            <h2 class="text-center animated-title mb-4">Register</h2>

            <form method="post">
                <div class="mb-3">
                    <label>
                        <input type="text" name="username" class="form-control" placeholder="Username" required>
                    </label>
                </div>
                <div class="mb-3">
                    <label>
                        <input type="email" name="email" class="form-control" placeholder="Email" required>
                    </label>
                </div>
                <div class="mb-3">
                    <label>
                        <input type="password" name="password" class="form-control" placeholder="Password" required>
                    </label>
                </div>
                <div class="mb-3">
                    <label>
                        <select name="role" class="form-select">
                            <option value="4">Participant</option>
                            <option value="3">Organizer</option>
                            <option value="5">Author</option>
                        </select>
                    </label>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-glow" type="submit">Register</button>
                </div>
                <div class="mt-3 text-center">
                    <a href="{{ path('login') }}" class="text-info">Already have an account? Login</a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}



