<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام المؤتمرات المتطور | إنشاء حساب جديد</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap');

        :root {
            --primary-color: #9d4edd;
            --secondary-color: #00f5ff;
            --accent-color: #c77dff;
            --dark-bg: #10002b;
            --card-bg: rgba(255, 255, 255, 0.08);
            --card-border: rgba(255, 255, 255, 0.15);
        }

        * {
            font-family: 'Tajawal', sans-serif !important;
        }

        body {
            background-color: var(--dark-bg) !important;
            color: #fff !important;
            min-height: 100vh;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* خلفية التكنولوجيا المتحركة */
        .tech-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
        }

        .grid-lines {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image:
                    linear-gradient(to right, rgba(154, 96, 255, 0.1) 1px, transparent 1px),
                    linear-gradient(to bottom, rgba(154, 96, 255, 0.1) 1px, transparent 1px);
            background-size: 40px 40px;
            animation: gridMove 20s linear infinite;
        }

        .floating-shapes {
            position: absolute;
            width: 100%;
            height: 100%;
        }

        .shape {
            position: absolute;
            background: var(--primary-color);
            opacity: 0.1;
            border-radius: 50%;
            filter: blur(40px);
            animation: float 15s infinite ease-in-out;
        }

        .shape:nth-child(1) {
            width: 300px;
            height: 300px;
            top: 10%;
            left: 5%;
            animation-delay: 0s;
        }

        .shape:nth-child(2) {
            width: 250px;
            height: 250px;
            bottom: 15%;
            right: 10%;
            background: var(--secondary-color);
            animation-delay: -5s;
        }

        .shape:nth-child(3) {
            width: 350px;
            height: 350px;
            top: 50%;
            right: 15%;
            background: var(--accent-color);
            animation-delay: -10s;
        }

        /* كرت التسجيل */
        .register-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 24px;
            border: 1px solid var(--card-border);
            box-shadow:
                    0 20px 40px rgba(0, 0, 0, 0.3),
                    inset 0 1px 0 rgba(255, 255, 255, 0.1),
                    0 0 30px rgba(154, 96, 255, 0.2);
            width: 100%;
            max-width: 900px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            z-index: 2;
        }

        .register-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg,
            var(--secondary-color),
            var(--primary-color),
            var(--accent-color));
            z-index: 3;
        }

        .register-header {
            text-align: center;
            margin-bottom: 40px;
            position: relative;
        }

        .hologram-logo {
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            background: linear-gradient(45deg,
            var(--primary-color),
            var(--secondary-color),
            var(--accent-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            box-shadow:
                    0 0 30px rgba(154, 96, 255, 0.6),
                    inset 0 0 20px rgba(255, 255, 255, 0.2);
            position: relative;
            animation: hologramPulse 4s infinite alternate;
        }

        .hologram-logo::after {
            content: '';
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            background: linear-gradient(45deg,
            var(--primary-color),
            transparent,
            var(--secondary-color));
            border-radius: 50%;
            z-index: -1;
            filter: blur(10px);
            opacity: 0.6;
        }

        .register-title {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(90deg,
            var(--secondary-color),
            var(--accent-color),
            var(--primary-color));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 10px;
            text-shadow: 0 0 10px rgba(154, 96, 255, 0.8);
        }

        .register-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.7);
            font-weight: 300;
        }

        /* خطوات التسجيل */
        .register-steps {
            display: flex;
            justify-content: space-between;
            margin-bottom: 40px;
            position: relative;
        }

        .register-steps::before {
            content: '';
            position: absolute;
            top: 25px;
            right: 50px;
            left: 50px;
            height: 2px;
            background: rgba(255, 255, 255, 0.1);
            z-index: 1;
        }

        .step {
            text-align: center;
            position: relative;
            z-index: 2;
            flex: 1;
        }

        .step-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 20px;
            color: rgba(255, 255, 255, 0.5);
            transition: all 0.3s ease;
        }

        .step.active .step-icon {
            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));
            border-color: var(--secondary-color);
            color: white;
            box-shadow: 0 0 15px rgba(154, 96, 255, 0.5);
        }

        .step.completed .step-icon {
            background: linear-gradient(45deg, #2ecc71, #27ae60);
            border-color: #2ecc71;
            color: white;
        }

        .step-label {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.7);
            font-weight: 500;
        }

        .step.active .step-label {
            color: var(--secondary-color);
            font-weight: 600;
        }

        /* حاوية النموذج */
        .form-container {
            min-height: 400px;
        }

        .form-step {
            display: none;
            animation: fadeIn 0.5s ease;
        }

        .form-step.active {
            display: block;
        }

        /* تخصيص حقول Bootstrap */
        .form-control, .form-select {
            background: rgba(0, 0, 0, 0.25) !important;
            border: 1px solid rgba(154, 96, 255, 0.3) !important;
            border-radius: 12px !important;
            color: white !important;
            padding: 15px !important;
            transition: all 0.3s ease !important;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--secondary-color) !important;
            box-shadow: 0 0 0 0.25rem rgba(0, 245, 255, 0.25) !important;
            outline: none !important;
        }

        .form-label {
            color: rgba(255, 255, 255, 0.9);
            font-weight: 500;
            margin-bottom: 10px;
            text-shadow: 0 0 5px rgba(154, 96, 255, 0.5);
        }

        .input-group-text {
            background: rgba(0, 0, 0, 0.25) !important;
            border: 1px solid rgba(154, 96, 255, 0.3) !important;
            color: var(--accent-color) !important;
            border-radius: 12px 0 0 12px !important;
        }

        /* اختيار الدور */
        .role-options {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .role-card {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            padding: 25px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .role-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent-color);
            background: rgba(154, 96, 255, 0.1);
        }

        .role-card.selected {
            border-color: var(--secondary-color);
            background: linear-gradient(135deg, rgba(0, 245, 255, 0.1), rgba(154, 96, 255, 0.1));
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

        .role-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }

        .role-card.selected .role-icon {
            background: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            color: white;
        }

        .role-name {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
            color: white;
        }

        .role-desc {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.5;
        }

        /* أزرار التنقل */
        .form-navigation {
            display: flex;
            justify-content: space-between;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .btn-custom {
            padding: 12px 30px;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            min-width: 150px;
        }

        .btn-prev {
            background: rgba(255, 255, 255, 0.05);
            color: rgba(255, 255, 255, 0.8);
        }

        .btn-prev:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .btn-next, .btn-submit {
            background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
            color: white;
        }

        .btn-next:hover, .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(154, 96, 255, 0.3);
        }

        /* رسائل التنبيه */
        .alert-custom {
            border-radius: 12px;
            border: none;
            backdrop-filter: blur(10px);
        }

        .alert-success-custom {
            background: rgba(46, 204, 113, 0.15);
            color: #2ecc71;
            border-left: 4px solid #2ecc71;
        }

        .alert-danger-custom {
            background: rgba(231, 76, 60, 0.15);
            color: #e74c3c;
            border-left: 4px solid #e74c3c;
        }

        /* تأثيرات الحركة */
        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(40px, 40px); }
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-30px) rotate(5deg); }
        }

        @keyframes hologramPulse {
            0% {
                box-shadow:
                        0 0 20px rgba(154, 96, 255, 0.6),
                        inset 0 0 15px rgba(255, 255, 255, 0.2);
            }
            100% {
                box-shadow:
                        0 0 40px rgba(154, 96, 255, 0.8),
                        inset 0 0 20px rgba(255, 255, 255, 0.3);
            }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* تصميم متجاوب */
        @media (max-width: 768px) {
            .register-card {
                padding: 30px 20px;
                max-width: 95%;
            }

            .hologram-logo {
                width: 80px;
                height: 80px;
                font-size: 32px;
            }

            .register-title {
                font-size: 28px;
            }

            .role-options {
                grid-template-columns: 1fr;
            }

            .form-navigation {
                flex-direction: column;
                gap: 15px;
            }

            .btn-custom {
                width: 100%;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 10px;
            }

            .register-card {
                padding: 25px 15px;
            }

            .register-steps::before {
                display: none;
            }

            .step-label {
                font-size: 12px;
            }
        }
    </style>
</head>
<body>
<!-- خلفية التكنولوجيا -->
<div class="tech-background">
    <div class="grid-lines"></div>
    <div class="floating-shapes">
        <div class="shape"></div>
        <div class="shape"></div>
        <div class="shape"></div>
    </div>
</div>

<!-- كرت التسجيل -->
<div class="register-card">
    <!-- رأس التسجيل -->
    <div class="register-header">
        <div class="hologram-logo">
            <i class="fas fa-user-plus"></i>
        </div>
        <h1 class="register-title">إنشاء حساب جديد</h1>
        <p class="register-subtitle">انضم إلى منصة المؤتمرات المتطورة وابدأ رحلتك العلمية</p>
    </div>

    <!-- خطوات التسجيل -->
    <div class="register-steps">
        <div class="step active" id="step1">
            <div class="step-icon">
                <i class="fas fa-user-tag"></i>
            </div>
            <div class="step-label">اختيار الدور</div>
        </div>
        <div class="step" id="step2">
            <div class="step-icon">
                <i class="fas fa-user-edit"></i>
            </div>
            <div class="step-label">المعلومات الأساسية</div>
        </div>
        <div class="step" id="step3">
            <div class="step-icon">
                <i class="fas fa-id-card"></i>
            </div>
            <div class="step-label">المعلومات الإضافية</div>
        </div>
        <div class="step" id="step4">
            <div class="step-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="step-label">تأكيد الحساب</div>
        </div>
    </div>

    <!-- رسائل التنبيه -->
    <div id="alertContainer"></div>

    <!-- حاوية النماذج -->
    <div class="form-container">
        <!-- الخطوة 1: اختيار الدور -->
        <div class="form-step active" id="formStep1">
            <h5 class="text-center mb-4" style="color: var(--secondary-color);">اختر دورك في المنصة</h5>

            <div class="role-options">
                <div class="role-card" data-role="participant">
                    <div class="role-icon">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                    <div class="role-name">مشارك</div>
                    <div class="role-desc">
                        اشترك في الأحداث، احضر الجلسات، شارك في النقاشات، واحصل على شهادات حضور
                    </div>
                </div>

                <div class="role-card" data-role="author">
                    <div class="role-icon">
                        <i class="fas fa-microphone"></i>
                    </div>
                    <div class="role-name">متحدث / مؤلف</div>
                    <div class="role-desc">
                        قدم أبحاثك، شارك في المؤتمرات، انشر أوراقك العلمية، وناقش خبراء المجال
                    </div>
                </div>

                <div class="role-card" data-role="reviewer">
                    <div class="role-icon">
                        <i class="fas fa-search"></i>
                    </div>
                    <div class="role-name">عضو لجنة علمية</div>
                    <div class="role-desc">
                        قيّم الأبحاث المقدمة، ساهم في تحكيم الأوراق العلمية، وشارك في تطوير المحتوى
                    </div>
                </div>

                <div class="role-card" data-role="organizer">
                    <div class="role-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="role-name">منظم</div>
                    <div class="role-desc">
                        أنشئ أحداثاً علمية، أدِر المشاركين، نظم البرامج، وشارك في تطوير المجتمع العلمي
                    </div>
                </div>
            </div>

            <div class="form-navigation">
                <div></div> <!-- Placeholder for spacing -->
                <button type="button" class="btn btn-custom btn-next" id="nextToStep2">
                    التالي <i class="fas fa-arrow-left"></i>
                </button>
            </div>
        </div>

        <!-- الخطوة 2: المعلومات الأساسية -->
        <div class="form-step" id="formStep2">
            <h5 class="text-center mb-4" style="color: var(--secondary-color);">المعلومات الأساسية</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label for="fullName" class="form-label">الاسم الكامل</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input type="text" class="form-control" id="fullName" placeholder="أدخل اسمك الكامل" required>
                    </div>
                    <div class="invalid-feedback">يرجى إدخال الاسم الكامل</div>
                </div>

                <div class="col-md-6">
                    <label for="email" class="form-label">البريد الإلكتروني</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input type="email" class="form-control" id="email" placeholder="example@domain.com" required>
                    </div>
                    <div class="invalid-feedback">يرجى إدخال بريد إلكتروني صحيح</div>
                </div>

                <div class="col-md-6">
                    <label for="password" class="form-label">كلمة المرور</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input type="password" class="form-control" id="password" placeholder="••••••••" required>
                        <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="form-text">كلمة المرور يجب أن تكون 8 أحرف على الأقل</div>
                </div>

                <div class="col-md-6">
                    <label for="confirmPassword" class="form-label">تأكيد كلمة المرور</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                        <input type="password" class="form-control" id="confirmPassword" placeholder="••••••••" required>
                    </div>
                    <div class="invalid-feedback" id="passwordMatchError">كلمات المرور غير متطابقة</div>
                </div>

                <div class="col-md-6">
                    <label for="phone" class="form-label">رقم الهاتف</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                        <input type="tel" class="form-control" id="phone" placeholder="05xxxxxxxx" required>
                    </div>
                </div>

                <div class="col-md-6">
                    <label for="institution" class="form-label">المؤسسة / الجامعة</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-university"></i></span>
                        <input type="text" class="form-control" id="institution" placeholder="اسم المؤسسة" required>
                    </div>
                </div>
            </div>

            <div class="form-navigation">
                <button type="button" class="btn btn-custom btn-prev" id="prevToStep1">
                    <i class="fas fa-arrow-right"></i> السابق
                </button>
                <button type="button" class="btn btn-custom btn-next" id="nextToStep3">
                    التالي <i class="fas fa-arrow-left"></i>
                </button>
            </div>
        </div>

        <!-- الخطوة 3: المعلومات الإضافية -->
        <div class="form-step" id="formStep3">
            <h5 class="text-center mb-4" style="color: var(--secondary-color);">المعلومات الإضافية</h5>

            <!-- معلومات المتحدث -->
            <div id="authorFields" style="display: none;">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label for="researchField" class="form-label">مجال البحث</label>
                        <select class="form-select" id="researchField">
                            <option value="">اختر مجال البحث</option>
                            <option value="ai">الذكاء الاصطناعي في الطب</option>
                            <option value="bioinformatics">المعلوماتية الحيوية</option>
                            <option value="genetics">علم الوراثة</option>
                            <option value="pharmacology">علم الأدوية</option>
                            <option value="public_health">الصحة العامة</option>
                            <option value="other">مجال آخر</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="orcid" class="form-label">معرف ORCID (اختياري)</label>
                        <input type="text" class="form-control" id="orcid" placeholder="0000-0000-0000-0000">
                    </div>

                    <div class="col-12">
                        <label for="bio" class="form-label">السيرة الذاتية المختصرة</label>
                        <textarea class="form-control" id="bio" rows="3" placeholder="اكتب نبذة مختصرة عن خبراتك وأبحاثك..."></textarea>
                    </div>
                </div>
            </div>

            <!-- معلومات المنظم -->
            <div id="organizerFields" style="display: none;">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label for="organizationName" class="form-label">اسم المؤسسة المنظمة</label>
                        <input type="text" class="form-control" id="organizationName" placeholder="اسم المؤسسة المنظمة للأحداث">
                    </div>

                    <div class="col-md-6">
                        <label for="organizationType" class="form-label">نوع المؤسسة</label>
                        <select class="form-select" id="organizationType">
                            <option value="">اختر نوع المؤسسة</option>
                            <option value="university">جامعة</option>
                            <option value="hospital">مستشفى</option>
                            <option value="research_center">مركز بحثي</option>
                            <option value="association">جمعية علمية</option>
                            <option value="company">شركة</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- معلومات عضو اللجنة العلمية -->
            <div id="reviewerFields" style="display: none;">
                <div class="row g-3 mb-4">
                    <div class="col-12">
                        <label for="specialization" class="form-label">التخصص الدقيق</label>
                        <input type="text" class="form-control" id="specialization" placeholder="أدخل تخصصك الدقيق">
                    </div>

                    <div class="col-md-6">
                        <label for="yearsOfExperience" class="form-label">سنوات الخبرة</label>
                        <select class="form-select" id="yearsOfExperience">
                            <option value="1-3">1-3 سنوات</option>
                            <option value="3-5">3-5 سنوات</option>
                            <option value="5-10">5-10 سنوات</option>
                            <option value="10+">أكثر من 10 سنوات</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="reviewInterests" class="form-label">مجالات الاهتمام</label>
                        <select class="form-select" id="reviewInterests" multiple>
                            <option value="ai">الذكاء الاصطناعي</option>
                            <option value="ml">تعلم الآلة</option>
                            <option value="data_science">علم البيانات</option>
                            <option value="biotech">التكنولوجيا الحيوية</option>
                            <option value="clinical">الأبحاث السريرية</option>
                        </select>
                        <div class="form-text">اضغط Ctrl لتحديد أكثر من مجال</div>
                    </div>
                </div>
            </div>

            <!-- معلومات المشارك -->
            <div id="participantFields" style="display: none;">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label for="qualification" class="form-label">المؤهل العلمي</label>
                        <select class="form-select" id="qualification">
                            <option value="">اختر المؤهل العلمي</option>
                            <option value="student">طالب</option>
                            <option value="bachelor">بكالوريوس</option>
                            <option value="master">ماجستير</option>
                            <option value="phd">دكتوراه</option>
                            <option value="professor">أستاذ</option>
                            <option value="professional">محترف</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label for="interests" class="form-label">مجالات الاهتمام</label>
                        <input type="text" class="form-control" id="interests" placeholder="أدخل مجالات اهتمامك">
                    </div>
                </div>
            </div>

            <!-- صورة الملف الشخصي -->
            <div class="mb-4">
                <label for="profilePicture" class="form-label">صورة الملف الشخصي (اختياري)</label>
                <div class="d-flex align-items-center gap-3">
                    <div class="position-relative">
                        <img src="" alt="صورة الملف الشخصي" id="profilePreview"
                             class="rounded-circle border border-2"
                             style="width: 100px; height: 100px; object-fit: cover; display: none;">
                        <div id="defaultAvatar" class="rounded-circle border border-2 d-flex align-items-center justify-content-center"
                             style="width: 100px; height: 100px; background: rgba(255,255,255,0.1);">
                            <i class="fas fa-user fa-2x text-muted"></i>
                        </div>
                    </div>
                    <div>
                        <input type="file" class="form-control" id="profilePicture" accept="image/*" style="display: none;">
                        <button type="button" class="btn btn-outline-primary" id="uploadPictureBtn">
                            <i class="fas fa-upload"></i> رفع صورة
                        </button>
                        <div class="form-text">الحجم الأقصى: 2MB. الصيغ المقبولة: JPG, PNG</div>
                    </div>
                </div>
            </div>

            <!-- شروط الاستخدام -->
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="termsAgreement" required>
                <label class="form-check-label" for="termsAgreement">
                    أوافق على <a href="#" class="text-decoration-none" style="color: var(--secondary-color);">شروط الاستخدام</a>
                    و <a href="#" class="text-decoration-none" style="color: var(--secondary-color);">سياسة الخصوصية</a>
                </label>
                <div class="invalid-feedback">يجب الموافقة على الشروط والأحكام</div>
            </div>

            <div class="form-navigation">
                <button type="button" class="btn btn-custom btn-prev" id="prevToStep2">
                    <i class="fas fa-arrow-right"></i> السابق
                </button>
                <button type="button" class="btn btn-custom btn-next" id="nextToStep4">
                    التالي <i class="fas fa-arrow-left"></i>
                </button>
            </div>
        </div>

        <!-- الخطوة 4: تأكيد الحساب -->
        <div class="form-step" id="formStep4">
            <h5 class="text-center mb-4" style="color: var(--secondary-color);">تأكيد المعلومات</h5>

            <div class="card mb-4" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                <div class="card-body">
                    <h6 class="card-title mb-3" style="color: var(--secondary-color);">معلومات الحساب</h6>
                    <div id="confirmationDetails">
                        <!-- سيتم ملؤها ديناميكياً -->
                    </div>
                </div>
            </div>

            <div class="alert alert-info alert-custom">
                <i class="fas fa-info-circle me-2"></i>
                سيتم إرسال رابط تفعيل إلى بريدك الإلكتروني. يرجى التحقق من صندوق الوارد أو الرسائل غير المرغوب فيها.
            </div>

            <div class="form-navigation">
                <button type="button" class="btn btn-custom btn-prev" id="prevToStep3">
                    <i class="fas fa-arrow-right"></i> السابق
                </button>
                <button type="button" class="btn btn-custom btn-submit" id="submitRegistration">
                    <i class="fas fa-check"></i> إنشاء الحساب
                </button>
            </div>
        </div>
    </div>

    <!-- رابط تسجيل الدخول -->
    <div class="text-center mt-4 pt-3 border-top border-secondary">
        <p class="mb-0">لديك حساب بالفعل؟
            <a href="login.html" class="text-decoration-none fw-bold" style="color: var(--secondary-color);">سجل الدخول من هنا</a>
        </p>
    </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // المتغيرات العامة
        let currentStep = 1;
        let selectedRole = '';
        const formData = {
            role: '',
            basicInfo: {},
            additionalInfo: {}
        };

        // عناصر DOM
        const steps = document.querySelectorAll('.step');
        const formSteps = document.querySelectorAll('.form-step');
        const roleCards = document.querySelectorAll('.role-card');
        const alertContainer = document.getElementById('alertContainer');

        // تغيير الخطوة
        function goToStep(step) {
            // تحديث الخطوات
            steps.forEach(s => {
                s.classList.remove('active');
                if (parseInt(s.id.replace('step', '')) < step) {
                    s.classList.add('completed');
                } else {
                    s.classList.remove('completed');
                }
            });
            document.getElementById(`step${step}`).classList.add('active');

            // تحديث النماذج
            formSteps.forEach(form => form.classList.remove('active'));
            document.getElementById(`formStep${step}`).classList.add('active');

            currentStep = step;
        }

        // اختيار الدور
        roleCards.forEach(card => {
            card.addEventListener('click', function() {
                roleCards.forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
                selectedRole = this.dataset.role;
                formData.role = selectedRole;

                // إظهار/إخفاء الحقول الإضافية حسب الدور
                const roleFields = {
                    'author': 'authorFields',
                    'organizer': 'organizerFields',
                    'reviewer': 'reviewerFields',
                    'participant': 'participantFields'
                };

                // إخفاء جميع الحقول أولاً
                document.getElementById('authorFields').style.display = 'none';
                document.getElementById('organizerFields').style.display = 'none';
                document.getElementById('reviewerFields').style.display = 'none';
                document.getElementById('participantFields').style.display = 'none';

                // إظهار الحقول المناسبة للدور
                if (selectedRole in roleFields) {
                    document.getElementById(roleFields[selectedRole]).style.display = 'block';
                }
            });
        });

        // التالي إلى الخطوة 2
        document.getElementById('nextToStep2').addEventListener('click', function() {
            if (!selectedRole) {
                showAlert('يرجى اختيار دورك في المنصة', 'danger');
                return;
            }
            goToStep(2);
        });

        // التالي إلى الخطوة 3
        document.getElementById('nextToStep3').addEventListener('click', function() {
            // التحقق من صحة البيانات الأساسية
            const fullName = document.getElementById('fullName').value.trim();
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const phone = document.getElementById('phone').value.trim();
            const institution = document.getElementById('institution').value.trim();

            // التحقق من الاسم
            if (!fullName) {
                showAlert('يرجى إدخال الاسم الكامل', 'danger');
                document.getElementById('fullName').focus();
                return;
            }

            // التحقق من البريد الإلكتروني
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                showAlert('يرجى إدخال بريد إلكتروني صحيح', 'danger');
                document.getElementById('email').focus();
                return;
            }

            // التحقق من كلمة المرور
            if (password.length < 8) {
                showAlert('كلمة المرور يجب أن تكون 8 أحرف على الأقل', 'danger');
                document.getElementById('password').focus();
                return;
            }

            // التحقق من تطابق كلمات المرور
            if (password !== confirmPassword) {
                showAlert('كلمات المرور غير متطابقة', 'danger');
                document.getElementById('confirmPassword').focus();
                return;
            }

            // حفظ البيانات
            formData.basicInfo = {
                fullName,
                email,
                password,
                phone,
                institution
            };

            goToStep(3);
        });

        // التالي إلى الخطوة 4
        document.getElementById('nextToStep4').addEventListener('click', function() {
            // التحقق من شروط الاستخدام
            if (!document.getElementById('termsAgreement').checked) {
                showAlert('يجب الموافقة على شروط الاستخدام وسياسة الخصوصية', 'danger');
                return;
            }

            // جمع البيانات الإضافية حسب الدور
            formData.additionalInfo = {};

            if (selectedRole === 'author') {
                formData.additionalInfo = {
                    researchField: document.getElementById('researchField').value,
                    orcid: document.getElementById('orcid').value,
                    bio: document.getElementById('bio').value
                };
            } else if (selectedRole === 'organizer') {
                formData.additionalInfo = {
                    organizationName: document.getElementById('organizationName').value,
                    organizationType: document.getElementById('organizationType').value
                };
            } else if (selectedRole === 'reviewer') {
                formData.additionalInfo = {
                    specialization: document.getElementById('specialization').value,
                    yearsOfExperience: document.getElementById('yearsOfExperience').value,
                    reviewInterests: Array.from(document.getElementById('reviewInterests').selectedOptions)
                        .map(option => option.value)
                };
            } else if (selectedRole === 'participant') {
                formData.additionalInfo = {
                    qualification: document.getElementById('qualification').value,
                    interests: document.getElementById('interests').value
                };
            }

            // عرض بيانات التأكيد
            displayConfirmationDetails();
            goToStep(4);
        });

        // عرض بيانات التأكيد
        function displayConfirmationDetails() {
            const detailsContainer = document.getElementById('confirmationDetails');
            let html = `
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>الدور:</strong> ${getRoleName(selectedRole)}</p>
                        <p><strong>الاسم:</strong> ${formData.basicInfo.fullName}</p>
                        <p><strong>البريد الإلكتروني:</strong> ${formData.basicInfo.email}</p>
                        <p><strong>الهاتف:</strong> ${formData.basicInfo.phone}</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>المؤسسة:</strong> ${formData.basicInfo.institution}</p>
            `;

            // إضافة المعلومات الإضافية حسب الدور
            if (selectedRole === 'author' && formData.additionalInfo.researchField) {
                html += `<p><strong>مجال البحث:</strong> ${formData.additionalInfo.researchField}</p>`;
            }
            if (selectedRole === 'organizer' && formData.additionalInfo.organizationName) {
                html += `<p><strong>المؤسسة المنظمة:</strong> ${formData.additionalInfo.organizationName}</p>`;
            }
            if (selectedRole === 'reviewer' && formData.additionalInfo.specialization) {
                html += `<p><strong>التخصص:</strong> ${formData.additionalInfo.specialization}</p>`;
            }

            html += `</div></div>`;
            detailsContainer.innerHTML = html;
        }

        // الحصول على اسم الدور بالعربية
        function getRoleName(role) {
            const roles = {
                'participant': 'مشارك',
                'author': 'متحدث / مؤلف',
                'reviewer': 'عضو لجنة علمية',
                'organizer': 'منظم'
            };
            return roles[role] || role;
        }

        // الرجوع للخطوة السابقة
        document.getElementById('prevToStep1').addEventListener('click', () => goToStep(1));
        document.getElementById('prevToStep2').addEventListener('click', () => goToStep(2));
        document.getElementById('prevToStep3').addEventListener('click', () => goToStep(3));

        // إرسال التسجيل
        document.getElementById('submitRegistration').addEventListener('click', function() {
            const submitBtn = this;
            const originalText = submitBtn.innerHTML;

            // عرض حالة التحميل
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري إنشاء الحساب...';
            submitBtn.disabled = true;

            // محاكاة إرسال البيانات للخادم
            setTimeout(() => {
                // في حالة النجاح
                showAlert('تم إنشاء الحساب بنجاح! تم إرسال رابط التفعيل إلى بريدك الإلكتروني.', 'success');

                // إعادة تعيين الزر
                submitBtn.innerHTML = '<i class="fas fa-check"></i> تم إنشاء الحساب';

                // إعادة التوجيه بعد 3 ثواني
                setTimeout(() => {
                    window.location.href = "login.html";
                }, 3000);
            }, 2000);
        });

        // إظهار/إخفاء كلمة المرور
        document.getElementById('togglePassword').addEventListener('click', function() {
            const passwordField = document.getElementById('password');
            const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordField.setAttribute('type', type);

            const icon = this.querySelector('i');
            icon.className = type === 'password' ? 'fas fa-eye' : 'fas fa-eye-slash';
        });

        // رفع صورة الملف الشخصي
        document.getElementById('uploadPictureBtn').addEventListener('click', function() {
            document.getElementById('profilePicture').click();
        });

        document.getElementById('profilePicture').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                // التحقق من حجم الملف (2MB كحد أقصى)
                if (file.size > 2 * 1024 * 1024) {
                    showAlert('حجم الصورة يجب أن يكون أقل من 2MB', 'danger');
                    return;
                }

                // التحقق من نوع الملف
                const validTypes = ['image/jpeg', 'image/png', 'image/gif'];
                if (!validTypes.includes(file.type)) {
                    showAlert('صيغة الصورة غير مدعومة. يرجى استخدام JPG, PNG أو GIF', 'danger');
                    return;
                }

                // عرض المعاينة
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('profilePreview').src = e.target.result;
                    document.getElementById('profilePreview').style.display = 'block';
                    document.getElementById('defaultAvatar').style.display = 'none';
                };
                reader.readAsDataURL(file);
            }
        });

        // عرض رسائل التنبيه
        function showAlert(message, type) {
            const alertClass = type === 'success' ? 'alert-success-custom' : 'alert-danger-custom';
            const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';

            const alertHTML = `
                <div class="alert ${alertClass} alert-dismissible fade show" role="alert">
                    <i class="fas ${icon} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;

            alertContainer.innerHTML = alertHTML;

            // إخفاء الرسالة تلقائياً بعد 5 ثواني
            setTimeout(() => {
                const alert = document.querySelector('.alert');
                if (alert) {
                    alert.classList.remove('show');
                    setTimeout(() => alert.remove(), 300);
                }
            }, 5000);
        }

        // التحقق من تطابق كلمات المرور أثناء الكتابة
        document.getElementById('confirmPassword').addEventListener('input', function() {
            const password = document.getElementById('password').value;
            const confirmPassword = this.value;

            if (confirmPassword && password !== confirmPassword) {
                this.classList.add('is-invalid');
                document.getElementById('passwordMatchError').style.display = 'block';
            } else {
                this.classList.remove('is-invalid');
                document.getElementById('passwordMatchError').style.display = 'none';
            }
        });
    });
</script>
</body>
</html>