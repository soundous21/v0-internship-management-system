{% extends 'base.html.twig' %}

{% block title %}Reset Password{% endblock %}

{% block body %}
    <div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">
        <div class="glass-card p-5 col-md-4">
            <h2 class="text-center animated-title mb-4">Reset Password</h2>
            <form method="post">
                <div class="mb-3">
                    <label>
                        <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
                    </label>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-glow" type="submit">Send Reset Link</button>
                </div>
                <div class="mt-3 text-center">
                    <a href="{{ path('login') }}" class="text-info">Back to Login</a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
