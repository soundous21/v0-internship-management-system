{% extends 'base.html.twig' %}

{% block title %}Reset Password - Medical Conference{% endblock %}

{% block body %}
    <style>
        /* تنسيق الحاوية المركزية */
        .reset-container {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .reset-card {
            background: rgba(0, 0, 0, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 25px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
        }

        .reset-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(45deg, #6a11cb, #2575fc);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 0 20px rgba(37, 117, 252, 0.5);
        }

        .form-control-dark {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: white !important;
            border-radius: 12px;
            padding: 12px 20px;
        }

        .form-control-dark:focus {
            border-color: #2575fc !important;
            box-shadow: 0 0 10px rgba(37, 117, 252, 0.3);
        }
    </style>

    <div class="reset-container">
        <div class="reset-card text-center">
            <div class="reset-icon">
                <i class="bi bi-shield-lock text-white fs-1"></i>
            </div>

            <h2 class="text-white fw-bold mb-3">Forgot Password?</h2>
            <p class="text-white-50 mb-4 small">Enter your medical ID email and we'll send you instructions to reset your password.</p>

            <form>
                <div class="mb-4 text-start">
                    <label class="text-white-50 small mb-2 ms-2">Email Address</label>
                    <input type="email" class="form-control form-control-dark" placeholder="dr.name@example.com" required>
                </div>

                <button type="submit" class="btn btn-glow w-100 py-3 mb-3">
                    Send Reset Link
                </button>

                <div class="mt-3">
                    <a href="{{ path('app_login') }}" class="text-info text-decoration-none small">
                        <i class="bi bi-arrow-left me-1"></i> Back to Login
                    </a>
                </div>
            </form>
        </div>
    </div>
{% endblock %}