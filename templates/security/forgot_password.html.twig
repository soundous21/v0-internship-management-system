{% extends 'base.html.twig' %}

{% block title %}Stage.io - Reset Password{% endblock %}

{% block body %}
    <style>
        .navbar {
            display: none !important; /* هذا السطر سيقوم بإخفاء الشريط العلوي بالكامل */
            background-color: rgba(3, 7, 18, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
        }
        /* التنسيقات المتوافقة مع هوية الموقع البصرية */
        .auth-container {
            min-height: 80vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .auth-card {
            background-color: #09090b; /* نفس لون البطاقات في الصفحة الرئيسية */
            border: 1px solid #1f2937;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 0 40px rgba(0,0,0,0.5);
        }

        .icon-box-reset {
            width: 60px;
            height: 60px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #3b82f6;
            margin-bottom: 24px;
        }

        .v0-input {
            background: black !important;
            border: 1px solid #374151 !important;
            color: white !important;
            border-radius: 8px;
            padding: 12px;
        }

        .v0-input:focus {
            border-color: #3b82f6 !important;
            box-shadow: none !important;
        }

        .btn-v0-white {
            background: white;
            color: black;
            font-weight: 700;
            border-radius: 8px;
            padding: 12px;
            width: 100%;
            border: none;
            transition: 0.3s;
        }

        .btn-v0-white:hover {
            background: #e2e8f0;
        }

        .back-link {
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.3s;
        }

        .back-link:hover {
            color: white;
        }
    </style>

    <div class="container auth-container">
        <div class="auth-card">

            <div class="icon-box-reset mx-auto">
                <i class="bi bi-shield-lock-fill fs-2"></i>
            </div>

            <div class="text-center mb-4">
                <h3 class="fw-bold text-white">Forgot Password?</h3>
                <p class="text-secondary small">
                    Enter the email address associated with your account and we'll send you a link to reset your password.
                </p>
            </div>

            <form action="#" method="POST">
                <div class="mb-4 text-start">
                    <label class="small text-secondary fw-bold mb-1">EMAIL ADDRESS</label>
                    <input type="email" class="form-control v0-input" placeholder="name@university.edu" required>
                </div>

                <button type="submit" class="btn-v0-white mb-3">Send Reset Link</button>
            </form>

            <div class="text-center mt-3">
                <a href="{{ path('app_home') }}?openLogin=true" class="back-link">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </div>
        </div>
    </div>
{% endblock %}