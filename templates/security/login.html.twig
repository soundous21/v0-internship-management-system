{% extends 'base.html.twig' %}

{% block body %}
    <div id="splash-screen" class="text-center position-absolute w-100" style="transition: opacity 0.8s ease-out; z-index: 10;">
        <h1 class="animated-title px-3">SCIENTIFIC EVENT</h1>
        <p class="text-white opacity-75 fs-5">Health Management Platform</p>
    </div>

    <div id="login-container" class="container" style="display: none; opacity: 0; transition: opacity 1s ease-in;">
        <div class="row justify-content-center">
            <div class="col-11 col-sm-9 col-md-7 col-lg-5">
                <div class="card glass-card shadow-lg p-4 border-0">

                    <div class="text-center mb-4">
                        <div class="robot-glow-container mx-auto mb-3">
                            <i class="bi bi-robot text-white display-4"></i>
                            <i class="bi bi-heart-pulse-fill position-absolute text-info fs-5" style="bottom: 15px; right: 15px;"></i>
                        </div>
                        <h2 class="text-white fw-bold h4">ADVANCED CONFERENCE SYSTEM</h2>
                        <p class="small" style="color: var(--soft-blue)">Enter your credentials to access the platform</p>
                    </div>

                    <form method="post">
                        {% if error %}
                            <div class="alert alert-danger py-2 small text-center border-0 bg-danger bg-opacity-25 text-white">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <div class="form-floating mb-3">
                            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control bg-transparent border-0 border-bottom rounded-0 shadow-none" placeholder="Email" required autofocus>
                            <label class="text-white opacity-75">Email Address</label>
                        </div>

                        <div class="form-floating mb-3">
                            <input type="password" name="_password" id="password" class="form-control bg-transparent border-0 border-bottom rounded-0 shadow-none" placeholder="Password" required>
                            <label class="text-white opacity-75">Password</label>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                            <div class="form-check">
                                <input class="form-check-input bg-transparent border-info" type="checkbox" name="_remember_me" id="remember_me">
                                <label class="form-check-label text-white small" for="remember_me">Remember me</label>
                            </div>

                            {# تم تعديل الرابط هنا #}
                            <a href="{{ path('app_forgot_password') }}" class="text-decoration-none small" style="color: var(--soft-blue)">Forgot password?</a>
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button class="btn btn-glow w-100 py-3 fw-bold" type="submit">
                            SIGN IN
                        </button>

                        <div class="text-center mt-4 pt-3 border-top border-white border-opacity-10">
                            <p class="text-white small mb-0">Don't have an account?
                                <a href="/register" class="fw-bold text-decoration-none" style="color: var(--soft-blue)">Create New Account</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script>
        setTimeout(() => {
            const splash = document.getElementById('splash-screen');
            const login = document.getElementById('login-container');
            splash.style.opacity = '0';
            setTimeout(() => {
                splash.style.display = 'none';
                login.style.display = 'block';
                setTimeout(() => login.style.opacity = '1', 50);
            }, 800);
        }, 2500);
    </script>
{% endblock %}