                        <label class="form-check-label small text-secondary ms-1" for="remCheck">Remember me</label>
                    </div>
                    <button type="submit" class="btn-v0-white">Sign In</button>
                </form> #}

            <form action="{{ path('app_login') }}" method="post">
                {# 1. توكن الحماية #}
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# 2. عرض رسائل الخطأ إن وجدت #}
                {% if error|default(null) %}
                    <div class="alert alert-danger p-2 small" style="background: rgba(220, 38, 38, 0.1); border-color: #dc2626; color: #f87171;">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">EMAIL ADDRESS</label>
                    {# أضفنا name="_username" و القيمة الأخيرة المدخلة #}
                    <input type="email" name="_username" value="{{ last_username|default('') }}" class="form-control v0-input" placeholder="name@university.edu" required autofocus>
                </div>

                <div class="mb-3 text-start">
                    <div class="d-flex justify-content-between">
                        <label class="small text-secondary fw-bold mb-1">PASSWORD</label>
                       {#  <a href="{{ path('app_forgot_password') }}" class="text-primary small text-decoration-none" style="font-size: 11px;">
                            Forgot password?
                        </a>#}
                        <a href="{{ path('app_forgot_password_request') }}" class="text-primary small text-decoration-none" style="font-size: 11px;">
                            Forgot password?
                        </a>
                    </div>
                    <div class="position-relative">
                        {# أضفنا name="_password" #}
                        <input type="password" name="_password" class="form-control v0-input w-100" placeholder="••••••••" required>
                        <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 eye-icon"></i>
                    </div>
                </div>

                <div class="mb-4 form-check text-start">
                    {# أضفنا name="_remember_me" #}
                    <input type="checkbox" name="_remember_me" class="form-check-input bg-black border-secondary" id="remCheck">
                    <label class="form-check-label small text-secondary ms-1" for="remCheck">Remember me</label>
                </div>

                <button type="submit" class="btn-v0-white">Sign In</button>
            </form>
            <p class="text-center small text-secondary mt-4">New here? <a href="#" class="text-white fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#signUpModal" data-bs-dismiss="modal">Create account</a></p>
        </div>
    </div>
</div>

{# --- MODAL: SIGN UP --- #}
<div class="modal fade modal-v0" id="signUpModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
        <div class="modal-content p-4">
            <div class="text-end"><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="text-center mb-4">
                <div class="icon-box mx-auto mb-2"><i class="bi bi-person-plus-fill fs-4"></i></div>
                <h3 class="fw-bold text-white">Create Account</h3>
                <p class="text-secondary small">Choose your account type to get started</p>
            </div>

            {# --- Role Selector Buttons --- #}
            <div class="d-flex gap-2 mb-4" id="roleSelector">
                <button type="button" class="role-btn flex-fill active" data-role="student" onclick="switchRole('student')">
                    <i class="bi bi-mortarboard-fill d-block fs-4 mb-1"></i>
                    <span class="fw-bold">Student</span>
                </button>
                <button type="button" class="role-btn flex-fill" data-role="company" onclick="switchRole('company')">
                    <i class="bi bi-building d-block fs-4 mb-1"></i>
                    <span class="fw-bold">Company</span>
                </button>

            </div>

            {# --- STUDENT FORM --- #}
            <form id="form-student" class="role-form" action="{{ path('app_register') }}" method="post">
                <input type="hidden" name="role" value="ROLE_STUDENT">
                <div class="role-badge mb-3 text-center">
                        <span class="badge px-3 py-2" style="background:rgba(59,130,246,0.15);color:#60a5fa;border:1px solid #3b82f6;border-radius:20px;">
                            <i class="bi bi-mortarboard-fill me-1"></i> Registering as Student
                        </span>
                </div>
                <div class="row g-2 mb-3 text-start">
                    <div class="col-6">
                        <label class="small text-secondary fw-bold mb-1">FIRST NAME</label>
                        <input type="text" name="firstName" class="form-control v0-input" placeholder="Amine" required>
                    </div>
                    <div class="col-6">
                        <label class="small text-secondary fw-bold mb-1">LAST NAME</label>
                        <input type="text" name="lastName" class="form-control v0-input" placeholder="Benali" required>
                    </div>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">UNIVERSITY EMAIL</label>
                    <input type="email" name="email" class="form-control v0-input" placeholder="amine@univ-constantine.dz" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">STUDENT ID</label>
                    <input type="text" name="studentId" class="form-control v0-input" placeholder="20231234">
                </div>
                <div class="mb-4 text-start">
                    <label class="small text-secondary fw-bold mb-1">PASSWORD</label>
                    <div class="position-relative">
                        <input type="password" name="password" class="form-control v0-input w-100" placeholder="••••••••" required>
                        <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 eye-icon"></i>
                    </div>
                </div>
                <button type="submit" class="btn-v0-white" style="background:#3b82f6;color:white;">
                    <i class="bi bi-mortarboard-fill me-2"></i>Create Student Account
                </button>
            </form>

            {# --- COMPANY FORM --- #}
            <form id="form-company" class="role-form d-none" action="{{ path('app_register') }}" method="post">
                <input type="hidden" name="role" value="ROLE_COMPANY">
                <div class="role-badge mb-3 text-center">
                        <span class="badge px-3 py-2" style="background:rgba(16,185,129,0.15);color:#34d399;border:1px solid #10b981;border-radius:20px;">
                            <i class="bi bi-building me-1"></i> Registering as Company
                        </span>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">COMPANY NAME</label>
                    <input type="text" name="companyName" class="form-control v0-input" placeholder="Tech Solutions SPA" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">PROFESSIONAL EMAIL</label>
                    <input type="email" name="email" class="form-control v0-input" placeholder="contact@company.dz" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">WILAYA</label>
                    <input type="text" name="wilaya" class="form-control v0-input" placeholder="Constantine">
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">SECTOR / DOMAIN</label>
                    <input type="text" name="sector" class="form-control v0-input" placeholder="Web Development, AI...">
                </div>
                <div class="mb-4 text-start">
                    <label class="small text-secondary fw-bold mb-1">PASSWORD</label>
                    <div class="position-relative">
                        <input type="password" name="password" class="form-control v0-input w-100" placeholder="••••••••" required>
                        <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 eye-icon"></i>
                    </div>
                </div>
                <button type="submit" class="btn-v0-white" style="background:#10b981;color:white;">
                    <i class="bi bi-building me-2"></i>Create Company Account
                </button>
            </form>

            {# --- ADMIN FORM --- #}
            <form id="form-admin" class="role-form d-none" action="{{ path('app_register') }}" method="post">
                <input type="hidden" name="role" value="ROLE_ADMIN">
                <div class="role-badge mb-3 text-center">
                        <span class="badge px-3 py-2" style="background:rgba(245,158,11,0.15);color:#fbbf24;border:1px solid #f59e0b;border-radius:20px;">
                            <i class="bi bi-shield-lock-fill me-1"></i> Registering as Administrator
                        </span>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">FULL NAME</label>
                    <input type="text" name="fullName" class="form-control v0-input" placeholder="Dr. Mohamed Larbi" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">INSTITUTIONAL EMAIL</label>
                    <input type="email" name="email" class="form-control v0-input" placeholder="admin@univ-constantine.dz" required>
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">DEPARTMENT</label>
                    <input type="text" name="department" class="form-control v0-input" placeholder="Computer Science Dept.">
                </div>
                <div class="mb-3 text-start">
                    <label class="small text-secondary fw-bold mb-1">ACCESS CODE</label>
                    <input type="text" name="accessCode" class="form-control v0-input" placeholder="Admin access code">
                </div>
                <div class="mb-4 text-start">
                    <label class="small text-secondary fw-bold mb-1">PASSWORD</label>
                    <div class="position-relative">
                        <input type="password" name="password" class="form-control v0-input w-100" placeholder="••••••••" required>
                        <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 eye-icon"></i>
                    </div>
                </div>
                <button type="submit" class="btn-v0-white" style="background:#f59e0b;color:black;">
                    <i class="bi bi-shield-lock-fill me-2"></i>Create Admin Account
                </button>
            </form>

            <p class="text-center small text-secondary mt-4">Already have an account? <a href="#" class="text-white fw-bold text-decoration-none" data-bs-toggle="modal" data-bs-target="#signInModal" data-bs-dismiss="modal">Sign in</a></p>
        </div>
    </div>
</div>
    <script>
        // وظيفة إظهار وإخفاء كلمة المرور
        document.querySelectorAll('.eye-icon').forEach(icon => {
            icon.addEventListener('click', function() {
                const input = this.parentElement.querySelector('input');
                if (input.type === 'password') {
                    input.type = 'text';
                    this.classList.replace('bi-eye', 'bi-eye-slash');
                } else {
                    input.type = 'password';
                    this.classList.replace('bi-eye-slash', 'bi-eye');
                }
            });
        });

        // فتح نافذة تسجيل الدخول إذا كان الرابط يحتوي على openLogin
        window.onload = function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('openLogin')) {
                var myModal = new bootstrap.Modal(document.getElementById('signInModal'));
                myModal.show();
            }
        }

        // فتح نافذة تسجيل الدخول تلقائياً إذا أرسل الـ Controller متغيرة الخطأ
        {% if error|default(null) or open_login_modal|default(false) %}
        var loginModal = new bootstrap.Modal(document.getElementById('signInModal'));
        loginModal.show();
        {% endif %}

        // التبديل بين نماذج التسجيل (طالب، شركة، مسؤول)
        function switchRole(role) {
            document.querySelectorAll('.role-btn').forEach(btn => {
                btn.classList.toggle('active', btn.dataset.role === role);
            });
            document.querySelectorAll('.role-form').forEach(form => {
                form.classList.toggle('d-none', form.id !== 'form-' + role);
            });
        }
    </script>

{% endblock %}