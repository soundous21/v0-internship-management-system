<div class="modal fade modal-v0" id="signInModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content p-4">
            <div class="text-end"><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
            <div class="text-center mb-4">
                <div class="icon-box mx-auto"><i class="bi bi-layers-fill fs-4"></i></div>
                <h3 class="fw-bold text-white">Welcome back</h3>
            </div>
            {#  <form>
                    <div class="mb-3 text-start">
                        <label class="small text-secondary fw-bold mb-1">EMAIL ADDRESS</label>
                        <input type="email" class="form-control v0-input" placeholder="name@university.edu">
                    </div>
                    <div class="mb-3 text-start">
                        <div class="d-flex justify-content-between">
                            <label class="small text-secondary fw-bold mb-1">PASSWORD</label>
                            {#  <a href="#" class="text-primary small text-decoration-none" style="font-size: 11px;">Forgot password?</a>
                        </div>#}


            {#  <a href="{{ path('app_forgot_password') }}" class="text-primary small text-decoration-none" style="font-size: 11px;">
                                Forgot password?
                            </a>
                        </div>
                        <div class="position-relative">
                            <input type="password" class="form-control v0-input w-100" placeholder="••••••••">
                            <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 eye-icon"></i>
                        </div>
                    </div>
                    <div class="mb-4 form-check text-start">
