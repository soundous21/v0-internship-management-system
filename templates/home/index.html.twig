{% extends 'base.html.twig' %}


{% block title %}Stage.io - Connecting Students with Career Opportunities{% endblock %}

{% block body %}
<style>
    body { background-color: #030712; color: white; font-family: 'Inter', sans-serif; overflow-x: hidden; }

    /* Hero Section */
    .hero-section { padding: 120px 0 80px; text-align: center;

    }
    .hero-title { font-size: 4rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; }

    /* Cards Style (v0) */
    .card-custom {
        background-color: #09090b;
        border: 1px solid #1f2937;
        border-radius: 12px;
        transition: 0.3s;
        padding: 24px;
    }
    .card-custom:hover { border-color: #3b82f6; transform: translateY(-5px); }
    .icon-box {
        width: 40px; height: 40px; background: rgba(59, 130, 246, 0.1);
        border-radius: 8px; display: flex; align-items: center; justify-content: center;
        color: #3b82f6; margin-bottom: 20px;
    }

    /* Horizontal Cards Style */
    .user-card-horizontal {
        background: #09090b;
        border: 1px solid #1f2937;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: 0.3s;
    }
    .user-card-horizontal:hover { border-color: #3b82f6; }
    .user-features-inline {
        display: flex;
        gap: 20px;
        list-style: none;
        padding: 0;
        margin-top: 10px;
    }
    .user-features-inline li { font-size: 0.85rem; color: #94a3b8; display: flex; align-items: center; gap: 6px; }
    .user-features-inline li i { color: #10b981; }

    /* Modal Styles */
    .modal-v0 .modal-content {
        background-color: #09090b !important;
        border: 1px solid #1f2937 !important;
        border-radius: 16px !important;
        box-shadow: 0 0 40px rgba(0,0,0,0.5);
    }
    .v0-input {
        background: black !important;
        border: 1px solid #374151 !important;
        color: white !important;
        border-radius: 8px;
        padding: 12px;
    }
    .v0-input:focus { border-color: #3b82f6 !important; box-shadow: none !important; }

    .eye-icon { color: white !important; opacity: 0.8; cursor: pointer; transition: 0.2s; }
    .eye-icon:hover { opacity: 1; }

    .btn-v0-white {
        background: white; color: black; font-weight: 700;
        border-radius: 8px; padding: 12px; width: 100%; border: none; transition: 0.3s;
    }
    .btn-v0-white:hover { background: #e2e8f0; }

    /* --- Footer Styles (Matching Image) --- */
    .footer-custom { padding: 60px 0 30px; margin-top: 80px; border-top: 1px solid #1f2937; }
    .footer-logo-text { color: #ffffff; font-weight: 700; font-size: 1.5rem; display: flex; align-items: center; gap: 10px; }
    .footer-description { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; max-width: 400px; margin-top: 15px; }
    .footer-heading { color: #ffffff; font-weight: 600; font-size: 1rem; margin-bottom: 20px; }
    .footer-links { list-style: none; padding: 0; }
    .footer-links li { margin-bottom: 12px; }
    .footer-links a { color: #94a3b8; text-decoration: none; font-size: 0.9rem; transition: 0.3s; }
    .footer-links a:hover { color: #ffffff; }
    .footer-contact-info { color: #94a3b8; font-size: 0.9rem; line-height: 1.8; }
    .footer-contact-info a { color: #3b82f6; text-decoration: none; }
    .footer-divider { border-top: 1px solid #1f2937; margin: 40px 0 20px; opacity: 0.5; }
    .footer-bottom-text { color: #64748b; font-size: 0.85rem; }

    /* --- Role Selector Buttons --- */
    .role-btn {
        background: #111827;
        border: 1px solid #374151;
        color: #9ca3af;
        border-radius: 10px;
        padding: 14px 10px;
        cursor: pointer;
        transition: all 0.25s;
        text-align: center;
        font-size: 0.85rem;
    }
    .role-btn:hover {
        border-color: #6b7280;
        color: #e5e7eb;
    }
    .role-btn.active[data-role="student"] {
        background: rgba(59,130,246,0.15);
        border-color: #3b82f6;
        color: #60a5fa;
    }
    .role-btn.active[data-role="company"] {
        background: rgba(16,185,129,0.15);
        border-color: #10b981;
        color: #34d399;
    }
    .role-btn.active[data-role="admin"] {
        background: rgba(245,158,11,0.15);
        border-color: #f59e0b;
        color: #fbbf24;
    }














     .hero-title {
         font-size: 3.5rem;
         font-weight: 800;
         line-height: 1.2;
     }

    .custom-img-style {
        /* إضافة تأثير انحناء وتوهج بسيط للحواف */
        transition: transform 0.3s ease;
        box-shadow: 0 0 30px rgba(59, 130, 246, 0.2);
    }

    .custom-img-style:hover {
        transform: translateY(-10px); /* حركة بسيطة عند تمرير الماوس */
    }

    .blur-3xl {
        filter: blur(60px);
        border-radius: 50%;
    }





     .animated-gradient-text {
         /* تدرج لوني بين الأخضر النيوني والأزرق السماوي */
         background: linear-gradient(
                 to right,
                 #00ff87, /* أخضر فاقع نيون */
                 #60efff, /* أزرق فاتح */
                 #0061ff, /* أزرق ملكي */
                 #00ff87  /* العودة للأخضر لضمان سلاسة الدوران */
         );
         background-size: 200% auto;
         -webkit-background-clip: text;
         -webkit-text-fill-color: transparent;
         display: inline-block;
         font-weight: 800;
         /* حركة انسيابية هادئة (5 ثواني) */
         animation: shine 5s linear infinite;
     }

    @keyframes shine {
        to {
            background-position: 200% center;
        }
    }

    /* إضافة توهج خفيف للكلمة لتبدو وكأنها تضيء في الظلام */
    .animated-gradient-text {
        filter: drop-shadow(0 0 8px rgba(0, 255, 135, 0.3));
    }
</style>

