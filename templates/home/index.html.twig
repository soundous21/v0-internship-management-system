    <section class="hero-section py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-5 text-start">
                <span class="badge rounded-pill bg-dark border border-secondary mb-4 px-3 py-2">
                    <span class="text-primary me-1">●</span> University-Enterprise Bridge
                </span>
                    <h1 class="hero-title mb-4">Connecting Students with <br> <span class="animated-gradient-text">Internship Opportunities</span>
                    </h1>
                    <p class="lead text-secondary mb-5">
                        Stage.io streamlines internship management between students and companies.
                    </p>
                    <button class="btn btn-light btn-lg px-5 fw-bold" data-bs-toggle="modal" data-bs-target="#signUpModal">Get Started</button>
                </div>

                <div class="col-lg-7 text-center">
                    <img src="{{ asset('images/hero-bg.jpg.png') }}"
                         alt="Stage.io Digital Transformation"
                         class="img-fluid real-color-img">
                </div>
            </div>
        </div>
    </section>

    {# --- Features Section --- #}
    <div class="row g-4 mb-5 pb-5">
        <h2 class="text-center mb-5 fw-bold">Everything You Need for Internship Management</h2>
        {% set features = [
            {'icon': 'bi-search', 'title': 'Smart Matching', 'desc': 'Find internships based on skills and preferences.'},
            {'icon': 'bi-file-earmark-text', 'title': 'Digital Agreements', 'desc': 'Auto-generate internship conventions pre-filled.'},
            {'icon': 'bi-bar-chart', 'title': 'Analytics Dashboard', 'desc': 'Track placement rates and applications in real-time.'},
            {'icon': 'bi-person-badge', 'title': 'Skill-Based Profiles', 'desc': 'Create detailed profiles with technical tags.'},
            {'icon': 'bi-bell', 'title': 'Real-time Notifications', 'desc': 'Stay updated with instant alerts for new offers.'},
            {'icon': 'bi-shield-lock', 'title': 'Secure & Centralized', 'desc': 'All data is securely stored and accessible.'}
        ] %}
        {% for f in features %}
            <div class="col-md-4">
                <div class="card card-custom h-100">
                    <div class="icon-box"><i class="bi {{ f.icon }} fs-5"></i></div>
                    <h5 class="fw-bold">{{ f.title }}</h5>
                    <p class="text-secondary small mb-0">{{ f.desc }}</p>
                </div>
            </div>
        {% endfor %}
    </div>

    {# --- Horizontal Cards Section --- #}
    <section class="py-5">
        <h2 class="text-center fw-bold mb-5">Built for Everyone</h2>
        {# Student #}
        <div class="user-card-horizontal">
            <div class="user-info">
                <h4 class="fw-bold mb-1">For Students</h4>
                <p class="small text-secondary mb-2">Find your dream internship and start your professional journey.</p>
                <ul class="user-features-inline">
                    <li><i class="bi bi-check2"></i> Digital CV</li>
                    <li><i class="bi bi-check2"></i> Tech Filtering</li>
                    <li><i class="bi bi-check2"></i> Status Tracking</li>
                </ul>
            </div>
            <button class="btn btn-outline-light px-4 py-2 ms-4" data-bs-toggle="modal" data-bs-target="#signUpModal">Join as Student</button>
        </div>
        {# Company #}
        <div class="user-card-horizontal">
            <div class="user-info">
                <h4 class="fw-bold mb-1">For Companies</h4>
                <p class="small text-secondary mb-2">Recruit top university talent and manage applications easily.</p>
                <ul class="user-features-inline">
                    <li><i class="bi bi-check2"></i> Post Offers</li>
                    <li><i class="bi bi-check2"></i> Talent Search</li>
                    <li><i class="bi bi-check2"></i> Auto-Agreements</li>
                </ul>
            </div>
            <button class="btn btn-outline-light px-4 py-2 ms-4" data-bs-toggle="modal" data-bs-target="#signUpModal">Join as Company</button>
        </div>
        {# Admin #}
        <div class="user-card-horizontal">
            <div class="user-info">
                <h4 class="fw-bold mb-1">For Administrators</h4>
                <p class="small text-secondary mb-2">Control and validate the internship lifecycle from one dashboard.</p>
                <ul class="user-features-inline">
                    <li><i class="bi bi-check2"></i> Validation</li>
                    <li><i class="bi bi-check2"></i> Statistics</li>
                    <li><i class="bi bi-check2"></i> Doc Generation</li>
                </ul>
            </div>
            <button class="btn btn-outline-light px-4 py-2 ms-4" data-bs-toggle="modal" data-bs-target="#signInModal">Admin Portal</button>
        </div>
    </section>

    {# --- NEW FOOTER (Based on your Image) --- #}
