{% extends 'base.html.twig' %}

{% block title %}Stag.io - Webmaster Dashboard{% endblock %}

{% block body %}
    <style>

        nav.navbar { display: none !important; }
        :root {
            --bg-main: #000000;
            --card-bg: #09090b;
            --border-color: #1f2937;
            --accent-primary: #3b82f6;
            --accent-success: #10b981;
            --text-muted: #94a3b8;
        }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
        }

        .dashboard-container {
            padding-top: 50px;
            padding-bottom: 50px;
        }

        .page-header {
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.025em;
        }

        .stats-text {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Table Styling */
        .custom-table-container {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        .table {
            margin-bottom: 0;
            color: white;
        }

        .table thead th {
            background-color: #111827;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            padding: 16px 24px;
        }

        .table tbody td {
            padding: 20px 24px;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-color);
            background: transparent;
            color: #e5e7eb;
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Badge & Buttons */
        .btn-action {
            border-radius: 8px;
            font-weight: 500;
            padding: 8px 16px;
            font-size: 0.875rem;
            transition: all 0.2s;
        }

        .btn-view {
            background: rgba(59, 130, 246, 0.1);
            color: var(--accent-primary);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .btn-view:hover {
            background: var(--accent-primary);
            color: white;
        }

        .btn-approve {
            background: var(--accent-success);
            border: none;
            color: white;
        }

        .btn-approve:hover {
            background: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
        }

        .empty-state {
            padding: 60px 0;
            text-align: center;
            color: var(--text-muted);
        }

        .company-name {
            font-weight: 600;
            color: white;
            display: block;
        }

        .company-email {
            font-size: 0.85rem;
            color: var(--text-muted);
        }
    </style>

    <div class="container dashboard-container">
        <div class="page-header d-flex justify-content-between align-items-end">
            <div>
                <h1 class="page-title">Webmaster Dashboard</h1>
                <p class="stats-text">Review and manage company registration requests.</p>
            </div>
            <div class="badge bg-primary px-3 py-2 mb-2">
                {{ companies|length }} Pending Requests
            </div>
        </div>

        <div class="custom-table-container shadow-sm">
            <table class="table">
                <thead>
                <tr>
                    <th>Company Details</th>
                    <th>Verification Document</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for company in companies %}
                    <tr>
                        <td>
                            <span class="company-name">{{ company.companyName }}</span>
                            <span class="company-email">{{ company.email }}</span>
                        </td>
                        <td>
                            <a href="{{ asset('uploads/verification/' ~ company.verificationFile) }}"
                               target="_blank"
                               class="btn btn-action btn-view">
                                <i class="bi bi-file-earmark-pdf me-2"></i>View Document
                            </a>
                        </td>
                        <td class="text-end">
                            <form action="{{ path('app_webmaster_approve_company', {id: company.id}) }}" method="POST" class="d-inline">
                                <button class="btn btn-action btn-approve">
                                    <i class="bi bi-check-circle me-2"></i>Approve & Activate
                                </button>
                            </form>

                            {# رفض #}
                            <form action="{{ path('app_webmaster_reject_company', {id: company.id}) }}" method="POST" class="d-inline ms-2"
                                  onsubmit="return confirm('هل أنت متأكد من رفض هذه الشركة؟')">
                                <button class="btn btn-action" style="background:#1f2a42; color:white; border:none;">
                                    <i class="bi bi-x-circle me-2"></i>Reject
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">
                            <div class="empty-state">
                                <i class="bi bi-inbox mb-3 d-block" style="font-size: 3rem; opacity: 0.3;"></i>
                                <p>No pending company verification requests at the moment.</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>








        {# ── قسم إنشاء Admin ── #}
        <div class="mt-5">
            <h2 class="page-title mb-4" style="font-size:1.5rem;">Create Admin Account</h2>
            <div class="custom-table-container p-4">
                <form action="{{ path('app_webmaster_create_admin') }}" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted">Email</label>
                            <input type="email" name="admin_email" class="form-control"
                                   style="background:#111827; border-color:#1f2937; color:white;"
                                   placeholder="admin@university.dz" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Password</label>
                            <input type="password" name="admin_password" class="form-control"
                                   style="background:#111827; border-color:#1f2937; color:white;"
                                   placeholder="••••••••" required>
                        </div>
                            {#  <label class="form-label text-muted">University Name</label>
                            <input type="text" name="admin_university" class="form-control"
                                   style="background:#111827; border-color:#1f2937; color:white;"
                                   placeholder="Université de Constantine" required>#}
                            <div class="col-md-6">
                                <label class="form-label text-muted">University Name</label>
                                <select id="university-select" name="admin_university" class="form-select"
                                        style="background:#111827; border-color:#1f2937; color:white;" required>
                                    <option value="" disabled selected>Select a university</option>
                                    {% for university in universities %}
                                        <option value="{{ university.id }}">{{ university.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label text-muted">Department</label>
                                <select id="department-select" name="admin_department" class="form-control"
                                        style="background:#111827; border-color:#1f2937; color:white;" required>
                                    <option value="" selected disabled>اختر القسم...</option>

                                    {% for university in universities %}
                                        {# نربط المجموعة بـ ID الجامعة ونخفيها افتراضياً #}
                                        <optgroup label="{{ university.name }}" data-university-id="{{ university.id }}" style="display: none;">
                                            {% for dept in university.departments %}
                                                <option value="{{ dept.name }}" style="color: white; background: #111827;">
                                                    {{ dept.name }}
                                                </option>
                                            {% endfor %}
                                        </optgroup>
                                    {% endfor %}
                                </select>
                            </div>
                        <div class="col-12">
                            <button type="submit" class="btn btn-action btn-approve px-4">
                                <i class="bi bi-person-plus me-2"></i>Create Admin
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        {# ── قائمة الأدمنة الموجودين ── #}
        <div class="mt-4">
            <h3 style="font-size:1rem; color:var(--text-muted);">Existing Admins ({{ admins|length }})</h3>
            <div class="custom-table-container mt-2">
                <table class="table">
                    <thead>
                    <tr>
                        <th>Email</th>
                        <th>University</th>
                        <th>Department</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for admin in admins %}
                        <tr>
                            <td>{{ admin.email }}</td>
                            {# بعد التعديل (الأفضل) #}
                            <td>{{ admin.universityRef.name ?? admin.universityName ?? '-' }}</td>
                            <td>{{ admin.departmentRef.name ?? admin.department ?? '-' }}</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_webmaster_edit_admin', {id: admin.id}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <form method="post" action="{{ path('app_webmaster_delete_admin', {id: admin.id}) }}"
                                          onsubmit="return confirm('Are you sure you want to delete this account?');">
                                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center" style="color:var(--text-muted);">No admins yet.</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-center mt-5 mb-4">
        <a href="{{ path('app_logout') }}"
           style="color: #93c5fd; border: 1px solid rgba(147, 197, 253, 0.3); background: rgba(147, 197, 253, 0.05); text-decoration: none; padding: 10px 25px; border-radius: 8px; font-weight: 500; transition: all 0.3s ease;"
           onmouseover="this.style.background='rgba(147, 197, 253, 0.2)'; this.style.borderColor='#93c5fd';"
           onmouseout="this.style.background='rgba(147, 197, 253, 0.05)'; this.style.borderColor='rgba(147, 197, 253, 0.3)';"
           class="d-inline-flex align-items-center">
            <i class="bi bi-box-arrow-right me-2"></i> Logout
        </a>
    </div>

























    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const universitySelect = document.getElementById('university-select');
            const departmentSelect = document.getElementById('department-select');
            const allOptgroups = departmentSelect.querySelectorAll('optgroup');

            // وظيفة لتحديث قائمة الأقسام
            universitySelect.addEventListener('change', function () {
                const selectedUniversityId = this.value;

                // 1. تصفير اختيار القسم الحالي
                departmentSelect.value = "";

                // 2. إخفاء جميع المجموعات وحذفها مؤقتاً من العرض لتجنب اختيار أقسام خاطئة
                allOptgroups.forEach(group => {
                    if (group.getAttribute('data-university-id') === selectedUniversityId) {
                        group.style.display = 'block';
                        group.disabled = false; // تفعيل المجموعة المختارة
                    } else {
                        group.style.display = 'none';
                        group.disabled = true; // تعطيل المجموعات الأخرى
                    }
                });
            });
        });
    </script>
{% endblock %}
