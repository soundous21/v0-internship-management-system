{% extends 'base.html.twig' %}

{% block title %}Stag.io - Webmaster Dashboard{% endblock %}

{% block body %}
    <style>
        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --card-bg: #000000;
            --border-color: rgb(17, 24, 39);
            --text-muted: #94a3b8;
            --accent-primary: #3378f3;
            --glow-color: rgba(59, 130, 246, 0.3);
        }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        nav.navbar, .main-header, header { display: none !important; }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
            display: flex;
            flex-direction: column;
        }

        .brand-text {
            font-weight: 800;
            letter-spacing: -1px;
            color: white;
            font-size: 1.5rem;
        }
        .brand-text .dot {
            color: var(--accent-primary);
            text-shadow: 0 0 10px var(--glow-color);
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
            gap: 12px;
        }

        .nav-link-custom i { font-size: 1.1rem; transition: all 0.3s ease; }

        .nav-link-custom.active {
            background-color: rgba(51, 120, 243, 0.1);
            color: var(--accent-primary);
            border-left: 3px solid var(--accent-primary);
            box-shadow: inset 10px 0 20px rgba(51, 120, 243, 0.05);
        }

        .nav-link-custom:hover:not(.active) {
            color: white;
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        .nav-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-color), transparent);
            margin: 20px 0;
        }

        .logout-blue {
            color: var(--accent-primary) !important;
            margin-top: auto;
        }

        /* ── Badge on nav item ── */
        .nav-badge {
            margin-left: auto;
            background: var(--accent-primary);
            color: white;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 10px;
            min-width: 20px;
            text-align: center;
        }

        /* ── Main Content ── */
        .main-content {
            margin-left: 260px;
            padding: 2rem 2.5rem;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .section-header {
            margin-bottom: 2rem;
        }
        .section-title {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.025em;
        }
        .section-sub {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 4px;
        }

        /* ── Cards ── */
        .card-dark {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .card-dark:hover {
            border-color: rgba(51, 120, 243, 0.3);
            box-shadow: 0 8px 24px rgba(51, 120, 243, 0.06);
        }

        /* ── Table ── */
        .table { margin-bottom: 0; color: white; }

        .table thead th {
            background-color: #0a0f1a;
            border-bottom: 1px solid var(--border-color);
            color: var(--text-muted);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.08em;
            padding: 14px 20px;
        }

        .table tbody td {
            padding: 16px 20px;
            vertical-align: middle;
            border-bottom: 1px solid var(--border-color);
            background: transparent;
            color: #e5e7eb;
        }

        .table tbody tr:last-child td { border-bottom: none; }

        .table tbody tr {
            transition: background 0.2s ease;
        }

        .table tbody tr:hover td {
            background: rgba(51, 120, 243, 0.03) !important;
        }

        /* ── Buttons ── */
        .btn-action {
            border-radius: 8px;
            font-weight: 500;
            padding: 7px 14px;
            font-size: 0.82rem;
            transition: all 0.2s;
            border: none;
        }

        .btn-approve {
            background: #10b981;
            color: white;
        }
        .btn-approve:hover {
            background: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.25);
            color: white;
        }

        .btn-reject {
            background: rgba(239, 68, 68, 0.1);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2) !important;
        }
        .btn-reject:hover {
            background: rgba(239, 68, 68, 0.2);
            color: white;
        }

        .btn-edit {
            background: rgba(51, 120, 243, 0.1);
            color: var(--accent-primary);
            border: 1px solid rgba(51, 120, 243, 0.2) !important;
        }
        .btn-edit:hover {
            background: var(--accent-primary);
            color: white;
        }

        .btn-delete {
            background: rgba(239, 68, 68, 0.08);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.15) !important;
        }
        .btn-delete:hover {
            background: rgba(239, 68, 68, 0.2);
            color: white;
        }

        .btn-view {
            background: rgba(51, 120, 243, 0.1);
            color: var(--accent-primary);
            border: 1px solid rgba(51, 120, 243, 0.2) !important;
        }
        .btn-view:hover {
            background: var(--accent-primary);
            color: white;
        }

        /* ── Form ── */
        .form-label-custom {
            color: #e2e8f0;
            font-weight: 600;
            font-size: 0.82rem;
            margin-bottom: 6px;
            display: block;
            letter-spacing: 0.3px;
        }

        .form-control-dark,
        .form-select-dark {
            background: #0a0f1a !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 8px;
            padding: 0.65rem 1rem;
            transition: 0.3s;
            width: 100%;
        }

        .form-control-dark:focus,
        .form-select-dark:focus {
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 0 3px rgba(51, 120, 243, 0.15) !important;
            outline: none;
        }

        .form-control-dark::placeholder { color: #4b5563; }

        .form-select-dark option {
            background: #0a0f1a;
            color: white;
        }

        /* ── Empty state ── */
        .empty-state {
            padding: 60px 0;
            text-align: center;
            color: var(--text-muted);
        }

        /* ── Stat mini cards ── */
        .mini-stat {
            background: #0a0f1a;
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.2rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: all 0.3s ease;
        }
        .mini-stat:hover {
            border-color: rgba(51,120,243,0.3);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(51,120,243,0.08);
        }
        .mini-stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }
        .mini-stat-icon.blue  { background: rgba(51,120,243,0.12); color: var(--accent-primary); }
        .mini-stat-icon.green { background: rgba(16,185,129,0.12); color: #10b981; }
        .mini-stat-icon.purple{ background: rgba(139,92,246,0.12); color: #8b5cf6; }
        .mini-stat-label { font-size: 0.78rem; color: var(--text-muted); }
        .mini-stat-value { font-size: 1.4rem; font-weight: 800; color: white; line-height: 1; }

        /* ── Flash messages ── */
        .alert-custom-success {
            background: rgba(16,185,129,0.1);
            border: 1px solid rgba(16,185,129,0.25);
            color: #6ee7b7;
            border-radius: 10px;
            padding: 12px 18px;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .alert-custom-error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            color: #fca5a5;
            border-radius: 10px;
            padding: 12px 18px;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ── Tabs hidden by default ── */
        .tab-section { display: none; }
        .tab-section.active { display: block; }

        /* ── Company avatar ── */
        .company-avatar {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: rgba(51,120,243,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--accent-primary);
            font-size: 1rem;
            flex-shrink: 0;
        }
    </style>

    {# ══════════════════════════════════════════════════ #}
    {# SIDEBAR                                           #}
    {# ══════════════════════════════════════════════════ #}
    <div class="sidebar">
        <div class="mb-5">
            <h3 class="brand-text">Stag<span class="dot">.</span>io</h3>
            <small style="color: #4b5563; font-size: 0.72rem; letter-spacing: 1px; text-transform: uppercase;">Webmaster Panel</small>
        </div>

        <nav class="nav flex-column flex-grow-1">
            <button class="nav-link-custom active" onclick="switchTab('companies', this)">
                <i class="bi bi-building"></i>
                <span>Company Requests</span>
                {% if companies|length > 0 %}
                    <span class="nav-badge">{{ companies|length }}</span>
                {% endif %}
            </button>

            <button class="nav-link-custom" onclick="switchTab('admins', this)">
                <i class="bi bi-shield-person"></i>
                <span>Admin Accounts</span>
                <span class="nav-badge" style="background: rgba(139,92,246,0.8);">{{ admins|length }}</span>
            </button>

            <div class="nav-divider"></div>

            <a href="{{ path('app_logout') }}" class="nav-link-custom logout-blue">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </a>
        </nav>
    </div>

    {# ══════════════════════════════════════════════════ #}
    {# MAIN CONTENT                                      #}
    {# ══════════════════════════════════════════════════ #}
    <div class="main-content">

        {# ── Flash messages ── #}
        {% for msg in app.flashes('success') %}
            <div class="alert-custom-success mb-4">
                <i class="bi bi-check-circle-fill"></i> {{ msg }}
            </div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert-custom-error mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> {{ msg }}
            </div>
        {% endfor %}

        {# ══════════════════════════════════════════════ #}
        {# TAB 1: COMPANY REQUESTS                       #}
        {# ══════════════════════════════════════════════ #}
        <div id="tab-companies" class="tab-section active">

            <div class="section-header d-flex justify-content-between align-items-end">
                <div>
                    <h1 class="section-title">Company Requests</h1>
                    <p class="section-sub">Review and approve pending company registrations.</p>
                </div>
                <div style="background: rgba(51,120,243,0.1); border: 1px solid rgba(51,120,243,0.2); color: var(--accent-primary); padding: 6px 16px; border-radius: 8px; font-size: 0.82rem; font-weight: 600;">
                    {{ companies|length }} Pending
                </div>
            </div>

            {# Stats row #}
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="mini-stat">
                        <div class="mini-stat-icon blue"><i class="bi bi-hourglass-split"></i></div>
                        <div>
                            <div class="mini-stat-label">Awaiting Review</div>
                            <div class="mini-stat-value">{{ companies|length }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mini-stat">
                        <div class="mini-stat-icon green"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <div class="mini-stat-label">Total Admins</div>
                            <div class="mini-stat-value">{{ admins|length }}</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mini-stat">
                        <div class="mini-stat-icon purple"><i class="bi bi-bank"></i></div>
                        <div>
                            <div class="mini-stat-label">Universities</div>
                            <div class="mini-stat-value">{{ universities|length }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-dark">
                <table class="table">
                    <thead>
                    <tr>
                        <th>Company Details</th>
                        <th>Verification Document</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for company in companies %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="company-avatar">
                                        <i class="bi bi-building"></i>
                                    </div>
                                    <div>
                                        <div style="font-weight: 600; color: white;">{{ company.companyName }}</div>
                                        <div style="font-size: 0.82rem; color: var(--text-muted);">{{ company.email }}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="{{ asset('uploads/verification/' ~ company.verificationFile) }}"
                                   target="_blank"
                                   class="btn btn-action btn-view">
                                    <i class="bi bi-file-earmark-pdf me-1"></i>View Document
                                </a>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <form action="{{ path('app_webmaster_approve_company', {id: company.id}) }}" method="POST" class="d-inline">
                                        <button class="btn btn-action btn-approve">
                                            <i class="bi bi-check-circle me-1"></i>Approve
                                        </button>
                                    </form>
                                    <form action="{{ path('app_webmaster_reject_company', {id: company.id}) }}" method="POST" class="d-inline"
                                          onsubmit="return confirm('هل أنت متأكد من رفض هذه الشركة؟')">
                                        <button class="btn btn-action btn-reject">
                                            <i class="bi bi-x-circle me-1"></i>Reject
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3">
                                <div class="empty-state">
                                    <i class="bi bi-inbox-fill mb-3 d-block" style="font-size: 2.5rem; opacity: 0.25;"></i>
                                    <p class="mb-0">No pending company verification requests.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {# ══════════════════════════════════════════════ #}
        {# TAB 2: ADMIN ACCOUNTS                         #}
        {# ══════════════════════════════════════════════ #}
        <div id="tab-admins" class="tab-section">

            <div class="section-header">
                <h1 class="section-title">Admin Accounts</h1>
                <p class="section-sub">Create and manage university admin accounts.</p>
            </div>

            {# ── Create Admin Form ── #}
            <div class="card-dark p-4 mb-4">
                <h5 class="mb-4" style="font-weight: 700; font-size: 1rem; display: flex; align-items: center; gap: 8px;">
                <span style="background: rgba(51,120,243,0.12); color: var(--accent-primary); width: 32px; height: 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center;">
                    <i class="bi bi-person-plus"></i>
                </span>
                    Create New Admin
                </h5>

                <form action="{{ path('app_webmaster_create_admin') }}" method="POST">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label-custom">Email Address</label>
                            <input type="email" name="admin_email" class="form-control-dark"
                                   placeholder="admin@university.dz" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Password</label>
                            <input type="password" name="admin_password" class="form-control-dark"
                                   placeholder="••••••••" required>
                        </div>

                        {#
                        🐛 BUG FIX: كانت القيمة value="{{ university.id }}" (رقم)
                        لكن الـ Controller يبحث بـ findOneBy(['name' => $universityName])
                        الحل: نرسل اسم الجامعة value="{{ university.name }}"
                        #}
                        <div class="col-md-6">
                            <label class="form-label-custom">University</label>
                            <select id="university-select" name="admin_university" class="form-select-dark" required>
                                <option value="" disabled selected>Select a university...</option>
                                {% for university in universities %}
                                    <option value="{{ university.name }}">{{ university.name }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-custom">Department</label>
                            <select id="department-select" name="admin_department" class="form-select-dark" required>
                                <option value="" selected disabled>Select a department...</option>
                                {% for university in universities %}
                                    <optgroup label="{{ university.name }}"
                                              data-university-name="{{ university.name }}"
                                              style="display: none;">
                                        {% for dept in university.departments %}
                                            <option value="{{ dept.name }}" style="color: white; background: #0a0f1a;">
                                                {{ dept.name }}
                                            </option>
                                        {% endfor %}
                                    </optgroup>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-12 pt-1">
                            <button type="submit" class="btn btn-action btn-approve px-4">
                                <i class="bi bi-person-plus me-2"></i>Create Admin Account
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            {# ── Existing Admins Table ── #}
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                <h6 style="color: var(--text-muted); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; margin: 0;">
                    Existing Admins <span style="color: #6b7280;">({{ admins|length }})</span>
                </h6>
            </div>

            <div class="card-dark">
                <table class="table">
                    <thead>
                    <tr>
                        <th>Email</th>
                        <th>University</th>
                        <th>Department</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for admin in admins %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(139,92,246,0.12); display: flex; align-items: center; justify-content: center; color: #8b5cf6; flex-shrink: 0;">
                                        <i class="bi bi-shield-person" style="font-size: 0.9rem;"></i>
                                    </div>
                                    <span style="font-size: 0.9rem;">{{ admin.email }}</span>
                                </div>
                            </td>
                            <td>
                                {# نعرض اسم الجامعة من العلاقة، أو النص المحفوظ كـ fallback #}
                                <span style="color: #cbd5e1; font-size: 0.88rem;">
                                {{ admin.universityRef.name ?? admin.universityName ?? '—' }}
                            </span>
                            </td>
                            <td>
                            <span style="color: #cbd5e1; font-size: 0.88rem;">
                                {{ admin.departmentRef.name ?? admin.department ?? '—' }}
                            </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a href="{{ path('app_webmaster_edit_admin', {id: admin.id}) }}"
                                       class="btn btn-action btn-edit">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <form method="post"
                                          action="{{ path('app_webmaster_delete_admin', {id: admin.id}) }}"
                                          onsubmit="return confirm('Are you sure you want to delete this admin account?');">
                                        <button class="btn btn-action btn-delete">
                                            <i class="bi bi-trash3 me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">
                                <div class="empty-state">
                                    <i class="bi bi-person-slash mb-3 d-block" style="font-size: 2.5rem; opacity: 0.25;"></i>
                                    <p class="mb-0">No admin accounts created yet.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>{# /main-content #}

    <script>
        // ── Tab switching ──────────────────────────────
        function switchTab(tab, btn) {
            // إخفاء كل الأقسام
            document.querySelectorAll('.tab-section').forEach(s => s.classList.remove('active'));
            // إزالة active من كل الأزرار
            document.querySelectorAll('.nav-link-custom').forEach(b => b.classList.remove('active'));
            // إظهار القسم المطلوب
            document.getElementById('tab-' + tab).classList.add('active');
            // تفعيل الزر المضغوط
            btn.classList.add('active');
        }

        // ── Department dropdown filter ─────────────────
        document.addEventListener('DOMContentLoaded', function () {
            const universitySelect = document.getElementById('university-select');
            const departmentSelect = document.getElementById('department-select');

            if (!universitySelect || !departmentSelect) return;

            const allOptgroups = departmentSelect.querySelectorAll('optgroup');

            universitySelect.addEventListener('change', function () {
                const selectedName = this.value; // الآن القيمة هي الاسم مباشرة

                departmentSelect.value = "";

                allOptgroups.forEach(group => {
                    const match = group.getAttribute('data-university-name') === selectedName;
                    group.style.display = match ? 'block' : 'none';
                    group.disabled = !match;
                });

                // إعادة تفعيل الخيار الأول
                departmentSelect.value = "";
            });

            // ── الانتقال التلقائي لقسم الأدمنة إذا جاءنا من create admin ──
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('tab') === 'admins') {
                const adminBtn = document.querySelector('[onclick*="admins"]');
                if (adminBtn) switchTab('admins', adminBtn);
            }
        });
    </script>
{% endblock %}
