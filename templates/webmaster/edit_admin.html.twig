{% extends 'base.html.twig' %}

{% block title %}Stag.io - Edit Admin{% endblock %}

{% block body %}
    <style>
        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --card-bg: #000000;
            --border-color: rgb(17, 24, 39);
            --text-muted: #94a3b8;
            --accent-primary: #3378f3;
            --glow-color: rgba(59, 130, 246, 0.3);
        }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        nav.navbar, .main-header, header { display: none !important; }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
            display: flex;
            flex-direction: column;
        }

        .brand-text {
            font-weight: 800;
            letter-spacing: -1px;
            color: white;
            font-size: 1.5rem;
        }
        .brand-text .dot {
            color: var(--accent-primary);
            text-shadow: 0 0 10px var(--glow-color);
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            color: var(--text-muted);
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            gap: 12px;
        }
        .nav-link-custom.active {
            background-color: rgba(51, 120, 243, 0.1);
            color: var(--accent-primary);
            border-left: 3px solid var(--accent-primary);
        }
        .nav-link-custom:hover:not(.active) {
            color: white;
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        .nav-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-color), transparent);
            margin: 20px 0;
        }

        .logout-blue { color: var(--accent-primary) !important; }

        /* ── Main ── */
        .main-content {
            margin-left: 260px;
            padding: 2rem 2.5rem;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .section-title {
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.025em;
        }
        .section-sub { color: var(--text-muted); font-size: 0.9rem; margin-top: 4px; }

        .card-dark {
            background: #0a0f1a;
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2rem;
            transition: all 0.3s ease;
        }

        .form-label-custom {
            color: #e2e8f0;
            font-weight: 600;
            font-size: 0.82rem;
            margin-bottom: 6px;
            display: block;
            letter-spacing: 0.3px;
        }

        .form-control-dark,
        .form-select-dark {
            background: #060a12 !important;
            border: 1px solid var(--border-color) !important;
            color: white !important;
            border-radius: 8px;
            padding: 0.65rem 1rem;
            transition: 0.3s;
            width: 100%;
        }
        .form-control-dark:focus,
        .form-select-dark:focus {
            border-color: var(--accent-primary) !important;
            box-shadow: 0 0 0 3px rgba(51, 120, 243, 0.15) !important;
            outline: none;
        }
        .form-control-dark::placeholder { color: #4b5563; }
        .form-select-dark option { background: #0a0f1a; color: white; }

        .btn-save {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #1d4ed8 100%);
            border: none;
            color: white;
            border-radius: 8px;
            padding: 10px 28px;
            font-weight: 600;
            font-size: 0.88rem;
            transition: all 0.3s;
            cursor: pointer;
        }
        .btn-save:hover {
            box-shadow: 0 6px 20px var(--glow-color);
            transform: translateY(-2px);
        }

        .btn-cancel {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            border-radius: 8px;
            padding: 10px 28px;
            font-weight: 500;
            font-size: 0.88rem;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-cancel:hover {
            border-color: rgba(255,255,255,0.2);
            color: white;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            font-size: 0.82rem;
            text-decoration: none;
            margin-bottom: 1.5rem;
            transition: color 0.2s;
        }
        .back-link:hover { color: white; }

        .admin-info-badge {
            background: rgba(139,92,246,0.08);
            border: 1px solid rgba(139,92,246,0.2);
            border-radius: 10px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 2rem;
        }
        .admin-info-badge i { color: #8b5cf6; font-size: 1.3rem; }
        .admin-info-badge .email { font-weight: 600; font-size: 0.9rem; }
        .admin-info-badge .role { color: var(--text-muted); font-size: 0.78rem; }
    </style>

    {# ── Sidebar ── #}
    <div class="sidebar">
        <div class="mb-5">
            <h3 class="brand-text">Stag<span class="dot">.</span>io</h3>
            <small style="color: #4b5563; font-size: 0.72rem; letter-spacing: 1px; text-transform: uppercase;">Webmaster Panel</small>
        </div>

        <nav class="nav flex-column flex-grow-1">
            <a href="{{ path('app_webmaster_dashboard') }}" class="nav-link-custom">
                <i class="bi bi-building"></i>
                <span>Company Requests</span>
            </a>
            <a href="{{ path('app_webmaster_dashboard') }}" class="nav-link-custom active">
                <i class="bi bi-shield-person"></i>
                <span>Admin Accounts</span>
            </a>
            <div class="nav-divider"></div>
            <a href="{{ path('app_logout') }}" class="nav-link-custom logout-blue">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </a>
        </nav>
    </div>

    {# ── Main Content ── #}
    <div class="main-content">
        <a href="{{ path('app_webmaster_dashboard') }}" class="back-link">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>

        <div class="mb-4">
            <h1 class="section-title">Edit Admin</h1>
            <p class="section-sub">Update admin account information.</p>
        </div>

        {# ── Info badge ── #}
        <div class="admin-info-badge">
            <i class="bi bi-shield-person-fill"></i>
            <div>
                <div class="email">{{ admin.email }}</div>
                <div class="role">
                    ROLE_ADMIN
                    {% if admin.universityRef %}
                        &nbsp;·&nbsp; {{ admin.universityRef.name }}
                    {% endif %}
                    {% if admin.departmentRef %}
                        &nbsp;·&nbsp; {{ admin.departmentRef.name }}
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="card-dark">
            <form method="post" action="{{ path('app_webmaster_edit_admin', {id: admin.id}) }}">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label-custom">Email Address</label>
                        <input type="email" name="email"
                               value="{{ admin.email }}"
                               class="form-control-dark" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-custom">New Password <span style="color: #4b5563; font-weight: 400;">(leave blank to keep current)</span></label>
                        <input type="password" name="new_password"
                               class="form-control-dark"
                               placeholder="••••••••">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-custom">University</label>
                        <select id="edit-university-select" name="admin_university" class="form-select-dark">
                            <option value="" disabled>Select a university...</option>
                            {% for university in universities ?? [] %}
                                <option value="{{ university.name }}"
                                        {% if admin.universityRef and admin.universityRef.name == university.name %}selected{% endif %}>
                                    {{ university.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-custom">Department</label>
                        <select id="edit-department-select" name="admin_department" class="form-select-dark">
                            <option value="" disabled>Select a department...</option>
                            {% for university in universities ?? [] %}
                                <optgroup label="{{ university.name }}"
                                          data-university-name="{{ university.name }}">
                                    {% for dept in university.departments %}
                                        <option value="{{ dept.name }}"
                                                {% if admin.departmentRef and admin.departmentRef.name == dept.name %}selected{% endif %}
                                                style="color: white; background: #0a0f1a;">
                                            {{ dept.name }}
                                        </option>
                                    {% endfor %}
                                </optgroup>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-save">
                            <i class="bi bi-check-lg me-2"></i>Save Changes
                        </button>
                        <a href="{{ path('app_webmaster_dashboard') }}" class="btn-cancel">
                            <i class="bi bi-x-lg"></i> Cancel
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const uniSelect  = document.getElementById('edit-university-select');
            const deptSelect = document.getElementById('edit-department-select');
            if (!uniSelect || !deptSelect) return;

            const allGroups = deptSelect.querySelectorAll('optgroup');

            function filterDepts(selectedName) {
                allGroups.forEach(group => {
                    const match = group.getAttribute('data-university-name') === selectedName;
                    group.style.display = match ? 'block' : 'none';
                    group.disabled = !match;
                });
            }

            // تطبيق عند التحميل إذا كانت هناك جامعة محددة
            if (uniSelect.value) filterDepts(uniSelect.value);

            uniSelect.addEventListener('change', function () {
                filterDepts(this.value);
                deptSelect.value = "";
            });
        });
    </script>
{% endblock %}
