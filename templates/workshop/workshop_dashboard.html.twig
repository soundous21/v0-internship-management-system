{% extends 'base.html.twig' %}

{% block title %}Medical Workshops - Expert Training{% endblock %}

{% block body %}
    <style>
        /* حل مشكلة التمرير والنزول في الصفحة */
        html, body {
            height: auto !important;
            min-height: 100vh !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            background-color: #050505; /* لون خلفية غامق لضمان التناسق */
        }

        body {
            padding: 60px 0;
            display: block !important;
        }

        /* حاوية الورشة */
        .workshop-card {
            background: rgba(10, 10, 10, 0.9) !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            border-radius: 20px;
            overflow: hidden;
            transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
            position: relative;
        }

        .workshop-card:hover {
            transform: translateY(-12px);
            border-color: var(--royal-blue) !important;
            box-shadow: 0 20px 40px rgba(0, 82, 212, 0.3);
        }

        /* ترويسة البطاقة */
        .workshop-header {
            background: linear-gradient(135deg, var(--bourgeois-purple), var(--royal-blue));
            padding: 30px;
            text-align: center;
        }

        .workshop-icon {
            font-size: 3rem;
            color: white;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.4));
        }

        /* تفاصيل الورشة */
        .workshop-details {
            padding: 25px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .instructor-name {
            color: var(--soft-blue);
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .workshop-time {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .category-badge {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #fff;
            font-size: 0.7rem;
            padding: 5px 15px;
            border-radius: 50px;
            text-transform: uppercase;
        }

        /* تحسين مظهر الأزرار */
        .btn-register {
            background: linear-gradient(45deg, var(--royal-blue), var(--soft-blue));
            border: none;
            color: white;
            font-weight: bold;
            border-radius: 10px;
            padding: 12px;
            transition: 0.3s;
        }

        .btn-register:hover {
            filter: brightness(1.2);
            box-shadow: 0 0 15px var(--soft-blue);
            color: white;
        }
    </style>

    <div class="container mt-5">
        <div class="text-center mb-5">
            <h1 class="animated-title h2">Medical Training Workshops</h1>
            <p class="text-white-50 mx-auto" style="max-width: 600px;">
                Enhance your professional clinical skills through our certified hands-on training sessions.
            </p>
        </div>

        <div class="row g-4 justify-content-center">
            {# جلب البيانات من مصفوفة workshops القادمة من قاعدة البيانات #}
            {% for workshop in workshops %}
                <div class="col-lg-4 col-md-6">
                    <div class="workshop-card">
                        <div class="workshop-header">
                            <i class="bi {{ workshop.icon }} workshop-icon"></i>
                        </div>

                        <div class="workshop-details">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="category-badge">{{ workshop.category }}</span>
                                <span class="text-info small fw-bold">
                                    <i class="bi bi-people-fill me-1"></i>
                                    {{ workshop.registered }} / {{ workshop.seats }}
                                </span>
                            </div>

                            <h5 class="text-white fw-bold mb-2" style="min-height: 50px;">
                                {{ workshop.title }}
                            </h5>

                            <p class="instructor-name mb-3">
                                <i class="bi bi-person-badge me-1"></i> {{ workshop.instructor }}
                            </p>

                            <div class="workshop-time">
                                <i class="bi bi-calendar-check"></i> {{ workshop.workshop_date }}
                                <span class="mx-1">|</span>
                                <i class="bi bi-clock"></i> {{ workshop.workshop_time }}
                            </div>

                            <p class="small text-white-50 mb-4">
                                Intensive session focused on latest medical advancements and practical applications in {{ workshop.category }}.
                            </p>

                            <a href="#" class="btn btn-register w-100">
                                <i class="bi bi-pencil-square me-2"></i> Register Now
                            </a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <div class="glass-card p-5">
                        <i class="bi bi-calendar-x text-white-50 fs-1"></i>
                        <p class="text-white-50 mt-3">No workshops are scheduled at this moment. Please check back later.</p>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="text-center mt-5">
            <a href="{{ path('app_home') }}" class="text-white-50 text-decoration-none small hover-blue">
                <i class="bi bi-arrow-left me-1"></i> Return to Main Gateway
            </a>
        </div>
    </div>
{% endblock %}