{% extends 'base.html.twig' %}

{% block title %}Stag.io - Admin Intelligence Dashboard{% endblock %}

{% block body %}
    <style>
        nav.navbar { display: none !important; }

        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');

        :root {
            --bg-main: #000000;
            --bg-sidebar: #000000;
            --card-bg: #000000;
            --border-color: rgb(41, 55, 89);
            --text-muted: #94a3b8;
            --accent-primary: #3378f3;
            --accent-info: #0ea5e9;
            --accent-white: #ffffff;
            --accent-success: #10b981;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --glow-color: rgba(59, 130, 246, 0.3);
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            margin: 0;
        }

        /* ─── Sidebar ─────────────────────────────────────── */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            margin-left: 260px;
            padding: 2rem;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        /* ─── Navigation ──────────────────────────────────── */
        .nav-pills .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: 0.2s;
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .nav-pills .nav-link:hover,
        .nav-pills .nav-link.active {
            background: #1e293b !important;
            color: white !important;
        }

        .nav-pills .nav-link.active {
            border-left: 2px solid var(--accent-primary);
        }

        /* ─── Cards ───────────────────────────────────────── */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-primary);
            box-shadow: 0 10px 30px var(--glow-color);
        }

        /* ─── Tables ──────────────────────────────────────── */
        .table { color: #cbd5e1; margin-bottom: 0; }
        .table thead th {
            background: rgba(17, 24, 39, 0.6);
            color: var(--accent-primary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem;
            border: none;
        }
        .table tbody td {
            padding: 1.2rem;
            border-bottom: 1px solid rgba(17, 24, 39, 0.5);
            vertical-align: middle;
        }

        /* ─── Badges ──────────────────────────────────────── */
        .badge-tech {
            background: rgba(51, 120, 243, 0.1);
            border: 1px solid rgba(51, 120, 243, 0.3);
            color: var(--accent-primary);
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        /* ✅ FIXED: was missing */
        .badge-custom-tech {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(51, 120, 243, 0.08);
            border: 1px solid rgba(51, 120, 243, 0.25);
            color: #93c5fd;
            padding: 5px 14px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* ✅ FIXED: was missing */
        .dot-glow {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent-primary);
            box-shadow: 0 0 6px var(--accent-primary);
            animation: pulse-dot 2s infinite;
            flex-shrink: 0;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }

        /* ✅ FIXED: was missing */
        .uppercase-tracking {
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ✅ FIXED: was missing */
        .btn-tech-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-tech-outline:hover {
            border-color: var(--accent-primary);
            color: white;
            background: rgba(51, 120, 243, 0.1);
        }

        /* ✅ FIXED: was missing */
        .btn-tech-outline-danger {
            background: transparent;
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: var(--accent-danger);
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
        }

        .btn-tech-outline-danger:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: var(--accent-danger);
        }

        .btn-tech {
            background: var(--accent-primary);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            transition: 0.3s;
            cursor: pointer;
        }

        .btn-tech:hover {
            opacity: 0.9;
            box-shadow: 0 0 15px var(--accent-primary);
        }

        .chart-container {
            min-height: 300px;
            position: relative;
        }

        .border-color { border-color: rgba(17, 24, 39, 0.8) !important; }

        .badge { font-size: 0.7rem; padding: 4px 8px; }
        .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1) !important; }
        .bg-secondary-subtle { background-color: rgba(148, 163, 184, 0.1) !important; }

        .transition-row { transition: background 0.15s; }
        .transition-row:hover { background: rgba(51, 120, 243, 0.04) !important; }

        /* ─── Statistics Section Specific ────────────────── */
        .progress-bar-custom {
            height: 8px;
            border-radius: 99px;
            background: rgba(255,255,255,0.06);
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            border-radius: 99px;
            transition: width 1s ease;
        }

        .kpi-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2.4rem;
            font-weight: 700;
            line-height: 1;
        }

        .wilaya-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        .wilaya-row:last-child { border-bottom: none; }

        .section-accent-bar {
            width: 4px;
            height: 26px;
            border-radius: 2px;
            background: var(--accent-primary);
            box-shadow: 0 0 10px var(--accent-primary);
            flex-shrink: 0;
        }




        /* تحسينات إضافية للتصميم الأسود */
        #agreementsTable tbody tr:hover {
            background-color: #09090b !important;
            transition: background 0.2s ease;
        }
        .btn-outline-primary:hover {
            background-color: var(--accent-primary);
            color: white;
        }










        .stamp-upload-card {
            background: #111113;
            border: 1px solid #27272a;
            border-radius: 16px;
            padding: 20px;
            transition: transform 0.3s ease;
        }

        .icon-box {
            width: 40px;
            height: 40px;
            background: rgba(51, 120, 243, 0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
        }

        .upload-zone {
            border: 2px dashed #27272a;
            border-radius: 12px;
            height: 160px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            background: #09090b;
        }

        .upload-zone:hover {
            border-color: var(--accent-primary);
            background: rgba(51, 120, 243, 0.05);
        }

        .current-stamp img {
            max-height: 130px;
            max-width: 100%;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.1));
        }

        .overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.3s;
            color: white;
            font-weight: 500;
        }

        .upload-zone:hover .overlay { opacity: 1; }

        .status-badge {
            font-size: 0.75rem;
            padding: 6px 12px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
        }

        .status-badge.success { background: rgba(16, 185, 129, 0.1); color: #10b981; }
        .status-badge.warning { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }

        .placeholder-content { color: #52525b; text-align: center; }















        /* شعار الأدمن */
        .brand-text {
            font-weight: 800;
            letter-spacing: -1px;
            color: white;
            font-size: 1.5rem;
            margin-bottom: 0;
        }
        .brand-text .dot {
            color: var(--accent-primary);
            text-shadow: 0 0 10px var(--glow-color);
        }

        .admin-tag {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: var(--text-muted);
            letter-spacing: 1px;
            text-transform: uppercase;
            opacity: 0.8;
        }

        /* التنسيق الموحد للروابط والأزرار */
        .nav-link-custom {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            color: var(--text-muted) !important;
            text-decoration: none;
            border-radius: 10px;
            margin-bottom: 8px;
            background: transparent;
            border: none;
            width: 100%;
            text-align: left;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-link-custom i {
            font-size: 1.1rem;
            margin-right: 12px;
        }

        /* الحالة النشطة (Active) */
        .nav-link-custom.active {
            background-color: rgba(51, 120, 243, 0.1) !important;
            color: var(--accent-primary) !important;
            border-left: 3px solid var(--accent-primary);
            box-shadow: inset 10px 0 20px rgba(51, 120, 243, 0.05);
        }

        /* تأثير التمرير (Hover) */
        .nav-link-custom:hover:not(.active) {
            color: white !important;
            background-color: rgba(255, 255, 255, 0.05);
            transform: translateX(5px);
        }

        /* الفاصل */
        .nav-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-color), transparent);
            margin: 20px 0;
        }

        /* زر الخروج الأزرق */
        .logout-blue {
            color: var(--accent-primary) !important;
            margin-top: auto;
        }

        .logout-blue:hover {
            background-color: rgba(51, 120, 243, 0.1) !important;
            box-shadow: 0 0 15px var(--glow-color);
        }





        /* تصميم نقطة الإشعار */
        .notification-dot {
            position: absolute;
            top: 10px;
            left: 28px; /* ضبط المكان ليكون فوق أيقونة الدرع مباشرة */
            width: 8px;
            height: 8px;
            background-color: #ef4444; /* لون أحمر نيون */
            border-radius: 50%;
            border: 2px solid var(--bg-sidebar); /* لإعطاء مسافة بينها وبين الأيقونة */
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.8); /* توهج أحمر */
            animation: pulse-red 2s infinite; /* إضافة حركة نبض لجذب الانتباه */
        }

        /* حركة النبض لزيادة التنبيه */
        @keyframes pulse-red {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

    </style>

    <div class="d-flex">
        <!-- ═══════════════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════════════ -->
        <div class="sidebar">
            <div class="brand-container mb-5">
                <h3 class="brand-text">Stag<span class="dot">.</span>io</h3>
                <small class="admin-tag">ADMIN TERMINAL</small>
            </div>

            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist">
                <button class="nav-link-custom active" data-bs-toggle="pill" data-bs-target="#content-dashboard">
                    <i class="bi bi-grid-1x2"></i> <span>Dashboard</span>
                </button>
                {#  <button class="nav-link-custom" data-bs-toggle="pill" data-bs-target="#content-validations">
                    <i class="bi bi-shield-check"></i> <span>Validations</span>
                   {% if stats.pendingApps > 0 %}
                        <span class="notification-dot"></span>
                    {% endif %}
                </button>#}
                <button class="nav-link-custom position-relative" data-bs-toggle="pill" data-bs-target="#content-validations">
                    <i class="bi bi-shield-check"></i>
                    <span>Validations</span>

                    {# تظهر النقطة فقط إذا كان عدد الطلبات المعلقة أكبر من 0 #}
                    {% if stats.pendingApps > 0 %}
                        <span class="notification-dot"></span>
                    {% endif %}
                </button>
                <button class="nav-link-custom" data-bs-toggle="pill" data-bs-target="#content-agreements">
                    <i class="bi bi-file-earmark-binary"></i> <span>Agreements</span>
                    </a>
                </button>
                <button class="nav-link-custom" data-bs-toggle="pill" data-bs-target="#content-company-requests">
                    <i class="bi bi-building-check"></i> <span>Company Requests</span>
                </button>

                <div class="nav-divider"></div>

                <a href="{{ path('app_logout') }}" class="nav-link-custom logout-blue">
                    <i class="bi bi-box-arrow-left"></i> <span>Logout</span>
                </a>
            </div>
        </div>
        <!-- ═══════════════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════════════ -->
        <div class="main-content">
            <div class="tab-content" id="v-pills-tabContent">

                <!-- ════════════════════════════════════════
                     TAB 1 – DASHBOARD OVERVIEW
                ════════════════════════════════════════ -->
                <div class="tab-pane fade show active" id="content-dashboard">
                    <div class="row align-items-end mb-5">
                        <div class="col">
                            <h2 class="fw-bold mb-0">Admin dashboard</h2>
                            <p class="text-secondary small">.</p>
                        </div>
                    </div>
                    {# --- هذا هو الجزء الأهم: يجب أن يكون في الأسفل تماماً أو داخل block javascripts --- #}
                    {# --- جزء الختم المحدث --- #}
                    <style>
                        .dark-premium-card {
                            background: #0b0b0b;
                            border: 1px solid #1f1f1f;
                            border-radius: 20px;
                            padding: 20px; /* تقليل الحشو الداخلي قليلاً */
                            box-shadow: 0 10px 30px rgba(0,0,0,0.6);
                            transition: transform 0.3s ease;
                        }

                        /* تحسين أيقونة العنوان لتكون أصغر وأكثر تناسقاً */
                        .icon-wrapper {
                            background: #111;
                            border: 1px solid #0c0c0c;
                            width: 35px;
                            height: 35px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 8px;
                            color: #0d6efd;
                        }

                        .custom-upload-zone {
                            background: #050505 !important;
                            border: 1px dashed #333 !important;
                            border-radius: 12px;
                            padding: 20px 10px; /* تقليل الارتفاع */
                            transition: all 0.3s ease;
                        }

                        .stamp-preview {
                            max-height: 70px; /* تصغير حجم عرض الختم */
                            border-radius: 6px;
                            background: #fff;
                            padding: 4px;
                        }

                        .text-dimmed { color: #6c757d !important; font-size: 0.75rem; }
                        .text-upload { color: #e0e0e0; font-weight: 500; font-size: 0.85rem; }
                    </style>

                    <!-- تم تعديل كلاس الـ Column ليكون أصغر (col-md-4) وأضفت mb-5 للمسافة السفلية -->
                    <div class="row mb-5 mt-3">
                        <div class="col-md-4 col-xl-3">
                            <div class="dark-premium-card">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="icon-wrapper me-2">
                                        <i class="bi bi-shield-check fs-6"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 text-white fw-bold" style="font-size: 0.9rem;">University seal</h6>
                                        <span class="text-dimmed">Official Stamp</span>
                                    </div>
                                </div>

                                <div class="custom-upload-zone text-center" id="dropZone" style="cursor: pointer;">
                                    {% if app.user.stampFilename %}
                                        <div class="current-stamp">
                                            <img src="{{ asset('uploads/stamps/' ~ app.user.stampFilename) }}"
                                                 class="stamp-preview mb-2" alt="Stamp">
                                            <div>
                                                <span class="text-primary" style="font-size: 10px; text-decoration: underline;">تغيير الملف</span>
                                            </div>
                                        </div>
                                    {% else %}
                                        <div class="upload-placeholder">
                                            <i class="bi bi-plus-lg text-primary opacity-50 mb-1"></i>
                                            <p class="text-upload mb-0">Lift the stamp</p>
                                        </div>
                                    {% endif %}
                                    <input type="file" id="stampInput" class="d-none" accept="image/*">
                                </div>

                                <div id="uploadStatus" class="mt-3 text-center">
                                    {% if app.user.stampFilename %}
                                        <div class="status-pill status-ready" style="font-size: 10px; color: #2ecc71; background: rgba(46, 204, 113, 0.1); padding: 2px 10px; border-radius: 20px;">
                                            <i class="bi bi-check-circle-fill me-1"></i>Stamp Ready
                                        </div>
                                    {% else %}
                                        <div class="status-pill status-pending" style="font-size: 10px; color: #888; background: rgba(255,255,255,0.05); padding: 2px 10px; border-radius: 20px;">
                                            <i class="bi bi-dash-circle me-1"></i>required
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <script>

                        document.addEventListener('DOMContentLoaded', function() {

                            const zone = document.getElementById('dropZone');

                            const input = document.getElementById('stampInput');

                            const statusContainer = document.getElementById('uploadStatus');



                            if (zone && input) {

// فتح نافذة الملفات عند الضغط على المربع

                                zone.addEventListener('click', () => input.click());



// معالجة اختيار الملف

                                input.addEventListener('change', function() {

                                    if (this.files && this.files[0]) {

                                        const file = this.files[0];



// إظهار مؤشر التحميل

                                        statusContainer.innerHTML = '<div class="spinner-border spinner-border-sm text-primary" role="status"></div> <span class="text-white-50 ms-2" style="font-size: 11px;">جاري المعالجة...</span>';



                                        const formData = new FormData();

                                        formData.append('file', file);



                                        fetch('/admin/stamp', {

                                            method: 'POST',

                                            body: formData

                                        })

                                            .then(response => response.json())

                                            .then(data => {

                                                if (data.success) {

// نجاح: تحديث الصفحة لإظهار الختم الجديد

                                                    window.location.reload();

                                                } else {

// فشل: إظهار الخطأ

                                                    statusContainer.innerHTML = `<span class="text-danger small"><i class="bi bi-x-circle"></i> خطأ: ${data.error || 'فشل الرفع'}</span>`;

                                                }

                                            })

                                            .catch(error => {

                                                console.error('Error:', error);

                                                statusContainer.innerHTML = '<span class="text-danger small">حدث خطأ في الاتصال بالسيرفر</span>';

                                            });

                                    }

                                });



// تحسين بصري: تأثير السحب والإفلات

                                zone.addEventListener('dragover', (e) => {

                                    e.preventDefault();

                                    zone.style.borderColor = '#0d6efd';

                                    zone.style.background = '#0f0f0f';

                                });



                                zone.addEventListener('dragleave', () => {

                                    zone.style.borderColor = '#333';

                                    zone.style.background = '#050505';

                                });



                                zone.addEventListener('drop', (e) => {

                                    e.preventDefault();

                                    input.files = e.dataTransfer.files;

                                    input.dispatchEvent(new Event('change'));

                                });

                            }

                        });

                    </script>
                    {# --- نهاية جزء الختم --- #}
                    <!-- KPI Grid -->
                    <div class="row g-3 mb-5">

                        <div class="col-md">
                            <div class="stat-card">
                                <small class="fw-bold mb-3 d-block">TOTAL STUDENTS</small>
                                <div class="kpi-number">{{ stats.totalStudents|default(0) }}</div>
                                <div class="progress-bar-custom mt-3">
                                    <div class="progress-bar-fill" style="width:100%; background: var(--accent-primary);"></div>
                                </div>
                                <small class="text-white-50 mt-2 d-block" style="font-size:0.65rem;">Academic Year 25/26</small>
                            </div>
                        </div>

                        <div class="col-md">
                            {% set total = stats.totalStudents|default(0) %}
                            {% set placed = stats.placedStudentsCount|default(0) %}
                            {% set placedPercentage = (total > 0) ? (placed / total * 100) : 0 %}

                            <div class="stat-card" style="border-bottom: 2px solid var(--accent-success);">
                                <small class="text-success fw-bold d-block mb-3">PLACED</small>
                                <div class="kpi-number" style="color: var(--accent-success);">{{ placed }}</div>
                                <div class="progress-bar-custom mt-3">
                                    <div class="progress-bar-fill" style="width: {{ placedPercentage }}%; background: var(--accent-success);"></div>
                                </div>
                                <small class="text-success mt-2 d-block fw-bold" style="font-size:0.7rem;">
                                    {{ placedPercentage|round(1) }}% Secured Internships
