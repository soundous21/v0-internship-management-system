{% extends 'base.html.twig' %}

{% block title %}Stag.io - Admin Intelligence Dashboard{% endblock %}

{% block body %}
    <style>
        nav.navbar { display: none !important; }

        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');

        :root {
            --bg-main: #030712;
            --bg-sidebar: #09090b;
            --card-bg: #000000;
            --border-color: rgb(17, 24, 39);
            --text-muted: #94a3b8;
            --accent-primary: #3378f3;
            --accent-info: #0ea5e9;
            --accent-white: #ffffff;
            --accent-success: #10b981;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --glow-color: rgba(59, 130, 246, 0.3);
        }

        * { box-sizing: border-box; }

        body {
            background-color: var(--bg-main);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            margin: 0;
        }

        /* ─── Sidebar ─────────────────────────────────────── */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: fixed;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem;
            z-index: 1000;
            top: 0;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            margin-left: 260px;
            padding: 2rem;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        /* ─── Navigation ──────────────────────────────────── */
        .nav-pills .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-muted);
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: 0.2s;
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            font-size: 0.875rem;
            font-weight: 500;
        }

        .nav-pills .nav-link:hover,
        .nav-pills .nav-link.active {
            background: #1e293b !important;
            color: white !important;
        }

        .nav-pills .nav-link.active {
            border-left: 2px solid var(--accent-primary);
        }

        /* ─── Cards ───────────────────────────────────────── */
        .stat-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            height: 100%;
        }

        .stat-card:hover {
            transform: translateY(-4px);
            border-color: var(--accent-primary);
            box-shadow: 0 10px 30px var(--glow-color);
        }

        /* ─── Tables ──────────────────────────────────────── */
        .table { color: #cbd5e1; margin-bottom: 0; }
        .table thead th {
            background: rgba(17, 24, 39, 0.6);
            color: var(--accent-primary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem;
            border: none;
        }
        .table tbody td {
            padding: 1.2rem;
            border-bottom: 1px solid rgba(17, 24, 39, 0.5);
            vertical-align: middle;
        }

        /* ─── Badges ──────────────────────────────────────── */
        .badge-tech {
            background: rgba(51, 120, 243, 0.1);
            border: 1px solid rgba(51, 120, 243, 0.3);
            color: var(--accent-primary);
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        /* ✅ FIXED: was missing */
        .badge-custom-tech {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(51, 120, 243, 0.08);
            border: 1px solid rgba(51, 120, 243, 0.25);
            color: #93c5fd;
            padding: 5px 14px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* ✅ FIXED: was missing */
        .dot-glow {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent-primary);
            box-shadow: 0 0 6px var(--accent-primary);
            animation: pulse-dot 2s infinite;
            flex-shrink: 0;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(0.8); }
        }

        /* ✅ FIXED: was missing */
        .uppercase-tracking {
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        /* ✅ FIXED: was missing */
        .btn-tech-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-muted);
            padding: 6px 16px;
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-tech-outline:hover {
            border-color: var(--accent-primary);
            color: white;
            background: rgba(51, 120, 243, 0.1);
        }

        /* ✅ FIXED: was missing */
        .btn-tech-outline-danger {
            background: transparent;
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: var(--accent-danger);
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
        }

        .btn-tech-outline-danger:hover {
            background: rgba(239, 68, 68, 0.1);
            border-color: var(--accent-danger);
        }

        .btn-tech {
            background: var(--accent-primary);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 600;
            transition: 0.3s;
            cursor: pointer;
        }

        .btn-tech:hover {
            opacity: 0.9;
            box-shadow: 0 0 15px var(--accent-primary);
        }

        .chart-container {
            min-height: 300px;
            position: relative;
        }

        .border-color { border-color: rgba(17, 24, 39, 0.8) !important; }

        .badge { font-size: 0.7rem; padding: 4px 8px; }
        .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1) !important; }
        .bg-secondary-subtle { background-color: rgba(148, 163, 184, 0.1) !important; }

        .transition-row { transition: background 0.15s; }
        .transition-row:hover { background: rgba(51, 120, 243, 0.04) !important; }

        /* ─── Statistics Section Specific ────────────────── */
        .progress-bar-custom {
            height: 8px;
            border-radius: 99px;
            background: rgba(255,255,255,0.06);
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            border-radius: 99px;
            transition: width 1s ease;
        }

        .kpi-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 2.4rem;
            font-weight: 700;
            line-height: 1;
        }

        .wilaya-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.04);
        }

        .wilaya-row:last-child { border-bottom: none; }

        .section-accent-bar {
            width: 4px;
            height: 26px;
            border-radius: 2px;
            background: var(--accent-primary);
            box-shadow: 0 0 10px var(--accent-primary);
            flex-shrink: 0;
        }




        /* تحسينات إضافية للتصميم الأسود */
        #agreementsTable tbody tr:hover {
            background-color: #09090b !important;
            transition: background 0.2s ease;
        }
        .btn-outline-primary:hover {
            background-color: var(--accent-primary);
            color: white;
        }





    </style>

    <div class="d-flex">
        <!-- ═══════════════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════════════ -->
        <div class="sidebar">
            <div class="mb-5 px-2">
                <h3 class="fw-bold text-primary mb-0">Stag.io</h3>
                <small class="text-muted" style="font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;">ADMIN TERMINAL</small>
            </div>

            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist">
                <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#content-dashboard">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </button>
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#content-validations">
                    <i class="bi bi-shield-check"></i> Validations
                    <span class="badge bg-warning text-dark ms-auto">14</span>
                </button>
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#content-agreements">
                    <i class="bi bi-file-earmark-binary"></i> Agreements
                </button>
                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#content-statistics">
                    <i class="bi bi-bar-chart-line"></i> Statistics
                </button>


                <button class="nav-link" data-bs-toggle="pill" data-bs-target="#content-company-requests">
                    <i class="bi bi-building-check"></i> company requests
                </button>

            </div>

            <div class="mt-auto pt-4">
                <hr style="border-color: rgba(255,255,255,0.06);">

                <a href="{{ path('app_logout') }}" class="nav-link-custom text-danger">
                    <i class="bi bi-box-arrow-left"></i> Logout
                </a>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════
             MAIN CONTENT
        ═══════════════════════════════════════════════ -->
        <div class="main-content">
            <div class="tab-content" id="v-pills-tabContent">

                <!-- ════════════════════════════════════════
                     TAB 1 – DASHBOARD OVERVIEW
                ════════════════════════════════════════ -->
                <div class="tab-pane fade show active" id="content-dashboard">
                    <div class="row align-items-end mb-5">
                        <div class="col">
                            <h2 class="fw-bold mb-0">Admin dashboard</h2>
                            <p class="text-secondary small">.</p>
                        </div>
                    </div>

                    <!-- KPI Grid -->
                    <div class="row g-4 mb-5">
                        <div class="col-md-3">
                            <div class="stat-card">
                                <small class="text-muted fw-bold uppercase-tracking">Total Students</small>
                                <div class="kpi-number mt-2">{{ stats.totalStudents }}</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <small class="text-muted fw-bold uppercase-tracking">Partner Companies</small>
                                <div class="kpi-number mt-2">{{ stats.totalCompanies }}</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <small class="text-muted fw-bold uppercase-tracking">Active Agreements</small>
                                <div class="kpi-number mt-2">{{ stats.activeAgreements }}</div>
                                <div class="text-warning small mt-2 fw-bold">⚠ 12 Awaiting signature</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <small class="text-muted fw-bold uppercase-tracking">Pending internship applications</small>
                                <div class="kpi-number mt-2">{{ stats.pendingApps }}</div>
                            </div>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="row g-4 mb-4">
                        <div class="col-lg-8">
                            <div class="stat-card">
                                <h5 class="fw-bold mb-4">Placement & Application Trends</h5>
                                <div class="chart-container">
                                    <canvas id="dashboardMainChart"></canvas>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="stat-card">
                                <h5 class="fw-bold mb-4">Student Status</h5>
                                <div class="chart-container" style="min-height: 250px;">
                                    <canvas id="studentStatusChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!-- END #content-dashboard -->


            <!-- ════════════════════════════════════════
                 TAB 2 – VALIDATIONS
            ════════════════════════════════════════ -->
            <div class="tab-pane fade" id="content-validations">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="section-accent-bar"></div>
                            <h2 class="fw-bold mb-0 text-white">Pending Validations</h2>
                        </div>
                        <p class="text-muted small ms-4">Review and authorize internship agreements in the system.</p>
                    </div>
                    <div class="stat-card py-2 px-4 d-flex align-items-center gap-2" style="border-radius:50px;height:auto;">
                        <div class="dot-glow"></div>
                        <span class="small fw-bold text-white">{{ pendingApps|length }} Requests Awaiting</span>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="row g-4 mb-5">
                    <!-- إجمالي الطلبات (Pending + Active) -->
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-secondary small fw-bold uppercase-tracking">TOTAL REQUESTS</span>
                                <i class="bi bi-file-earmark-text text-primary fs-5"></i>
                            </div>
                            {# نجمع الطلبات المعلقة مع الاتفاقيات النشطة للحصول على الإجمالي #}
                            <div class="kpi-number">{{ stats.pendingApps + stats.activeAgreements }}</div>
                        </div>
                    </div>

                    <!-- الطلبات التي تم التحقق منها (Active Agreements) -->
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-secondary small fw-bold uppercase-tracking">VALIDATED</span>
                                <i class="bi bi-shield-check text-success fs-5"></i>
                            </div>
                            <div class="kpi-number">{{ stats.activeAgreements }}</div>
                        </div>
                    </div>

                    <!-- الطلبات العاجلة (ديناميكية بناءً على منطق معين) -->
                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-secondary small fw-bold uppercase-tracking">PENDING</span>
                                <i class="bi bi-exclamation-triangle text-warning fs-5"></i>
                            </div>
                            <div class="kpi-number">{{ pendingApps|length }}</div>
                        </div>
                    </div>
                </div>
                <!-- Validation Table -->
                <div class="stat-card p-0 overflow-hidden" style="background:#000;">
                    <div class="table-responsive">
                        <table class="table table-dark mb-0" style="--bs-table-bg:transparent;">
                            <thead>
                            <tr style="border-bottom:1px solid var(--border-color);background:rgba(255,255,255,0.02);">
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking">STUDENT & LEVEL</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking">TARGET COMPANY</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking">INTERNSHIP TYPE</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-center">STATUS</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-end">DECISION</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for app in pendingApps %}
                                <tr class="align-middle transition-row" style="border-bottom:1px solid rgba(17,24,39,0.5);">
                                    <td class="p-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                                 style="width:40px;height:40px;background:#09090b;border:1px solid var(--border-color);color:var(--accent-primary);font-size:0.8rem;">
                                                {{ app.student.firstName|first }}{{ app.student.lastName|first }}
                                            </div>
                                            <div>
                                                <p class="fw-bold mb-0 text-white">{{ app.student.firstName }} {{ app.student.lastName }}</p>
                                                <button class="btn btn-link p-0 text-primary small" style="font-size: 0.75rem; text-decoration: none;"
                                                        onclick="openStudentDetails('{{ app.student.id }}')">
                                                    View Profile
                                                </button>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-4">
                                        {# تم إضافة اسم الشركة وزر التفاصيل #}
                                        <p class="mb-0 text-white fw-medium">{{ app.offer.company.companyName }}</p>
                                        <button class="btn btn-link p-0 text-info small" style="font-size: 0.75rem; text-decoration: none;"
                                                onclick="openOfferDetails('{{ app.offer.id }}')">
                                            View Offer & Company
                                        </button>
                                    </td>
                                    <td class="p-4 text-center">
                                        {# نظام الـ Smart Matching #}
                                        <div class="d-flex flex-column align-items-center">
                                            <span class="badge-tech mb-1">{{ app.offer.locationType }}</span>
                                            <small class="text-{{ app.matchingScore > 70 ? 'success' : 'warning' }}" style="font-size: 0.65rem;">
                                                Match: {{ app.matchingScore }}%
                                            </small>
                                        </div>
                                    </td>
                                    <td class="p-4 text-center">
                                        <span class="badge-custom-tech"><span class="dot-glow"></span> PENDING</span>
                                    </td>
                                    <td class="p-4 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form method="post" action="{{ path('app_admin_approve_application', {'id': app.id}) }}" onsubmit="return confirm('Accept this application?');">
                                                <button type="submit" class="btn-tech" style="padding: 6px 14px;">Approve</button>
                                            </form>
                                            <button class="btn-tech-outline-danger" onclick="openStudentRejectModal('{{ app.id }}', '{{ app.student.firstName }}')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div><!-- END #content-validations -->


            <!-- ════════════════════════════════════════
                 TAB 3 – AGREEMENTS
            ════════════════════════════════════════ -->

            <div class="tab-pane fade" id="content-agreements">
                <div class="mb-5">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div class="section-accent-bar" style="width: 4px; height: 24px; background: var(--accent-primary); border-radius: 2px;"></div>
                        <h2 class="fw-bold mb-0 text-white" style="letter-spacing: -0.5px;">Official Agreements</h2>
                    </div>
                    <p class="text-muted small ms-4">Gestion des conventions de stage – Recherche et téléchargement.</p>

                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="position-relative">
                                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-primary"></i>
                                <input type="text"
                                       id="agreementSearchInput"
                                       onkeyup="filterAgreements()"
                                       class="form-control bg-dark border-secondary border-opacity-25 text-white ps-5 py-2 rounded-3"
                                       placeholder="Rechercher par nom d'étudiant..."
                                       style="background: #09090b !important; border: 1px solid #1e293b !important;">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card bg-black border-secondary border-opacity-25 shadow-sm rounded-3 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle mb-0" id="agreementsTable">
                            <thead style="background-color: #000000;"> {# خلفية سوداء ناتئة #}
                            <tr style="border-bottom: 2px solid #1e293b;">
                                <th class="ps-4 py-3 text-uppercase small fw-bold" style="color: #f8fafc; letter-spacing: 0.5px;">Étudiant</th>
                                <th class="py-3 text-uppercase small fw-bold" style="color: #f8fafc; letter-spacing: 0.5px;">Entreprise</th>
                                <th class="py-3 text-uppercase small fw-bold" style="color: #f8fafc; letter-spacing: 0.5px;">Date d'approbation</th>
                                <th class="py-3 text-end pe-4 text-uppercase small fw-bold" style="color: #f8fafc; letter-spacing: 0.5px;">Action</th>
                            </tr>
                            </thead>
                            <tbody style="border-top: none;">
                            {% for app in acceptedApps %}
                                <tr class="agreement-row" style="border-bottom: 1px solid #111827;">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3 bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                                {{ app.student.firstName|first }}{{ app.student.lastName|first }}
                                            </div>
                                            <span class="fw-medium text-white student-name">{{ app.student.fullName }}</span>
                                        </div>
                                    </td>
                                    <td>
                            <span class="text-info">
                                <i class="bi bi-building me-1 small"></i>
                                {# جلب اسم الشركة ديناميكياً من علاقة العرض #}
                                {{ app.offer.company.companyName ?? 'Non spécifié' }}
                            </span>
                                    </td>
                                    <td>
                            <span class="text-white small">
        <i class="bi bi-calendar3 me-1 text-primary"></i> {# أضفت أيقونة التقويم بلون أزرق لجمالية التصميم #}
                                {{ app.approvedAt ? app.approvedAt|date('d M Y') : 'N/A' }}
    </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        {% if app.conventionFile %}
                                            <a href="{{ path('app_admin_download_convention', {'id': app.id}) }}"
                                               class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                <i class="bi bi-file-earmark-pdf me-1"></i> Convention
                                            </a>
                                        {% else %}
                                            <span class="badge bg-dark text-muted fw-normal">Pas de fichier</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <i class="bi bi-folder-x d-block mb-2 fs-2"></i>
                                        Aucune convention générée pour le moment.
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <!-- ════════════════════════════════════════
                 TAB 4 – STATISTICS  ✅ NEW (was missing)
                 Required by proposal: "Global view –
                 students placed vs. unplaced"
            ════════════════════════════════════════ -->
            <div class="tab-pane fade" id="content-statistics">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <div class="section-accent-bar"></div>
                    <h2 class="fw-bold mb-0 text-white">Global Statistics</h2>
                </div>
                <p class="text-muted small mb-5" style="margin-left:20px;">Overview of student placement status across all departments.</p>

                <!-- ── PLACED vs UNPLACED (core requirement) ── -->
                <div class="row g-4 mb-5">
                    <div class="col-md-4">
                        <div class="stat-card text-center">
                            <small class="text-muted fw-bold uppercase-tracking d-block mb-3">TOTAL STUDENTS</small>

                            {# عرض إجمالي عدد الطلاب من قاعدة البيانات #}
                            <div class="kpi-number" style="font-size:3rem;color:white;">
                                {{ stats.totalStudents|default(0) }}
                            </div>

                            <div class="progress-bar-custom mt-3">
                                {# شريط الإجمالي يظل مكتملاً 100% عادةً #}
                                <div class="progress-bar-fill" style="width:100%;background:var(--accent-primary);"></div>
                            </div>

                            {# عرض السنة الأكاديمية ديناميكياً إذا كانت متوفرة #}
                            <small class="text-muted mt-2 d-block">
                                Academic year {{ "now"|date("Y") }}-{{ "now"|date_modify("+1 year")|date("Y") }}
                            </small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card text-center" style="border-color:rgba(16,185,129,0.3);">
                            <small class="text-success fw-bold uppercase-tracking d-block mb-3">✅ PLACED</small>

                            {# عرض عدد الطلاب المثبتين ديناميكياً #}
                            <div class="kpi-number" style="font-size:3rem;color:#10b981;">
                                {{ stats.placedStudentsCount|default(0) }}
                            </div>

                            <div class="progress-bar-custom mt-3">
                                {# جعل عرض الشريط (width) يتناسب مع النسبة المئوية #}
                                <div class="progress-bar-fill"
                                     style="width: {{ stats.placedPercentage|default(0) }}%; background:#10b981;">
                                </div>
                            </div>

                            {# عرض النسبة المئوية كصيغة نصية #}
                            <small class="text-success mt-2 d-block fw-bold">
                                {{ stats.placedPercentage|default(0) }}% of total students
                            </small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="stat-card text-center" style="border-color:rgba(239,68,68,0.3);">
                            <small class="text-danger fw-bold uppercase-tracking d-block mb-3">❌ UNPLACED</small>

                            {# حساب عدد الطلاب غير المثبتين: الإجمالي - المثبتين #}
                            {% set unplacedCount = stats.totalStudents|default(0) - stats.placedStudentsCount|default(0) %}

                            {# حساب النسبة المئوية لغير المثبتين #}
                            {% set unplacedPercentage = (stats.totalStudents|default(0) > 0)
                                ? (unplacedCount / stats.totalStudents) * 100
                                : 0
                            %}

                            <div class="kpi-number" style="font-size:3rem;color:#ef4444;">
                                {{ unplacedCount }}
                            </div>

                            <div class="progress-bar-custom mt-3">
                                {# شريط التقدم لغير المثبتين #}
                                <div class="progress-bar-fill"
                                     style="width: {{ unplacedPercentage }}%; background:#ef4444;">
                                </div>
                            </div>

                            <small class="text-danger mt-2 d-block fw-bold">
                                {{ unplacedPercentage|round(1) }}% still searching
                            </small>
                        </div>
                    </div>
                </div>

                <!-- ── Charts Row ── -->
                <div class="row g-4 mb-5">
                    <div class="col-lg-5">
                        <div class="stat-card">
                            <h5 class="fw-bold mb-1">Placement Rate</h5>
                            <small class="text-muted d-block mb-4">Placed vs. Unplaced breakdown</small>
                            <div class="chart-container" style="min-height:280px;">
                                <canvas id="placementDonutChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="stat-card">
                            <h5 class="fw-bold mb-1">By Industry</h5>
                            <small class="text-muted d-block mb-4">Company sector distribution</small>
                            <div class="chart-container" style="min-height:280px;">
                                <canvas id="industryChart"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <div class="stat-card">
                            <h5 class="fw-bold mb-1">By Type</h5>
                            <small class="text-muted d-block mb-4">Internship categories</small>
                            <div class="d-flex flex-column gap-3 mt-3">
                                {# مصفوفة لتعريف الأنواع والألوان لتسهيل التكرار (Loop) #}
                                {% set internshipTypes = [
                                    {'label': 'PFE', 'count': stats.pfeCount|default(0), 'color': 'var(--accent-primary)', 'textClass': 'text-primary'},
                                    {'label': 'Perfectionnement', 'count': stats.perfectionnementCount|default(0), 'color': 'var(--accent-info)', 'textClass': 'text-info'},
                                    {'label': 'Initiation', 'count': stats.initiationCount|default(0), 'color': 'var(--accent-warning)', 'textClass': 'text-warning'}
                                ] %}

                                {% set total = stats.totalStudents|default(0) %}

                                {% for type in internshipTypes %}
                                    {% set percentage = (total > 0) ? (type.count / total * 100)|round(0) : 0 %}
                                    <div>
                                        <div class="d-flex justify-content-between mb-1">
                                            <small class="text-white fw-bold">{{ type.label }}</small>
                                            <small class="{{ type.textClass }}">{{ percentage }}%</small>
                                        </div>
                                        <div class="progress-bar-custom">
                                            <div class="progress-bar-fill"
                                                 style="width: {{ percentage }}%; background: {{ type.color }};">
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>



            </div><!-- END #content-statistics -->


























            <!-- ════════════════════════════════════════
                 TAB 5 – COMPANY REQUESTS (Dynamic)
            ════════════════════════════════════════ -->
            <div class="tab-pane fade" id="content-company-requests">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="fw-bold mb-0 text-white">Company Verifications</h2>
                        <p style="color: #94a3b8; font-size: 0.85rem;">Validate registration documents and manage access</p>
                    </div>
                    <div class="stat-card py-2 px-4 mb-0 d-flex align-items-center gap-2" style="border-radius: 50px;">
                        <i class="bi bi-shield-lock text-primary"></i>
                        <span class="small fw-bold text-white">Admin Secure Panel</span>
                    </div>
                </div>

                <div class="stat-card p-0 overflow-hidden border-0 shadow-lg" style="background: #000000;">
                    <div class="table-responsive">
                        <table class="table table-dark mb-0" style="--bs-table-bg: transparent; background: rgba(0,0,0,0.4);">
                            <thead>
                            <tr style="border-bottom: 1px solid var(--border-color); background: rgba(255,255,255,0.02);">
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Company Identity</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking">Preview & Verification</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-center">Current Status</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-center">Profile</th>
                                <th class="p-4 small fw-bold text-white-50 uppercase-tracking text-end">Action Panel</th>
                            </tr>
                            </thead>
                            <tbody class="border-0">
                            {% for vr in stats.allRequests %}
                                <tr class="align-middle transition-row" style="border-bottom: 1px solid rgba(17,24,39,0.5);" id="company-row-{{ vr.id }}">

                                    {# Company Identity #}
                                    <td class="p-4">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width:45px;height:45px;background:#09090b;border:1px solid var(--border-color);">
                                                {% if vr.company.logo %}
                                                    <img src="{{ asset('uploads/logos/' ~ vr.company.logo) }}" width="30" class="rounded-circle">
                                                {% else %}
                                                    <i class="bi bi-building text-primary"></i>
                                                {% endif %}
                                            </div>
                                            <div>
                                                <p class="fw-bold mb-0 text-white">{{ vr.company.companyName ?? vr.company.fullName }}</p>
                                                <small style="color:#64748b;">{{ vr.company.wilaya ?? '—' }}, Algeria</small>
                                            </div>
                                        </div>
                                    </td>

                                    {# Document #}
                                    <td class="p-4">
                                        {% if vr.company.verificationFile %}
                                            <a href="{{ asset('uploads/verification/' ~ vr.company.verificationFile) }}" target="_blank"
                                               class="btn btn-dark btn-sm border-secondary border-opacity-25 d-inline-flex align-items-center py-2 px-3 rounded-3">
                                                <i class="bi bi-file-earmark-text me-2 text-primary"></i>
                                                <span class="small fw-bold">VIEW DOCUMENT</span>
                                            </a>
                                        {% else %}
                                            <span class="text-muted small">No file provided</span>
                                        {% endif %}
                                    </td>

                                    {# Status #}
                                    <td class="p-4 text-center">
                                        {% if vr.status == 'Pending' %}
                                            <span class="badge-custom-tech"><span class="dot-glow" style="background-color:#f59e0b;"></span> PENDING</span>
                                        {% elseif vr.status == 'Accepted' %}
                                            <span class="badge-custom-tech text-success"><i class="bi bi-check-circle-fill me-1"></i> PARTNER</span>
                                        {% else %}
                                            <span class="badge-custom-tech text-danger">REJECTED</span>
                                        {% endif %}
                                    </td>

                                    {# ★ زر View Profile — دائماً ظاهر #}
                                    <td class="p-4 text-center">
                                        <button class="btn btn-sm btn-outline-info rounded-3 px-3 py-2"
                                                onclick="openCompanyModal(this)"
                                                data-name="{{ (vr.company.companyName ?? vr.company.fullName)|escape('html_attr') }}"
                                                data-email="{{ vr.company.email|escape('html_attr') }}"
                                                data-phone="{{ (vr.company.phone ?? '')|escape('html_attr') }}"
                                                data-industry="{{ (vr.company.industry ?? '')|escape('html_attr') }}"
                                                data-wilaya="{{ (vr.company.wilaya ?? '')|escape('html_attr') }}"
                                                data-website="{{ (vr.company.website ?? '')|escape('html_attr') }}"
                                                data-bio="{{ (vr.company.bio ?? '')|escape('html_attr') }}"
                                                data-logo="{{ vr.company.logo ? asset('uploads/logos/' ~ vr.company.logo) : '' }}"
                                                data-doc="{{ vr.company.verificationFile ? asset('uploads/verification/' ~ vr.company.verificationFile) : '' }}"
                                                data-status="{{ vr.status }}">
                                            <i class="bi bi-eye me-1"></i> View Profile
                                        </button>
                                    </td>

                                    {# Actions #}
                                    <td class="p-4 text-end">
                                        {% if vr.status == 'Pending' %}
                                            <div class="d-flex justify-content-end gap-2">
                                                <button class="btn btn-sm btn-outline-success rounded-3 px-3 py-2"
                                                        onclick="handleVerification({{ vr.id }}, 'accept', this)">
                                                    <i class="bi bi-check2-circle"></i> Approve
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger rounded-3 px-3 py-2"
                                                        onclick="openRejectModal({{ vr.id }}, '{{ vr.company.companyName|escape('js') }}')">
                                                    <i class="bi bi-shield-x"></i> Reject
                                                </button>
                                            </div>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center p-5 text-muted">No company verification requests found.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div><!-- END tab-content -->
    </div><!-- END main-content -->
    </div><!-- END d-flex -->








    <div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: #09090b; border: 1px solid #ef4444; box-shadow: 0 0 20px rgba(239, 68, 68, 0.2);">
                <div class="modal-header border-secondary border-opacity-25">
                    <h5 class="modal-title text-white" id="rejectModalLabel">
                        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>
                        Reject Company: <span id="rejectCompanyName" class="text-primary"></span>
