    <div class="modal fade" id="studentDetailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="background: #09090b; border: 1px solid var(--border-color) !important;">
                <div id="studentDetailContent" class="modal-body p-0">
                    <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="offerDetailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="background: #09090b; border: 1px solid var(--border-color) !important;">
                <div id="offerDetailContent" class="modal-body p-0">
                    <div class="text-center p-5"><div class="spinner-border text-info"></div></div>
                </div>
            </div>
        </div>
    </div>
    <!-- ─── Scripts ─────────────────────────────────────── -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const CHART_DEFAULTS = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { labels: { color: '#94a3b8', padding: 20, usePointStyle: true } }
            }
        };

        // 1. Dashboard – Trend Line
        new Chart(document.getElementById('dashboardMainChart'), {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [
                    {
                        label: 'Placements',
                        data: [12, 18, 24, 31, 28, 43],
                        borderColor: '#3378f3',
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(51,120,243,0.1)'
                    },
                    {
                        label: 'Applications',
                        data: [30, 42, 55, 68, 60, 87],
                        borderColor: '#0ea5e9',
                        tension: 0.4,
                        fill: true,
                        backgroundColor: 'rgba(14,165,233,0.05)'
                    }
                ]
            },
            options: {
                ...CHART_DEFAULTS,
                plugins: { legend: { display: true, labels: { color: '#94a3b8' } } },
                scales: {
                    y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#94a3b8' } },
                    x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
                }
            }
        });

        // 2. Dashboard – Student Status Donut
        new Chart(document.getElementById('studentStatusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Interning', 'Pending', 'Unplaced'],
                datasets: [{
                    data: [156, 87, 81],
                    backgroundColor: ['#3378f3', '#0ea5e9', '#1e293b'],
                    hoverOffset: 10,
                    borderWidth: 0
                }]
            },
            options: { ...CHART_DEFAULTS, cutout: '70%', plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', padding: 20, usePointStyle: true } } } }
        });

        // 3. Statistics – Placement Donut  ✅ NEW
        new Chart(document.getElementById('placementDonutChart'), {
            type: 'doughnut',
            data: {
                labels: ['Placed ✅', 'Unplaced ❌'],
                datasets: [{
                    data: [156, 168],
                    backgroundColor: ['#10b981', '#ef4444'],
                    hoverOffset: 10,
                    borderWidth: 0
                }]
            },
            options: {
                ...CHART_DEFAULTS,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { color: '#94a3b8', padding: 20, usePointStyle: true } }
                }
            }
        });

        // 4. Statistics – Industry Donut  ✅ canvas now exists
        new Chart(document.getElementById('industryChart'), {
            type: 'doughnut',
            data: {
                labels: ['Tech', 'Telecom', 'Finance', 'Gov'],
                datasets: [{
                    data: [45, 18, 15, 12],
                    backgroundColor: ['#3378f3', '#10b981', '#f59e0b', '#6366f1'],
                    borderWidth: 0
                }]
            },
            options: {
                ...CHART_DEFAULTS,
                cutout: '60%',
                plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', padding: 15, usePointStyle: true } } }
            }
        });





















        // ══════════════════════════════════════════════════
        // ★ متغيرات مشتركة
        // ══════════════════════════════════════════════════
        let currentRejectId = null;
        let currentAppId    = null;

        // ══════════════════════════════════════════════════
        // ★ Company Profile Preview Modal
        // ══════════════════════════════════════════════════
        function openCompanyModal(btn) {
            const d = btn.dataset;

            document.getElementById('cp-name').textContent     = d.name     || 'Company Name';
            document.getElementById('cp-industry').textContent = d.industry || 'Industry';
            document.getElementById('cp-email').textContent    = d.email    || '—';
            document.getElementById('cp-phone').textContent    = d.phone    || 'Not provided';
            document.getElementById('cp-wilaya').textContent   = d.wilaya   || 'Location';
            document.getElementById('cp-website').textContent  = d.website  || '—';
            document.getElementById('cp-bio').textContent      = d.bio      || 'No description provided.';

            // Logo
            const img  = document.getElementById('cp-logo-img');
            const icon = document.getElementById('cp-logo-icon');
            if (d.logo) {
                img.src = d.logo;
                img.classList.remove('d-none');
                icon.classList.add('d-none');
            } else {
                img.classList.add('d-none');
                icon.classList.remove('d-none');
            }

            // Verification Doc
            const docWrap = document.getElementById('cp-doc-wrap');
            if (d.doc) {
                document.getElementById('cp-doc').href = d.doc;
                docWrap.classList.remove('d-none');
            } else {
                docWrap.classList.add('d-none');
            }

            new bootstrap.Modal(document.getElementById('companyProfileModal')).show();
        }

        // ══════════════════════════════════════════════════
        // ★ رفض طلب شراكة شركة
        // ══════════════════════════════════════════════════
        function openRejectModal(id, name) {
            currentRejectId = id;
            document.getElementById('rejectCompanyName').innerText = name;
            document.getElementById('rejectionReason').value = '';
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        }

        async function confirmRejection() {
            const reason = document.getElementById('rejectionReason').value.trim();
            if (!reason) { alert("Please provide a reason for rejection."); return; }

            const btn = event.target;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

            try {
                const res  = await fetch(`/admin/verification-requests/${currentRejectId}/reject`, {
                    method : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body   : JSON.stringify({ reason: reason })
                });
                const data = await res.json();

                if (data.success) {
                    // ★ إغلاق المودال
                    bootstrap.Modal.getInstance(document.getElementById('rejectModal')).hide();

                    // ★ إخفاء الصف بأنيميشن ثم حذفه
                    const row = document.getElementById(`company-row-${currentRejectId}`);
                    if (row) {
                        row.style.transition = 'opacity 0.4s, transform 0.4s';
                        row.style.opacity    = '0';
                        row.style.transform  = 'translateX(30px)';
                        setTimeout(() => row.remove(), 420);
                    }
                } else {
                    alert(data.error || "Error during rejection.");
                    btn.disabled = false;
                    btn.innerHTML = 'Confirm Rejection';
                }
            } catch (err) {
                alert('Network error.');
                btn.disabled = false;
                btn.innerHTML = 'Confirm Rejection';
            }
        }

        // ══════════════════════════════════════════════════
        // ★ رفض طلب طالب (Application)
        // ══════════════════════════════════════════════════
        function openStudentRejectModal(id, name) {
            currentAppId = id;
            document.getElementById('rejectStudentName').innerText = name;
            document.getElementById('studentRejectionReason').value = '';
            new bootstrap.Modal(document.getElementById('studentRejectModal')).show();
        }

        async function confirmStudentRejection() {
            const reason = document.getElementById('studentRejectionReason').value.trim();
            if (!reason) { alert("Please provide a reason for the student."); return; }

            const res = await fetch(`/admin/applications/${currentAppId}/reject`, {
                method : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body   : JSON.stringify({ reason: reason })
            });
            if (res.ok) { location.reload(); }
            else        { alert("Process failed. Please check server logs."); }
        }

        // ══════════════════════════════════════════════════
        // ★ قبول طلب شراكة شركة
        // ══════════════════════════════════════════════════
        async function handleVerification(id, action, btn) {
            if (!confirm(`Are you sure you want to ${action} this request?`)) return;

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const res  = await fetch(`/admin/verification-requests/${id}/${action}`, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Process failed.');
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Network error.');
                btn.disabled = false;
            }
        }












