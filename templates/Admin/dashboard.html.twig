    <!-- Modal لرفض طلبات الطلاب -->
    <div class="modal fade" id="studentRejectModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: #09090b; border: 1px solid #ef4444;">
                <div class="modal-header border-secondary border-opacity-25">
