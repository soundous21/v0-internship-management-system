        // جلب تفاصيل الطالب (Profile Preview)
        async function openStudentDetails(studentId) {
            const modal = new bootstrap.Modal(document.getElementById('studentDetailModal'));
            const container = document.getElementById('studentDetailContent');
            modal.show();

            try {
                const response = await fetch(`/admin/student-profile-preview/${studentId}`);
                container.innerHTML = await response.text();
            } catch (error) {
                container.innerHTML = '<div class="p-4 text-danger">Error loading profile.</div>';
            }
        }

