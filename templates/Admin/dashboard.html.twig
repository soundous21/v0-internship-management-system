        // ══════════════════════════════════════════════════
        // ★ Student Profile Card — Validation Tab
        // ══════════════════════════════════════════════════
        function openStudentCard(btn) {
            const d = btn.dataset;

            const avatar = document.getElementById('sp-avatar');
            if (d.image) {
                avatar.innerHTML = `<img src="${d.image}" class="w-100 h-100" style="object-fit:cover;">`;
            } else {
                const initials = (d.name || 'NA').split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase();
                avatar.innerHTML = `<div class="fw-bold fs-2 text-primary bg-black d-flex align-items-center justify-content-center w-100 h-100">${initials}</div>`;
            }

            document.getElementById('sp-name').textContent       = d.name        || '—';
            document.getElementById('sp-level').textContent      = d.level       || '—';
            document.getElementById('sp-specialty').textContent  = d.specialty   || '—';
            document.getElementById('sp-wilaya').textContent     = d.wilaya      || 'Not set';
            document.getElementById('sp-university').textContent = d.university  || 'Not set';
            document.getElementById('sp-email').textContent      = d.email       || '—';
            document.getElementById('sp-mail-btn').href          = 'mailto:' + (d.email || '');
            document.getElementById('sp-phone-text').textContent = d.phone       || 'Not provided';
            document.getElementById('sp-phone-link').href        = d.phone ? 'tel:' + d.phone : '#';

            const bioSec = document.getElementById('sp-bio-section');
            const bioEl  = document.getElementById('sp-bio');
            if (d.bio && d.bio.trim()) {
                bioEl.textContent = d.bio;
                bioSec.classList.remove('d-none');
            } else {
                bioSec.classList.add('d-none');
            }

            const skillSec  = document.getElementById('sp-skills-section');
            const skillList = document.getElementById('sp-skills-list');
            skillList.innerHTML = '';
            if (d.skills && d.skills.trim()) {
                d.skills.split(',').forEach(s => {
                    const b = document.createElement('span');
                    b.className = 'badge rounded-pill px-3 py-2';
                    b.style.cssText = 'background:rgba(59,130,246,0.1);color:#3b82f6;border:1px solid rgba(59,130,246,0.25);font-size:0.75rem;';
                    b.textContent = s.trim();
                    skillList.appendChild(b);
                });
                skillSec.classList.remove('d-none');
            } else {
                skillSec.classList.add('d-none');
            }

            const gh = document.getElementById('sp-github');
            if (d.github) { gh.href = d.github; gh.classList.remove('d-none'); }
            else           { gh.classList.add('d-none'); }

            const pf = document.getElementById('sp-portfolio');
            if (d.portfolio) { pf.href = d.portfolio; pf.classList.remove('d-none'); }
            else              { pf.classList.add('d-none'); }

            new bootstrap.Modal(document.getElementById('studentProfileModal')).show();
        }

        // ══════════════════════════════════════════════════
        // ★ Offer + Company Card — Validation Tab
        // ══════════════════════════════════════════════════
        function openOfferCard(btn) {
            const d = btn.dataset;

            document.getElementById('oc-title').textContent       = d.offerTitle       || '—';
            document.getElementById('oc-wilaya').textContent      = d.offerWilaya      || '—';
            document.getElementById('oc-duration').textContent    = d.offerDuration    || '—';
            document.getElementById('oc-deadline').textContent    = d.offerDeadline    || '—';
            document.getElementById('oc-intern').textContent      = d.offerInternship  || '—';
            document.getElementById('oc-description').textContent = d.offerDescription || 'No description provided.';
            document.getElementById('oc-type-badge').textContent  = d.offerType        || '';

            const lvl = document.getElementById('oc-level-badge');
            if (d.offerLevel) { lvl.textContent = d.offerLevel; lvl.style.display = ''; }
            else               { lvl.style.display = 'none'; }

            const pct   = parseInt(d.match) || 0;
            const color = pct >= 70 ? '#22c55e' : pct >= 40 ? '#f59e0b' : '#ef4444';
            const label = pct >= 70 ? 'Great Match' : pct >= 40 ? 'Partial Match' : 'Low Match';
            document.getElementById('oc-match-circle').style.borderColor = color;
            document.getElementById('oc-match-pct').style.color   = color;
            document.getElementById('oc-match-pct').textContent   = pct + '%';
            document.getElementById('oc-match-label').style.color = color;
            document.getElementById('oc-match-label').textContent = label;

            const mapWrap = document.getElementById('oc-map-wrap');
            if (d.offerLat && d.offerLng) {
                document.getElementById('oc-map-link').href = `https://www.google.com/maps?q=${d.offerLat},${d.offerLng}`;
                mapWrap.classList.remove('d-none');
            } else {
                mapWrap.classList.add('d-none');
            }

            const skillsEl = document.getElementById('oc-skills');
            skillsEl.innerHTML = '';
            if (d.offerSkills) {
                d.offerSkills.split(',').filter(s => s.trim()).forEach(skill => {
                    skillsEl.innerHTML += `<span style="background:#1e293b;border:1px solid #334155;color:#94a3b8;border-radius:20px;padding:4px 12px;font-size:12px;display:inline-block;">${skill.trim()}</span>`;
                });
            }

            document.getElementById('oc-cp-name').textContent     = d.companyName     || '—';
            document.getElementById('oc-cp-industry').textContent = d.companyIndustry || '—';
            document.getElementById('oc-cp-email').textContent    = d.companyEmail    || '—';
            document.getElementById('oc-cp-phone').textContent    = d.companyPhone    || 'Not provided';
            document.getElementById('oc-cp-wilaya').textContent   = d.companyWilaya   || '—';
            document.getElementById('oc-cp-bio').textContent      = d.companyBio      || '';

            const img  = document.getElementById('oc-logo-img');
            const icon = document.getElementById('oc-logo-icon');
            if (d.companyLogo) { img.src = d.companyLogo; img.classList.remove('d-none'); icon.classList.add('d-none'); }
            else                { img.classList.add('d-none'); icon.classList.remove('d-none'); }

            const webEl  = document.getElementById('oc-cp-website');
            const webRow = document.getElementById('oc-web-row');
            if (d.companyWebsite) {
                webEl.href = d.companyWebsite;
                webEl.textContent = d.companyWebsite;
                webRow.style.display = 'flex';
            } else {
                webRow.style.display = 'none';
            }

            const docWrap = document.getElementById('oc-doc-wrap');
            if (d.companyDoc) { document.getElementById('oc-doc').href = d.companyDoc; docWrap.classList.remove('d-none'); }
            else               { docWrap.classList.add('d-none'); }

            new bootstrap.Modal(document.getElementById('offerCompanyModal')).show();
        }



        function filterAgreements() {
            const input = document.getElementById('agreementSearchInput');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('agreementsTable');
            const tr = table.getElementsByClassName('agreement-row');

            for (let i = 0; i < tr.length; i++) {
                const studentName = tr[i].querySelector('.student-name').innerText.toLowerCase();
                if (studentName.indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }
        }









