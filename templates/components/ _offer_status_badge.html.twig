{#
ملف: templates/components/_offer_status_badge.html.twig
الاستخدام: {{ include('components/_offer_status_badge.html.twig', {offer: offer}) }}
#}

{% set computed = offer.computedStatus %}

{% if computed == 'Active' %}
    <span class="status-badge" style="background:rgba(16,185,129,0.1);color:#10b981;border:1px solid rgba(16,185,129,0.3);">
        <i class="bi bi-circle-fill me-1" style="font-size:8px;"></i> Active
    </span>

{% elseif computed == 'In Progress' %}
    <span class="status-badge" style="background:rgba(59,130,246,0.1);color:#3b82f6;border:1px solid rgba(59,130,246,0.3);">
        <i class="bi bi-play-circle me-1"></i> In Progress
    </span>

{% elseif computed == 'Deadline Over' %}
    <span class="status-badge" style="background:rgba(245,158,11,0.1);color:#f59e0b;border:1px solid rgba(245,158,11,0.3);">
        <i class="bi bi-clock-history me-1"></i> Deadline Over
    </span>

{% elseif computed == 'Expired' %}
    <span class="status-badge" style="background:rgba(220,53,69,0.1);color:#dc3545;border:1px solid rgba(220,53,69,0.3);">
        <i class="bi bi-x-circle me-1"></i> Expired
    </span>

{% elseif computed == 'Closed' %}
    <span class="status-badge" style="background:rgba(100,116,139,0.1);color:#64748b;border:1px solid rgba(100,116,139,0.3);">
        <i class="bi bi-lock me-1"></i> Closed
    </span>

{% elseif computed == 'Draft' %}
    <span class="status-badge" style="background:rgba(148,163,184,0.1);color:#94a3b8;border:1px solid rgba(148,163,184,0.3);">
        <i class="bi bi-pencil me-1"></i> Draft
    </span>
{% endif %}

