{% extends 'base.html.twig' %}

{% block title %}Scientific Events - Health Platform{% endblock %}

{% block body %}
    <div class="container py-5 mt-5">
        <div class="text-center mb-5">
            <h1 class="animated-title fs-1">MEDICAL EVENTS</h1>
            <p class="text-white opacity-75">Discover and participate in the latest scientific research meetings</p>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="card glass-card p-4 border-0 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge bg-primary rounded-pill px-3">CONGRESS</span>
                        <div class="text-info small"><i class="bi bi-calendar3 me-1"></i> May 20, 2026</div>
                    </div>
                    <h3 class="text-white fw-bold">Global Oncology Summit</h3>
                    <p class="text-white opacity-50 small mb-4">Focusing on new immunotherapy treatments and clinical trials in health management.</p>
                    <div class="mt-auto d-flex gap-2">
                        <a href="#" class="btn btn-glow flex-grow-1">View Details</a>
                        <button class="btn btn-outline-light rounded-pill px-3"><i class="bi bi-bookmark"></i></button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card glass-card p-4 border-0 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="badge bg-purple rounded-pill px-3" style="background: var(--bourgeois-purple)">WORKSHOP</span>
                        <div class="text-info small"><i class="bi bi-calendar3 me-1"></i> June 12, 2026</div>
                    </div>
                    <h3 class="text-white fw-bold">AI in Medical Diagnosis</h3>
                    <p class="text-white opacity-50 small mb-4">Hands-on session for researchers using deep learning for medical imaging.</p>
                    <div class="mt-auto d-flex gap-2">
                        <a href="#" class="btn btn-glow flex-grow-1">View Details</a>
                        <button class="btn btn-outline-light rounded-pill px-3"><i class="bi bi-bookmark"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}