 {% extends 'base.html.twig' %}

{% block title %}Event Details - {{ event.title }}{% endblock %}

{% block body %}
<style>
    /* تطبيق هوية base.html.twig بدقة */
    body {
        display: block !important;
        overflow-y: auto !important;
        height: auto !important;
        /* استخدام التدرج اللوني من ملف base  */
        background: radial-gradient(circle at center, var(--royal-blue) 0%, var(--royal-blue) 30%, var(--deep-black) 100%) !important;
        color: var(--pure-white);
    }

    .main-content-wrapper { padding: 40px 0; width: 100%; }

    /* العنوان المتحرك من ملف base [cite: 11, 13] */
    .neon-title {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(to right, var(--pure-white), var(--soft-blue), var(--pure-white));
        background-size: 200% auto;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shine 3s linear infinite;
        text-transform: uppercase;
    }

    @keyframes shine { to { background-position: 200% center; } }

    /* البطاقة الزجاجية الفخمة من ملف base [cite: 9, 10] */
    .admin-full-card {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.15) !important;
        border-radius: 30px !important;
        padding: 40px;
        margin-bottom: 30px;
    }

    .hero-img-box {
        width: 100%;
        max-height: 500px;
        border-radius: 40px;
        overflow: hidden;
        margin: 30px 0;
        border: 2px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 0 50px rgba(0, 82, 212, 0.5);
    }

    .hero-img-box img { width: 100%; height: 100%; object-fit: cover; }

    /* الزر المضيء من ملف base [cite: 15, 17] */
    .btn-admin-glow {
        background: linear-gradient(45deg, var(--bourgeois-purple), var(--royal-blue));
        color: var(--pure-white) !important;
        border: 1px solid rgba(255,255,255,0.2);
        padding: 15px 40px;
        border-radius: 50px;
        text-transform: uppercase;
        font-weight: bold;
        transition: 0.4s;
        display: inline-block;
        text-decoration: none;
    }
    .btn-admin-glow:hover {
        box-shadow: 0 0 20px var(--royal-blue);
        transform: scale(1.05);
    }

    .section-label {
        color: var(--soft-blue);
        text-transform: uppercase;
        letter-spacing: 4px;
        font-weight: 800;
        font-size: 0.85rem;
        margin-bottom: 20px;
        display: block;
    }
</style>

<div class="container main-content-wrapper">
    <header class="event-header-top text-center">
        <span class="badge bg-info mb-3 px-4 py-2 text-dark fw-bold">SCIENTIFIC EVENT 2026</span>
        <h1 class="neon-title">International Cardiology & <br>Tech Innovation</h1>
        <p class="lead mt-4 fs-4" style="color: var(--soft-blue);">
            <i class="bi bi-geo-alt-fill me-2"></i> Grand Medical Center, Dubai |
            <i class="bi bi-calendar3 mx-2"></i> Feb 15-17, 2026
        </p>
    </header>

    <div class="hero-img-box">
        <img src="{{ asset('images/دكتور_قلب.jpg') }}" alt="Cardiology Dubai">
    </div>
    <div class="row">
        <div class="col-lg-8">
            <section class="admin-full-card">
                <span class="section-label">01. Overview</span>
                <h3 class="mb-4 fw-bold">Breaking Frontiers in Cardiology</h3>
                <p class="lh-lg fs-5" style="color: rgba(255,255,255,0.7);">
                    This conference is a global platform for researchers and medical professionals to showcase
                    their latest findings in heart disease treatment using AI and robotics.
                </p>
            </section>
        </div>

        <div class="col-lg-4">
            <section class="admin-full-card">
                <span class="section-label">Key Stats</span>
                <div class="mb-4">
                    <h2 style="color: var(--soft-blue);">50+</h2>
                    <p class="text-white-50">Expert Speakers</p>
                </div>
                <div>
                    <h2 style="color: var(--soft-blue);">1200+</h2>
                    <p class="text-white-50">Global Attendees</p>
                </div>
            </section>
        </div>
    </div>

    <div class="text-center py-5">
        {% if app.user %}
            <a href="{{ path('app_author_dashboard') }}" class="btn-admin-glow mb-3">
                <i class="bi bi-speedometer2 me-2"></i> My Dashboard
            </a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn-admin-glow mb-3">
                <i class="bi bi-box-arrow-in-right me-2"></i> Dashboard Access
            </a>
        {% endif %}

        <a href="{{ path('app_workshops') }}" class="btn-admin-glow ms-4 mb-3">
            <i class="bi bi-calendar3 me-2"></i> View Workshops
        </a>
    </div>
</div>
{% endblock %}